# ============================================================================
# 1C AI Development Environment — .env.example
# ============================================================================
# S8.6 (2026-07-05): Шаблон переменных окружения.
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с реальными секретами!
#
# Использование:
#   cp .env.example .env
#   # Отредактируйте .env, вставив свои значения
#   # .env уже в .gitignore — он не попадёт в коммит
# ============================================================================

# ─── Базовые настройки ───
# Корень проекта (авто-обнаружение, если не задан)
# ONEC_AI_DEV_ENV_ROOT=/path/to/1c-ai-dev-env

# Язык интерфейса (ru / en)
# 1C_AI_LANG=ru

# ─── BSL Language Server ───
# Путь к бинарнику BSL LS (по умолчанию ~/.local/bin/bsl-language-server)
# BSL_LS_BINARY=~/.local/bin/bsl-language-server

# ─── GitHub Releases (data persistence) ───
# Personal Access Token для push/pull data package через GitHub Releases
# ВАЖНО: используйте fine-grained token с минимальными scope!
# GITHUB_TOKEN=github_pat_your_token_here

# ─── MCP Server ───
# Rate limiting: максимум вызовов tool в минуту (0 = отключено)
# MCP_RATE_LIMIT=100

# Prometheus metrics endpoint (порт, если нужен /metrics)
# MCP_METRICS_PORT=8001

# ─── Ollama (RAG, опционально) ───
# URL Ollama API (по умолчанию http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Модель LLM по умолчанию
# OLLAMA_MODEL=llama3.1:8b

# ─── Логирование ───
# Формат логов: json (для CI) или console (для dev)
# LOG_FORMAT=console

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# ─── Backup (опционально) ───
# GitLab mirror (требует GITLAB_TOKEN и GITLAB_REPO в GitHub Secrets)
# GITLAB_TOKEN=your_gitlab_token
# GITLAB_REPO=gitlab.com/username/1c-ai-dev-env.git

# S3 backup (опционально, требует S3_* в GitHub Secrets)
# S3_ENDPOINT=https://s3.example.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=your_bucket_name

# ============================================================================
# ВАЖНО: .env файл НЕ коммитится (в .gitignore).
# Для CI используйте GitHub Secrets (Settings → Secrets and variables → Actions).
# ============================================================================

# ============================================================================
# 1C AI Development Environment — Конфигурация путей
# ============================================================================
# Этот файл содержит все пути к данным и инструментам.
# Генерируется install.sh при установке.
# Можно редактировать вручную — все скрипты читают этот файл.
#
# Формат: KEY=value (без пробелов вокруг =)
# ============================================================================

# === Базовый путь проекта ===
PROJECT_ROOT=/home/z/my-project

# === Данные пользователя (конфигурации 1С) ===
# Активные конфигурации (распакованные)
CONFIG_UT11_DIR=${PROJECT_ROOT}/config
CONFIG_PRIEMKA_DIR=${PROJECT_ROOT}/config-priemka

# Архивы конфигураций (ZIP)
ARCHIVES_DIR=${PROJECT_ROOT}/archives
ARCHIVE_UNP=${ARCHIVES_DIR}/unp_full.zip

# === Справочная информация ===
# Синтакс-помощник (распакованные .hbk)
SYNTAX_HELPER_DIR=${PROJECT_ROOT}/syntax-helper

# Репозитории с инструментами (git clone)
SYNTAX_REPOS_DIR=${PROJECT_ROOT}/syntax

# === Индексы (генерируются скриптами) ===
INDEXES_DIR=${PROJECT_ROOT}/indexes

# Ключевые индексы
SYNTAX_HELPER_INDEX_JSON=${INDEXES_DIR}/syntax-helper-index.json
SYNTAX_HELPER_INDEX_MD=${INDEXES_DIR}/syntax-helper-index.md
FAST_SEARCH_INDEX=${INDEXES_DIR}/fast-search-index.json
UT11_API_REFERENCE_JSON=${INDEXES_DIR}/ut11-api-reference.json
UT11_API_REFERENCE_MD=${INDEXES_DIR}/ut11-api-reference.md
UNP_API_REFERENCE_JSON=${INDEXES_DIR}/unp-api-reference.json
UNP_API_REFERENCE_MD=${INDEXES_DIR}/unp-api-reference.md

# === Инструменты ===
# BSL Language Server
BSL_LS_BINARY=${HOME}/.local/bin/bsl-language-server
BSL_LS_CONFIG=${PROJECT_ROOT}/.bsl-language-server.json

# === Runtime ===
# Скилы, создаваемые агентом (learning loop)
LEARNED_SKILLS_DIR=${PROJECT_ROOT}/learned-skills

# Временные файлы
TMP_DIR=/tmp/bsl_tmp
BASELINE_DIR=/tmp/bsl_baseline

# === Воспроизводимость ===
# Setup (что коммитить в GitHub)
SETUP_DIR=${PROJECT_ROOT}/setup
SETUP_SCRIPTS=${SETUP_DIR}/scripts
SETUP_CONFIGS=${SETUP_DIR}/configs
SETUP_TEMPLATES=${SETUP_DIR}/templates

# === Рабочие скрипты ===
SCRIPTS_DIR=${PROJECT_ROOT}/scripts

# === Конфигурации 1С (список) ===
# Формат: ИМЯ=путь
# Добавляй новые конфигурации сюда
CONFIG_UT11=${CONFIG_UT11_DIR}
CONFIG_PRIEMKA=${CONFIG_PRIEMKA_DIR}

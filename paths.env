# ============================================================================
# 1C AI Development Environment — Конфигурация путей
# ============================================================================
# 4 слоя: data/ (исходные) → derived/ (генерируемые) → tools/ (инструменты) → runtime/ (работа)
# ============================================================================

# === Базовый путь ===
PROJECT_ROOT=/home/z/my-project

# === СЛОЙ 1: data/ — ИСХОДНЫЕ ДАННЫЕ (от пользователя) ===
DATA_DIR=${PROJECT_ROOT}/data
CONFIGS_DIR=${DATA_DIR}/configs
ARCHIVES_DIR=${DATA_DIR}/archives
HBK_DIR=${DATA_DIR}/hbk

# Пути к конкретным конфигурациям (динамические — register_config.py управляет)
# Добавляются автоматически при register_config.py add
CONFIG_UT11=${CONFIGS_DIR}/ut11
CONFIG_PRIEMKA=${CONFIGS_DIR}/priemka

# === СЛОЙ 2: derived/ — ПРОИЗВОДНЫЕ (генерируются скриптами) ===
DERIVED_DIR=${PROJECT_ROOT}/derived
DERIVED_CONFIGS=${DERIVED_DIR}/configs
DERIVED_PLATFORM=${DERIVED_DIR}/platform

# Платформенные индексы
SYNTAX_HELPER_DIR=${DERIVED_PLATFORM}/syntax-helper
SYNTAX_HELPER_INDEX_JSON=${DERIVED_PLATFORM}/syntax-helper-index.json
SYNTAX_HELPER_INDEX_MD=${DERIVED_PLATFORM}/syntax-helper-index.md
FAST_SEARCH_INDEX=${DERIVED_PLATFORM}/fast-search-index.json

# === СЛОЙ 3: tools/ — ИНСТРУМЕНТЫ ===
TOOLS_DIR=${PROJECT_ROOT}/tools
REPOS_DIR=${TOOLS_DIR}/repos
BSL_LS_BINARY=${HOME}/.local/bin/bsl-language-server
BSL_LS_CONFIG=${PROJECT_ROOT}/runtime/.bsl-language-server.json

# === СЛОЙ 4: runtime/ — ФАЙЛЫ РАБОТЫ ===
RUNTIME_DIR=${PROJECT_ROOT}/runtime
SESSION_RESUME=${RUNTIME_DIR}/session-resume.md
PROJECT_CONTEXT=${RUNTIME_DIR}/project-context.md
SOUL_MD=${RUNTIME_DIR}/soul.md
USER_PROFILE=${RUNTIME_DIR}/user-profile.md
WORKLOG=${RUNTIME_DIR}/worklog.md
CONFIG_REGISTRY=${RUNTIME_DIR}/config-registry.json

# === Learning loop ===
LEARNED_SKILLS_DIR=${PROJECT_ROOT}/learned-skills

# === Временные файлы ===
TMP_DIR=/tmp/bsl_tmp
BASELINE_DIR=/tmp/bsl_baseline

# === Setup (для GitHub) ===
SETUP_DIR=${PROJECT_ROOT}/setup
SETUP_SCRIPTS=${SETUP_DIR}/scripts
SCRIPTS_DIR=${PROJECT_ROOT}/scripts

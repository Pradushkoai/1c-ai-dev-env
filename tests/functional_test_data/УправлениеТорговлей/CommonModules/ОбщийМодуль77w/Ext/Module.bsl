				КонецЕсли;
				
				
			КонецЕсли;	 
		КонецЦикла; 

	    Возврат ДокументОплачен;
		
КонецФункции // ()
 

Функция ТекстЗапросаСтатусПредоплатыМССО() //jadmin

	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РасчетыСКлиентами.ЗаказКлиента КАК ЗаказКлиента,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(РасчетыСКлиентами.СуммаКонечныйОстаток, 0) > 0
	|					И ЕСТЬNULL(РасчетыСКлиентами.ОтгружаетсяКонечныйОстаток, 0) <= 0
	|				ТОГДА ЕСТЬNULL(РасчетыСКлиентами.СуммаКонечныйОстаток, 0)
	|			КОГДА ЕСТЬNULL(РасчетыСКлиентами.СуммаКонечныйОстаток, 0) >= 0
	|					И ЕСТЬNULL(РасчетыСКлиентами.ОтгружаетсяКонечныйОстаток, 0) > 0
	|				ТОГДА ЕСТЬNULL(РасчетыСКлиентами.СуммаКонечныйОстаток, 0) + ЕСТЬNULL(РасчетыСКлиентами.ОтгружаетсяКонечныйОстаток, 0)
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ДолгКлиентаВсегоКонечныйОстаток,
	|	РасчетыСКлиентами.КОплатеКонечныйОстаток КАК КОплатеКонечныйОстаток
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.ОстаткиИОбороты(, , , , ) КАК РасчетыСКлиентами
	|ГДЕ
	|	(РасчетыСКлиентами.СуммаОборот <> 0
	|			ИЛИ РасчетыСКлиентами.ОтгружаетсяОборот <> 0)
	|	И РасчетыСКлиентами.ЗаказКлиента = &ЗаказКлиента
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСКлиентами.ЗаказКлиента,
	|	РасчетыСКлиентами.КОплатеКонечныйОстаток";
	Возврат ТекстЗапроса;

КонецФункции // ()

Функция ПроверкаОбещанногоПлатежа(Заказ) Экспорт

	ЕстьОбещанныйПлатеж = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
        |   ОбещанныйПлатежЗаказы.Заказ.Ссылка КАК ЗаказСсылка,
        |   ОбещанныйПлатежЗаказы.Ссылка КАК Ссылка
        |ИЗ
        |   Документ.ОбещанныйПлатеж.Заказы КАК ОбещанныйПлатежЗаказы
        |ГДЕ
        |   ОбещанныйПлатежЗаказы.Заказ.Ссылка = &Ссылка
        |   И ОбещанныйПлатежЗаказы.Ссылка.Проведен = ИСТИНА
        |   И ОбещанныйПлатежЗаказы.Ссылка.Статус = &Статус";
	
	Запрос.УстановитьПараметр("Ссылка", Заказ);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЗаказовПоставщикам.Подтвержден);
    
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() > 0 Тогда
	
		ЕстьОбещанныйПлатеж = ИСТИНА;
	
	КонецЕсли; 
	
	Возврат ЕстьОбещанныйПлатеж;

КонецФункции // ПреверкаОбещанногоПлатежа(Заказ)()





/////Помещения
&НаСервере
Функция ПолучитьПомещениеНоменклатуры(Номенклатура,Склад) Экспорт
	
	Помещение = Справочники.СкладскиеПомещения.ПустаяСсылка();

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НоменклатураПомещения.Номенклатура КАК Номенклатура,
	|	НоменклатураПомещения.Склад КАК Склад,
	|	НоменклатураПомещения.Помещение КАК Помещение
	|ИЗ
	|	РегистрСведений.НоменклатураПомещения КАК НоменклатураПомещения
	|ГДЕ
	|	НоменклатураПомещения.Номенклатура = &Номенклатура
	|	И НоменклатураПомещения.Склад = &Склад";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Помещение = ВыборкаДетальныеЗаписи.Помещение; 
	КонецЦикла;
	
	Возврат Помещение;
КонецФункции

Функция ПолучитьСкладскуюЯчейку(Номенклатура,Помещение,Склад) Экспорт

	Ячейка = Справочники.СкладскиеЯчейки.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура КАК Номенклатура,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад КАК Склад,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Помещение КАК Помещение,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка КАК ОсновнаяЯчейка
		|ИЗ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|ГДЕ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = &Номенклатура
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Помещение = &Помещение";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Помещение", Помещение);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Ячейка = ВыборкаДетальныеЗаписи.Ячейка;
	КонецЦикла;
	
	Возврат Ячейка;


КонецФункции // ()






Процедура ДобавитьТаблицуВМенеджерВременныхТаблиц(Знач МенеджерВременныхТаблиц, Знач ИмяТаблицы, Знач ДанныеТаблицы) Экспорт
	
	ТекстЗапроса = "ВЫБРАТЬ * ПОМЕСТИТЬ %1 ИЗ &ТЗ КАК ТЗ";
	ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяТаблицы);
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТЗ", ДанныеТаблицы);
	Запрос.Выполнить();
	
КонецПроцедуры 






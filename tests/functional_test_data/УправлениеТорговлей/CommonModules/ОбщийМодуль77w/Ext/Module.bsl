 Функция ПолучитьКолВоСтрокЭквивалентОтдельныеГруппыТовара(ТЧ_Товары,ГруппыТовара,Склад,ДатаДок) Экспорт
	СтрокВЭквиваленте = 0;
	
	Запрос = Новый Запрос;
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТЗ_Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_ТЗ_ТОВАРЫ
		|ИЗ
		|	&ТЗ_Товары КАК ТЗ_Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыТЧ.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТАБЗаказ
		|ИЗ
		|	ВТ_ТЗ_ТОВАРЫ КАК ТоварыТЧ
		|ГДЕ
		|	ТоварыТЧ.Номенклатура В ИЕРАРХИИ(&ГруппыТовара)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасценкиКладовщикиСрезПоследних.Цена КАК Цена,
		|	РасценкиКладовщикиСрезПоследних.Номенклатура КАК Номенклатура,
		|	КОЛИЧЕСТВО(РасценкиКладовщикиСрезПоследних.Номенклатура) КАК КолВоСтрок,
		|	РасценкиКладовщикиСрезПоследнихБАЗА.Цена КАК ЦенаЭкв,
		|	РасценкиКладовщикиСрезПоследних.Цена / РасценкиКладовщикиСрезПоследнихБАЗА.Цена КАК Коэф,
		|	ВЫРАЗИТЬ(КОЛИЧЕСТВО(РасценкиКладовщикиСрезПоследних.Номенклатура) * РасценкиКладовщикиСрезПоследних.Цена / РасценкиКладовщикиСрезПоследнихБАЗА.Цена КАК ЧИСЛО(15, 1)) КАК КолВоСтрокЭквивалент
		|ИЗ
		|	ТАБЗаказ КАК ЗаказКлиентаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РасценкиКладовщики.СрезПоследних(&ДатаДок, ) КАК РасценкиКладовщикиСрезПоследних
		|		ПО (ЗаказКлиентаТовары.Номенклатура.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура
		|				ИЛИ ЗаказКлиентаТовары.Номенклатура.Родитель.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура
		|				ИЛИ ЗаказКлиентаТовары.Номенклатура.Родитель.Родитель.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура
		|				ИЛИ ЗаказКлиентаТовары.Номенклатура.Родитель.Родитель.Родитель.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура),
		|	РегистрСведений.РасценкиКладовщики.СрезПоследних(&ДатаДок, ) КАК РасценкиКладовщикиСрезПоследнихБАЗА
		|ГДЕ
		|	РасценкиКладовщикиСрезПоследнихБАЗА.Номенклатура = &БазоваяНоменклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	РасценкиКладовщикиСрезПоследних.Цена,
		|	РасценкиКладовщикиСрезПоследних.Номенклатура,
		|	РасценкиКладовщикиСрезПоследнихБАЗА.Цена";
	
	Запрос.Текст = ТекстЗапроса;
	Если Склад = Справочники.Склады.Склад3 Тогда
		Запрос.УстановитьПараметр("БазоваяНоменклатура", Справочники.Номенклатура.НайтиПоКоду("00-00000001"));  ///1. Семена овощей
	Иначе
		Запрос.УстановитьПараметр("БазоваяНоменклатура", Справочники.Номенклатура.НайтиПоКоду("00-00000024"));  ///8.удобрения
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаДок", ДатаДок);
	Запрос.УстановитьПараметр("ТЗ_Товары", ТЧ_Товары);
	Запрос.УстановитьПараметр("ГруппыТовара", ГруппыТовара);

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	

	СтрокВЭквиваленте = Окр(РезультатЗапроса.Итог("КолВоСтрокЭквивалент"),0);
	Возврат СтрокВЭквиваленте;
	
КонецФункции

Функция ДоступноСтрокКСборкеОтдельныеГруппыТовара(Склад, ГруппаНоменклатуры, ДатаОтгрузки, ДатаДок, ПриоритетСборки = Неопределено,СпособДоставки) Экспорт	

	

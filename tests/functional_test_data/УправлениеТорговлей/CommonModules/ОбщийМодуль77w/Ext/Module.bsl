Процедура КонтрольСрокаДействияЗаказовКлиента() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Ссылка,
		|	ЗаказКлиента.Проведен КАК Проведен,
		|	ЗаказКлиента.Статус КАК Статус,
		|	ЗаказКлиента.Партнер.ВидПартнераКонтрагента КАК ПартнерВидПартнераКонтрагента,
		|	ЗаказКлиента.СрокДействияЗаказа КАК СрокДействияЗаказа,
		|	ЗаказКлиента.ПорядокРасчетов КАК ПорядокРасчетов,
		|	ЗаказКлиента.Склад.ТипСклада КАК СкладТипСклада
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.Проведен = ИСТИНА
		|	И ЗаказКлиента.Статус = &Статус
		|	И ЗаказКлиента.СрокДействияЗаказа < &СрокДействияЗаказа
		|	И ЗаказКлиента.Партнер.ВидПартнераКонтрагента <> &ПартнерВидПартнераКонтрагента
		|	И ЗаказКлиента.Соглашение <> &Соглашение
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказКлиента.СрокДействияЗаказа";
	
	Запрос.УстановитьПараметр("СрокДействияЗаказа", ТекущаяДата());
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЗаказовКлиентов.КОбеспечению);
	//Запрос.УстановитьПараметр("ТипСклада", Перечисления.ТипыСкладов.ОптовыйСклад);
	Запрос.УстановитьПараметр("ПартнерВидПартнераКонтрагента", Справочники.ВидПартнераКонтрагента.НайтиПоКоду("000000007"));     //Торговые сети
	Запрос.УстановитьПараметр("Соглашение", Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Благотворительность",ИСТИНА));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗаказСсылка = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		
		Если ВыборкаДетальныеЗаписи.СкладТипСклада = Перечисления.ТипыСкладов.РозничныйМагазин Тогда
		    ЗаказСсылка.Статус = Перечисления.СтатусыЗаказовКлиентов.Отменен;
			ЗаказСсылка.ДатаОтменыЗаказа = ТекущаяДата();
			Попытка
			
				ЗаказСсылка.Записать(РежимЗаписиДокумента.Проведение);
			
			Исключение
			
			КонецПопытки;
		Иначе
			Если ВыборкаДетальныеЗаписи.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным Тогда
				
				Оплачено = ПроверкаСуммОплат(ЗаказСсылка.Ссылка);
	
				Если Оплачено > 0 Тогда
					Продолжить;
				Иначе
					Попытка
					
						ЗаказСсылка.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					
					Исключение
					
					КонецПопытки;
				КонецЕсли;
			Иначе
				Попытка
					
					ЗаказСсылка.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					
				Исключение
					
				КонецПопытки;
				
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры







Функция ПроверкаСуммОплат(ЗаказСсылка) //jadmin

	Оплачено = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СостоянияЗаказовКлиентов.Заказ КАК Заказ,
		|	СостоянияЗаказовКлиентов.Состояние КАК Состояние,
		|	СостоянияЗаказовКлиентов.ДатаСобытия КАК ДатаСобытия,
		|	СостоянияЗаказовКлиентов.СуммаОплаты КАК СуммаОплаты,
		|	СостоянияЗаказовКлиентов.ПроцентОплаты КАК ПроцентОплаты,
		|	СостоянияЗаказовКлиентов.СуммаОтгрузки КАК СуммаОтгрузки,
		|	СостоянияЗаказовКлиентов.ПроцентОтгрузки КАК ПроцентОтгрузки,
		|	СостоянияЗаказовКлиентов.СуммаДолга КАК СуммаДолга,
		|	СостоянияЗаказовКлиентов.ПроцентДолга КАК ПроцентДолга,
		|	СостоянияЗаказовКлиентов.ЕстьРасхожденияОрдерНакладная КАК ЕстьРасхожденияОрдерНакладная
		|ИЗ
		|	РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|ГДЕ
		|	СостоянияЗаказовКлиентов.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", ЗаказСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Оплачено =  Оплачено + ВыборкаДетальныеЗаписи.СуммаОплаты; 
	КонецЦикла;
	
	Возврат Оплачено;
	
КонецФункции // ()




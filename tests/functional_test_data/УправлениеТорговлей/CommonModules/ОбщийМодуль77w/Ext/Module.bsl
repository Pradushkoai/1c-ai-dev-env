	|	ТАБИТОГ КАК ТАБИТОГ
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ТАБИТОГ.ДатаОтгрузкиОчередь, ДЕНЬ) <= &ДатаОкон
	|	И ТАБИТОГ.Склад = &Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(ТАБИТОГ.ДатаОтгрузкиОчередь, ДЕНЬ),
	|	ТАБИТОГ.Склад
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеПроизводственногоКалендаря.Дата,
	|	0,
	|	0,
	|	0,
	|	&Склад
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &ДатаНач И &ДатаОкон
	|	И ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &ПроизводственныйКалендарь
	|	И (ДанныеПроизводственногоКалендаря.ВидДня = ЗНАЧЕНИЕ(Перечисление.ВидыДнейПроизводственногоКалендаря.Рабочий)
	|			ИЛИ ДанныеПроизводственногоКалендаря.ВидДня = ЗНАЧЕНИЕ(Перечисление.ВидыДнейПроизводственногоКалендаря.Предпраздничный))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТАБПРОМ1.Дата КАК Дата,
	|	СУММА(ТАБПРОМ1.КоличествоСтрокВЭквиваленте) КАК КоличествоСтрокВЭквиваленте,
	|	СУММА(ТАБПРОМ1.КоличествоСтрокВЭквивалентеОпт) КАК КоличествоСтрокВЭквивалентеОпт,
	|	СУММА(ТАБПРОМ1.КоличествоСтрокВЭквивалентеРозница) КАК КоличествоСтрокВЭквивалентеРозница,
	|	ТАБПРОМ1.Склад КАК Склад
	|ПОМЕСТИТЬ ТАБПРОМ
	|ИЗ
	|	ТАБПРОМ1 КАК ТАБПРОМ1
	|
	|СГРУППИРОВАТЬ ПО
	|	ТАБПРОМ1.Дата,
	|	ТАБПРОМ1.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТАБПРОМ.Дата КАК Дата,
	|	ЕСТЬNULL(ТАБПРОМ.КоличествоСтрокВЭквиваленте, 0) КАК КоличествоСтрокВЭквиваленте,
	|	ЕСТЬNULL(ТАБПРОМ.КоличествоСтрокВЭквивалентеОпт, 0) КАК КоличествоСтрокВЭквивалентеОпт,
	|	ЕСТЬNULL(ТАБПРОМ.КоличествоСтрокВЭквивалентеРозница, 0) КАК КоличествоСтрокВЭквивалентеРозница,
	|	ТАБПРОМ.Склад КАК Склад,
	|	СУММА(ЕСТЬNULL(ТАБСУММАЭКВ.КоличествоСтрокВЭквиваленте, 0)) КАК ВсегоСтрокВЭквиваленте,
	|	СУММА(ЕСТЬNULL(ТАБСУММАЭКВ.КоличествоСтрокВЭквивалентеОпт, 0)) КАК ВсегоСтрокВЭквивалентеОпт,
	|	СУММА(ЕСТЬNULL(ТАБСУММАЭКВ.КоличествоСтрокВЭквивалентеРозница, 0)) КАК ВсегоСтрокВЭквивалентеРозница
	|ПОМЕСТИТЬ ТАБКОЛВОСТРОК
	|ИЗ
	|	ТАБПРОМ КАК ТАБПРОМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТАБПРОМ КАК ТАБСУММАЭКВ
	|		ПО ТАБПРОМ.Дата >= ТАБСУММАЭКВ.Дата
	|			И ТАБПРОМ.Склад = ТАБСУММАЭКВ.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	ТАБПРОМ.Дата,
	|	ТАБПРОМ.КоличествоСтрокВЭквиваленте,
	|	ТАБПРОМ.КоличествоСтрокВЭквивалентеОпт,
	|	ТАБПРОМ.КоличествоСтрокВЭквивалентеРозница,
	|	ТАБПРОМ.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТАБДАТЫЛИМИТЫ.ДАТА КАК ДАТА,
	|	ЕСТЬNULL(ТАБДАТЫЛИМИТЫ.ЛимитСтрокВсего, 0) КАК ЛимитСтрокВсего,
	|	ЕСТЬNULL(ТАБДАТЫЛИМИТЫ.ЛимитСтрокОпт, 0) КАК ЛимитСтрокОпт,
	|	ЕСТЬNULL(ТАБДАТЫЛИМИТЫ.ЛимитСтрокРозница, 0) КАК ЛимитСтрокРозница,
	|	ТАБДАТЫЛИМИТЫ.Склад КАК Склад,
	|	СУММА(ЕСТЬNULL(ТАБДАТЫЛИМИТЫСУММА.ЛимитСтрокВсего, 0)) КАК ВсегоЛимит,
	|	СУММА(ЕСТЬNULL(ТАБДАТЫЛИМИТЫСУММА.ЛимитСтрокОпт, 0)) КАК ВсегоЛимитОпт,
	|	СУММА(ЕСТЬNULL(ТАБДАТЫЛИМИТЫСУММА.ЛимитСтрокРозница, 0)) КАК ВсегоЛимитРозница
	|ПОМЕСТИТЬ ТАБЛИМИТЫСУММА
	|ИЗ
	|	ТАБДАТЫЛИМИТЫ КАК ТАБДАТЫЛИМИТЫ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТАБДАТЫЛИМИТЫ КАК ТАБДАТЫЛИМИТЫСУММА
	|		ПО ТАБДАТЫЛИМИТЫ.ДАТА >= ТАБДАТЫЛИМИТЫСУММА.ДАТА
	|			И ТАБДАТЫЛИМИТЫ.Склад = ТАБДАТЫЛИМИТЫСУММА.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	ТАБДАТЫЛИМИТЫ.ДАТА,
	|	ТАБДАТЫЛИМИТЫ.ЛимитСтрокВсего,
	|	ТАБДАТЫЛИМИТЫ.ЛимитСтрокОпт,
	|	ТАБДАТЫЛИМИТЫ.ЛимитСтрокРозница,
	|	ТАБДАТЫЛИМИТЫ.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТАБЛИМИТЫСУММА.ДАТА КАК ДАТА,
	|	ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокВсего, 0) КАК ЛимитСтрокВсего,
	|	ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокОпт, 0) КАК ЛимитСтрокОпт,
	|	ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокРозница, 0) КАК ЛимитСтрокРозница,
	|	ТАБЛИМИТЫСУММА.Склад КАК Склад,
	|	ЕСТЬNULL(ТАБЛИМИТЫСУММА.ВсегоЛимит, 0) КАК ВсегоЛимит,
	|	ЕСТЬNULL(ТАБЛИМИТЫСУММА.ВсегоЛимитОпт, 0) КАК ВсегоЛимитОпт,
	|	ЕСТЬNULL(ТАБЛИМИТЫСУММА.ВсегоЛимитРозница, 0) КАК ВсегоЛимитРозница,
	|	ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквиваленте, 0) КАК КоличествоСтрокВЭквиваленте,
	|	ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквивалентеОпт, 0) КАК КоличествоСтрокВЭквивалентеОпт,
	|	ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквивалентеРозница, 0) КАК КоличествоСтрокВЭквивалентеРозница,
	|	ЕСТЬNULL(ТАБКОЛВОСТРОК.ВсегоСтрокВЭквиваленте, 0) КАК ВсегоСтрокВЭквиваленте,
	|	ЕСТЬNULL(ТАБКОЛВОСТРОК.ВсегоСтрокВЭквивалентеОпт, 0) КАК ВсегоСтрокВЭквивалентеОпт,
	|	ЕСТЬNULL(ТАБКОЛВОСТРОК.ВсегоСтрокВЭквивалентеРозница, 0) КАК ВсегоСтрокВЭквивалентеРозница,             	
	|	ВЫБОР
	|		КОГДА ТАБЛИМИТЫСУММА.ДАТА = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
	|				И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) >= 34200
	|				И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) <= 37800            
	|			ТОГДА ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокВсего, 0)/8*6.5 - ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквиваленте, 0)
	|		ИНАЧЕ ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокВсего, 0) - ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквиваленте, 0)
	|	КОНЕЦ КАК ДоступноСтрок,
	|	ВЫБОР
	|		КОГДА ТАБЛИМИТЫСУММА.ДАТА = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
	|				И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) >= 34200
	|				И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) <= 37800            
	|			ТОГДА ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокВсего, 0)/8*6.5 - ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквиваленте, 0)
	|		ИНАЧЕ ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокОпт, 0) - ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквивалентеОпт, 0)
	|	КОНЕЦ КАК ДоступноСтрокОпт,
	|	ВЫБОР
	|		КОГДА ТАБЛИМИТЫСУММА.ДАТА = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
	|				И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) >= 34200
	|				И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) <= 37800
	|			ТОГДА ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокВсего, 0)/8*6.5  - ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквиваленте, 0)
	|		ИНАЧЕ ЕСТЬNULL(ТАБЛИМИТЫСУММА.ЛимитСтрокРозница, 0) - ЕСТЬNULL(ТАБКОЛВОСТРОК.КоличествоСтрокВЭквивалентеРозница, 0)
	|	КОНЕЦ КАК ДоступноСтрокРозница
	|ИЗ
	|	ТАБЛИМИТЫСУММА КАК ТАБЛИМИТЫСУММА
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТАБКОЛВОСТРОК КАК ТАБКОЛВОСТРОК
	|		ПО ТАБЛИМИТЫСУММА.Склад = ТАБКОЛВОСТРОК.Склад
	|			И ТАБЛИМИТЫСУММА.ДАТА = ТАБКОЛВОСТРОК.Дата
	|ГДЕ
	|	ТАБЛИМИТЫСУММА.Склад = &Склад";
	
	
	
	ДатаСледРабДня = ОбщийМодуль77w.ДобавитьРабочиеДни(ТекущаяДата(),1) + ЧАС(ТекущаяДата())*3600+МИНУТА(ТекущаяДата())*60;
	ДатаНеделяЭквивалент = ОбщийМодуль77w.ДобавитьРабочиеДни(ТекущаяДата(),5) + ЧАС(ТекущаяДата())*3600;
	
	//Запрос.УстановитьПараметр("ДатаОкон", ДатаНеделяЭквивалент );
	Запрос.УстановитьПараметр("ДатаОкон", ДатаОтгрузки );
	Запрос.УстановитьПараметр("Склад", Склад);
	//Запрос.УстановитьПараметр("ВидДня", Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий);
	//Запрос.УстановитьПараметр("ВидДня1", Перечисления.ВидыДнейПроизводственногоКалендаря.Предпраздничный); 
	Запрос.УстановитьПараметр("ДатаНач", НачалоДня(ТекущаяДата()-86400*5));
	
	//Если СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
	//	Запрос.УстановитьПараметр("ДатаТек", ТекущаяДата());  	
	//Иначе	
	   	Запрос.УстановитьПараметр("ДатаТек", ДатаСледРабДня);  
	//КонецЕсли;
	
	
	//Если ПриоритетСборки = Перечисления.ПриоритетСборки.Магазины  Тогда
	//   	Если НачалоДня(ДатаСледРабДня) - НачалоДня(ТекущаяДата()) > 1 Тогда		
	//			Запрос.УстановитьПараметр("ДатаТек", НачалоДня(ДатаСледРабДня)+ ЧАС(ТекущаяДата())*3600);	
	//	КонецЕсли;	
	//КонецЕсли;
       
	
	Запрос.УстановитьПараметр("ПроизводственныйКалендарь", Справочники.ПроизводственныеКалендари.НайтиПоКоду("РБ"));
	Запрос.УстановитьПараметр("ОформлятьСначалаНакладные", ЛОЖЬ); 
	Запрос.УстановитьПараметр("ГруппаНоменклатуры", ГруппаНоменклатуры);           //Лук, Картошка
		
	Если Склад = Справочники.Склады.Склад3
		ИЛИ Склад = Справочники.Склады.НайтиПоНаименованию("Склад N 3 опт",ИСТИНА) Тогда
		Запрос.УстановитьПараметр("НомБазовая", Справочники.Номенклатура.НайтиПоКоду("00-00000001"));  //    семена
	ИначеЕсли Склад = Справочники.Склады.Склад5 Тогда
		Запрос.УстановитьПараметр("НомБазовая", Справочники.Номенклатура.НайтиПоКоду("00-00000024"));  //  удобрения
	КонецЕсли;	    
	
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ЛимитСтрок = 0;
	ЭквивалентНеделя = 0;
	
	Если РезультатЗапроса.Количество()>0 Тогда
		
		НайденныеСтроки = РезультатЗапроса.НайтиСтроки(Новый Структура("Дата",ДатаОтгрузки));
		Если НайденныеСтроки.Количество() > 0 Тогда
			Если ПриоритетСборки = Перечисления.ПриоритетСборки.Клиенты Тогда
				
				ЛимитСтрок =  НайденныеСтроки[0].ДоступноСтрокОпт;
			ИначеЕсли ПриоритетСборки = Перечисления.ПриоритетСборки.Магазины  Тогда
				ЛимитСтрок =  НайденныеСтроки[0].ДоступноСтрокРозница;
			Иначе
				ЛимитСтрок =  НайденныеСтроки[0].ДоступноСтрок;		
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	

	ДоступноСтрок = ЛимитСтрок;
		
	
	Если Константы.ОграничениеПоЭквивалентуСтрок.Получить()=Истина Тогда
	
		ДоступноСтрок = 0 ;
	
	КонецЕсли;
	
	
	Возврат ДоступноСтрок;


КонецФункции // ()
/////





Функция ДоступноСтрокКСборке_ЗАДАНИЕ_НА_ПЕРЕВОЗКУ(Склад, ДатаОтгрузки, ДатаДок, ПриоритетСборки = Неопределено,СпособДоставки) Экспорт
	

	
	
	ДоступноСтрок = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст =  	
	///v5
	"ВЫБРАТЬ
    |   ДанныеПроизводственногоКалендаря.Дата КАК ДАТА,
    |   ВЫБОР
    |       КОГДА ДанныеПроизводственногоКалендаря.Дата = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
    |               И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) <= 37800
    |           ТОГДА ЛимитыСборкиСклада.ЛимитСтрокВсего
    |       КОГДА ДанныеПроизводственногоКалендаря.Дата = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
    |               И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) > 37800
    |           ТОГДА 0
    |       КОГДА ДанныеПроизводственногоКалендаря.Дата < НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
    |           ТОГДА 0
    |       ИНАЧЕ ЛимитыСборкиСклада.ЛимитСтрокВсего
    |   КОНЕЦ КАК ЛимитСтрокВсего,
    |   ВЫБОР
    |       КОГДА ДанныеПроизводственногоКалендаря.Дата = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
    |               И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) < 34200
    |           ТОГДА ЛимитыСборкиСклада.ЛимитСтрокОпт
    |       КОГДА ДанныеПроизводственногоКалендаря.Дата = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)
    |               И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) >= 34200
    |               И РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ), &ДатаТек, СЕКУНДА) <= 37800
    |           ТОГДА ЛимитыСборкиСклада.ЛимитСтрокВсего
    |       КОГДА ДанныеПроизводственногоКалендаря.Дата = НАЧАЛОПЕРИОДА(&ДатаТек, ДЕНЬ)

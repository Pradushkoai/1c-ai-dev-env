	 |				Документ.ЧекККМВозврат КАК Т
	 |			ГДЕ
	 |				Т.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	 |				И Т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	 |				И Т.КассоваяСмена.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта)
	 |				И Т.Партнер = &Партнер
	 |				И Т.Партнер <> ЗНАЧЕНИЕ(Справочник.Партнеры.РозничныйПокупатель))
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	СУММА(ЕСТЬNULL(ИТОГ.Количество, 0)) КАК Количество,
	 |	СУММА(ЕСТЬNULL(ИТОГ.Сумма, 0)) КАК Сумма
	 |ПОМЕСТИТЬ ТАБИТОГ
	 |ИЗ
	 |	ИТОГ КАК ИТОГ
	 |
	 |ОБЪЕДИНИТЬ ВСЕ
	 |
	 |ВЫБРАТЬ
	 |	0,
	 |	МССО_ОборотыКлиентов.Оборот
	 |ИЗ
	 |	РегистрСведений.МССО_ОборотыКлиентов КАК МССО_ОборотыКлиентов
	 |ГДЕ
	 |	МССО_ОборотыКлиентов.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	 |	И МССО_ОборотыКлиентов.Контрагент.Партнер = &Партнер
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	СУММА(ТАБИТОГ.Количество) КАК Количество,
	 |	СУММА(ТАБИТОГ.Сумма) КАК Сумма
	 |ИЗ
	 |	ТАБИТОГ КАК ТАБИТОГ";
	
	
	Запрос.УстановитьПараметр("Партнер", Контрагент.Партнер);
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

	
	РезЗпр = Запрос.Выполнить().Выгрузить();
		СуммаОборотаМССО = 0;
		
		Если РезЗпр.Количество() > 0 Тогда
			СуммаОборотаМССО = РезЗпр.Итог("Сумма");
		КонецЕсли;
			
		СкидкаОборот = 0;
		
		Если СуммаОборотаМССО >= 2000 и СуммаОборотаМССО < 10000 Тогда
			СкидкаОборот = 5;
		ИначеЕсли СуммаОборотаМССО >= 10000 и СуммаОборотаМССО < 20000 Тогда
			СкидкаОборот = 7;
		ИначеЕсли СуммаОборотаМССО >= 20000  Тогда
			СкидкаОборот = 10;
		КонецЕсли; 

	
		СкидкаОктябрьЯнварь = 0;
		//Если Месяц(ДатаОкончания) = 10 
		//	ИЛИ Месяц(ДатаОкончания) = 11 
		//		ИЛИ Месяц(ДатаОкончания) = 12 
		//			ИЛИ (Месяц(ДатаОкончания) = 1 И День(ДатаОкончания)< 10) Тогда  
		//				 СкидкаОктябрьЯнварь = 5;
		//КонецЕсли; 
	
	СкидкаОбщая = СкидкаОктябрьЯнварь+СкидкаОборот;
	
КонецПроцедуры

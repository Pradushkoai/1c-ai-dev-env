&НаСервере
Процедура УсушкаЛука() Экспорт
    
    //КоэфУсушки = 0.004167;
    КоэфУсушки = Константы.КоэфУсушкиЛука.Получить();
    
    СписокНоменклатуры = Новый СписокЗначений;
    СписокНоменклатуры.Добавить(Справочники.Номенклатура.НайтиПоКоду("00-00000017"));
    СписокНоменклатуры.Добавить(Справочники.Номенклатура.НайтиПоКоду("00-00000018"));
    СписокНоменклатуры.Добавить(Справочники.Номенклатура.НайтиПоКоду("00-00015446"));
    
    ВыборкаСкладов = Справочники.Склады.Выбрать();
    Пока ВыборкаСкладов.Следующий() Цикл
        
        Если ВыборкаСкладов.ТипСклада <> Перечисления.ТипыСкладов.РозничныйМагазин ИЛИ ВыборкаСкладов.ЭтоГруппа Тогда
        	Продолжить;
        КонецЕсли; 
        
        Запрос = Новый Запрос;
        Запрос.Текст = 
        "ВЫБРАТЬ
        |   КалендарныеГрафики.ДатаГрафика КАК ДатаКалендаря
        |ПОМЕСТИТЬ Дни
        |ИЗ
        |   РегистрСведений.КалендарныеГрафики КАК КалендарныеГрафики
        |ГДЕ
        |   КалендарныеГрафики.ДатаГрафика МЕЖДУ &НачалоПериода И &КонецПериода
        |;
        |
        |////////////////////////////////////////////////////////////////////////////////
        |ВЫБРАТЬ
        |   Движения.Номенклатура КАК Номенклатура,
        |   Движения.Серия КАК Серия,
        |   ДНИ.ДатаКалендаря КАК ДатаКалендаря,
        |   СУММА(ВЫБОР
        |           КОГДА Движения.Период = &НачалоПериода
        |               ТОГДА Движения.ВНаличииКонечныйОстаток
        |           ИНАЧЕ ВЫБОР
        |                   КОГДА Движения.Период <= ДНИ.ДатаКалендаря
        |                       ТОГДА Движения.ВНаличииОборот
        |                   ИНАЧЕ 0
        |               КОНЕЦ
        |       КОНЕЦ) КАК КоличествоКонечныйОстаток,
        |   Движения.Склад КАК Склад
        |ПОМЕСТИТЬ ТАБОСТАТКИ
        |ИЗ
        |   Дни КАК ДНИ
        |       ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, День, , ) КАК Движения
        |       ПО (Движения.Период <= ДНИ.ДатаКалендаря)
        |ГДЕ
        |   Движения.Номенклатура В ИЕРАРХИИ(&СписокНоменклатуры)
        |   И Движения.Склад = &Склад
        |
        |СГРУППИРОВАТЬ ПО
        |   Движения.Номенклатура,
        |   ДНИ.ДатаКалендаря,
        |   Движения.Серия,
        |   Движения.Склад
        |;
        |
        |////////////////////////////////////////////////////////////////////////////////
        |ВЫБРАТЬ
        |   ТАБОСТАТКИ.Номенклатура КАК Номенклатура,
        |   ТАБОСТАТКИ.Серия КАК Серия,
        |   ТАБОСТАТКИ.ДатаКалендаря КАК ДатаКалендаря,
        |   ТАБОСТАТКИ.КоличествоКонечныйОстаток КАК КоличествоКонечныйОстаток,
        |   ВЫРАЗИТЬ(ТАБОСТАТКИ.КоличествоКонечныйОстаток * &КоэфУсушки КАК ЧИСЛО(15, 3)) КАК УСУШКА,
        |   ВЫРАЗИТЬ(ТАБОСТАТКИ.КоличествоКонечныйОстаток - ТАБОСТАТКИ.КоличествоКонечныйОстаток * &КоэфУсушки КАК ЧИСЛО(15, 3)) КАК ОСТАТОК,
        |   ТАБОСТАТКИ.Склад КАК Склад
        |ИЗ
        |   ТАБОСТАТКИ КАК ТАБОСТАТКИ";
        
        Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(ТекущаяДата()));
        Запрос.УстановитьПараметр("КонецПериода", КонецДня(ТекущаяДата()));
        Запрос.УстановитьПараметр("КоэфУсушки", КоэфУсушки);
        
        Запрос.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
        //Запрос.УстановитьПараметр("Серия", Серия);
        Запрос.УстановитьПараметр("Склад", ВыборкаСкладов.Ссылка);
        
        РезультатЗапроса = Запрос.Выполнить();
        
        ТЗ_Усушка = РезультатЗапроса.Выгрузить();
        Счет = 0;
        Повтор = 1;
        
        Для Счет = 0 По ТЗ_Усушка.Количество()-1 Цикл
            Номенклатура = ТЗ_Усушка[Счет].Номенклатура;
            Серия = ТЗ_Усушка[Счет].Серия;
            Склад = ТЗ_Усушка[Счет].Склад;	
            Период = ТЗ_Усушка[Счет].ДатаКалендаря;
            
            Если ТЗ_Усушка[Счет].КоличествоКонечныйОстаток > 0  Тогда
                
                //Если Счет > 0 И ТЗ_Усушка[Счет].КоличествоКонечныйОстаток = ТЗ_Усушка[Счет-1].КоличествоКонечныйОстаток Тогда
                //	Остаток = ТЗ_Усушка[Счет].ОСТАТОК - Повтор * КоэфУсушки;
                //	Усушка = Остаток * КоэфУсушки;
                //	Повтор = Повтор + 1;
                //	
                //Иначе
                Остаток = ТЗ_Усушка[Счет].ОСТАТОК;
                Усушка = ТЗ_Усушка[Счет].УСУШКА;
                //КонецЕсли; 
                
                ИтогоУсушки = ПолучитьИтого(Номенклатура,Серия,Склад,Период) + Усушка;
                
                МенеджерЗаписи = РегистрыСведений.УсушкаЛукЧеснок.СоздатьМенеджерЗаписи();
                МенеджерЗаписи.Номенклатура = Номенклатура;
                МенеджерЗаписи.Серия = Серия;
                МенеджерЗаписи.Склад = Склад;
                МенеджерЗаписи.ОстатокКоличество = Остаток;
                МенеджерЗаписи.КоличествоУсушки = Усушка;
                МенеджерЗаписи.Период =  Период;
                МенеджерЗаписи.ИтогоУсушки = ИтогоУсушки;
                МенеджерЗаписи.Записать(ИСТИНА);
                
            КонецЕсли; 
            
        КонецЦикла; 	
    КонецЦикла; 
    
КонецПроцедуры


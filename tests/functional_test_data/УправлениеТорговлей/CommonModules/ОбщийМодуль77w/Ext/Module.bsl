Функция ПолучитьИтого(Номенклатура,Серия,Склад,Период)
	Итого = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УсушкаЛукЧеснок.Номенклатура КАК Номенклатура,
		|	УсушкаЛукЧеснок.Серия КАК Серия,
		|	УсушкаЛукЧеснок.Склад КАК Склад,
		|	СУММА(УсушкаЛукЧеснок.КоличествоУсушки) КАК КоличествоУсушки
		|ИЗ
		|	РегистрСведений.УсушкаЛукЧеснок КАК УсушкаЛукЧеснок
		|ГДЕ
		|	УсушкаЛукЧеснок.Период < &Период
		|	И УсушкаЛукЧеснок.Номенклатура = &Номенклатура
		|	И УсушкаЛукЧеснок.Серия = &Серия
		|	И УсушкаЛукЧеснок.Склад = &Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	УсушкаЛукЧеснок.Номенклатура,
		|	УсушкаЛукЧеснок.Серия,
		|	УсушкаЛукЧеснок.Склад";
	
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Итого = ВыборкаДетальныеЗаписи.КоличествоУсушки;
	КонецЦикла;
	
	Возврат Итого;
	

КонецФункции // ()





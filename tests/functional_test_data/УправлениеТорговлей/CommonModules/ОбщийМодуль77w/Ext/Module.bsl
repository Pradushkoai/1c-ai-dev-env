		//Запрос.УстановитьПараметр("Период", Период);
		//Запрос.УстановитьПараметр("Склад", Склад);
		//
		//РезультатЗапроса = Запрос.Выполнить();
		//
		//Если РезультатЗапроса.Пустой() Тогда
		
		НаборЗаписейГрафикДоставки = РегистрыСведений.ГрафикДоставкиТоваров.СоздатьНаборЗаписей();
		//НаборЗаписейГрафикДоставки.Отбор.Склад.Установить(Склад);
		НаборЗаписейГрафикДоставки.Прочитать();
		
		Если НаборЗаписейГрафикДоставки.Количество() > 0 Тогда
			
			Для каждого Запись Из НаборЗаписейГрафикДоставки Цикл
					
				Если (ДеньНедели(Период) = 1 И Запись.Понедельник = ИСТИНА) 

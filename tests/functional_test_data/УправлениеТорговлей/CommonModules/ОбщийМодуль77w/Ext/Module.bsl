Функция ПолучитьЦенуТовараСтрокой(ЦенаТовараВременная)
	
	Если ЦенаТовараВременная > 0 Тогда
		ЦенаТовараРуб = Цел(ЦенаТовараВременная);
		ЦенаТовараКопейки = (ЦенаТовараВременная - Цел(ЦенаТовараВременная))*100;
	Иначе
		ЦенаТовараРуб = 0;
		ЦенаТовараКопейки = 0;
	КонецЕсли; 
	
	Если ЦенаТовараРуб <> 0 Тогда
		
		Если ((ЦенаТовараКопейки > 0) и (ЦенаТовараКопейки < 10)) Тогда
			ЦенаТовараКопейки = "0"+ЦенаТовараКопейки;
		КонецЕсли; 			   
		ЦенаТовара = ""+ЦенаТовараРуб+" руб."+ЦенаТовараКопейки+" коп.";
	Иначе    
		ЦенаТовара = "0 руб."+ЦенаТовараКопейки+" коп.";
	КонецЕсли; 
	
	Возврат ЦенаТовара;	
	
КонецФункции // ()


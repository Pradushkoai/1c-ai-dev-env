			|	И ЦеныНоменклатурыСрезПоследних.ВидЦены = &ВидЦены";
		
		Запрос.УстановитьПараметр("ВидЦены", Справочники.ВидыЦен.НайтиПоНаименованию("Оптовые"));
		Запрос.УстановитьПараметр("Дата", Дата);
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЦенаОптовая = ВыборкаДетальныеЗаписи.Цена;
		КонецЦикла;
	
	КонецЕсли; 	

	Возврат ЦенаОптовая;
	
КонецФункции // ()


Процедура BKP_ЗаполнитьЛимитыПоСкладамПоДнямНедели() Экспорт
	Склад3 = Справочники.Склады.Склад3;
	Склад5 = Справочники.Склады.Склад5; 
	Склад3опт = Справочники.Склады.НайтиПоНаименованию("Склад N 3 опт",ИСТИНА);
	
	СкладыСписок = Новый СписокЗначений;
	СкладыСписок.Добавить(Склад3);
	СкладыСписок.Добавить(Склад5); 
	СкладыСписок.Добавить(Склад3опт);
		
	стрДень = 0;
	КолВоДней = 30;
	Для стрДень=1 По КолВоДней Цикл
		Для каждого стр Из СкладыСписок Цикл
			
			Период = ТекущаяДата()+ 86400 * стрДень;

			ЛимитСтрокОпт = 0;
			ЛимитСтрокРозница = 0;

			склад = стр.Значение;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЛимитыСборкиСклада.Период КАК Период,
			|	ЛимитыСборкиСклада.Склад КАК Склад,
			|	ЛимитыСборкиСклада.ЛимитСтрокВсего КАК ЛимитСтрокВсего,
			|	ЛимитыСборкиСклада.ЛимитСтрокОпт КАК ЛимитСтрокОпт,
			|	ЛимитыСборкиСклада.ЛимитСтрокРозница КАК ЛимитСтрокРозница
			|ИЗ
			|	РегистрСведений.ЛимитыСборкиСклада КАК ЛимитыСборкиСклада
			|ГДЕ
			|	ЛимитыСборкиСклада.Склад = &Склад
			|	И ЛимитыСборкиСклада.Период = &Период";
			
			Запрос.УстановитьПараметр("Период", Период);
			Запрос.УстановитьПараметр("Склад", склад);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Если РезультатЗапроса.Пустой() Тогда
				
				НаборЗаписейЛимитыПоДнямНедели = РегистрыСведений.ЛимитыЗагрузкиСкладаПоДнямНедели.СоздатьНаборЗаписей();
				НаборЗаписейЛимитыПоДнямНедели.Отбор.Склад.Установить(склад);
				НаборЗаписейЛимитыПоДнямНедели.Прочитать();
				

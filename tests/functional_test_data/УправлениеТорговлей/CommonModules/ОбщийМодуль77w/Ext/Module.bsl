////ОБМЕН ЗАЯВКИ НА РАСХОДОВАНИЕ ДС
&НаСервере
Процедура ОбменНаРасходДС()  Экспорт
		    //////////////////////////////////////////////////////////////////////////////////////////////////
		СоединениеБУХ = ОбщийМодуль77w.ПодключитьБД_БУХ();
		
			
		Если ТипЗнч(СоединениеБУХ) <> Тип("Неопределено") Тогда
	        
	    Запрос = СоединениеБУХ.NewObject("Запрос");
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Обмен_ЗаявкиНаРасходДС.ПлатежноеПоручениеСсылка,
			|	Обмен_ЗаявкиНаРасходДС.Статус,
			|	Обмен_ЗаявкиНаРасходДС.СуммаПлатежа,
			|	Обмен_ЗаявкиНаРасходДС.ПометкаУдаления,
			|	Обмен_ЗаявкиНаРасходДС.ПризнакОбработано,
			|	Обмен_ЗаявкиНаРасходДС.ДатаПлатежа,
			|	Обмен_ЗаявкиНаРасходДС.УНП,
			|	Обмен_ЗаявкиНаРасходДС.UID_DOC			
			|ИЗ
			|	РегистрСведений.Обмен_ЗаявкиНаРасходДС КАК Обмен_ЗаявкиНаРасходДС
			|ГДЕ
			|	Обмен_ЗаявкиНаРасходДС.ПризнакОбработано = 0";
			
			
			//Запрос.УстановитьПараметр("UID_DOC_ЗаявкаНаРасходДС_УТ", СокрЛП(ЭтотОбъект.Ссылка.УникальныйИдентификатор()));
			
			РезультатЗапроса = Запрос.Выполнить();
	        
	        ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	        
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл		
				
				UID_DOC = СокрЛП(ВыборкаДетальныеЗаписи.UID_DOC);
				
				Попытка
	                НовыйUID = Новый УникальныйИдентификатор(СокрЛП(ВыборкаДетальныеЗаписи.UID_DOC));
	                ДокументВвода_Объект = Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПолучитьСсылку(НовыйUID);
	            Исключение
	                ДокументВвода_Объект = Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПустаяСсылка();
	            КонецПопытки; 

				Если ДокументВвода_Объект <> Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПустаяСсылка() Тогда
				
					ДокументВвода_Объект = ДокументВвода_Объект.ПолучитьОбъект();
					
					
	        	    ИндексЗначения = СоединениеБУХ.Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Индекс(ВыборкаДетальныеЗаписи.Статус);
	            	ИмяЗначенияПеречисленияCOM = Метаданные.Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.ЗначенияПеречисления[ИндексЗначения].Имя;          
					
					
					Если ИмяЗначенияПеречисленияCOM = "НеСогласована" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована;
					ИначеЕсли ИмяЗначенияПеречисленияCOM = "НаПодтверждение" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НаПодтверждение;	
					ИначеЕсли ИмяЗначенияПеречисленияCOM = "НаСогласование" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НаСогласование;
					ИначеЕсли ИмяЗначенияПеречисленияCOM = "Согласована" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована;
					ИначеЕсли ИмяЗначенияПеречисленияCOM = "КОплате" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате;
					ИначеЕсли ИмяЗначенияПеречисленияCOM = "Оплачена" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Оплачена;
					ИначеЕсли ИмяЗначенияПеречисленияCOM = "Отклонена" Тогда
						СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена;
					КонецЕсли; 

					СтатусЗаявкиВДокументе = ДокументВвода_Объект.Статус;
					
					Если СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована Тогда
						Если СтатусЗаявкиВДокументе = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НаСогласование Тогда	 
							ДокументВвода_Объект.Статус = СтатусЗаявки;	 
							
							//стрИстория = ДокументВвода_Объект.ИсторияСменыСтатусов.Добавить();
							//стрИстория.Дата = ТекущаяДата();
							//стрИстория.Статус = СтатусЗаявки;

						КонецЕсли;	
					ИначеЕсли СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате Тогда
						ДокументВвода_Объект.Статус = СтатусЗаявки;
	
					ИначеЕсли СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Оплачена Тогда
						ДокументВвода_Объект.Статус = СтатусЗаявки;

						//стрИстория = ДокументВвода_Объект.ИсторияСменыСтатусов.Добавить();
						//стрИстория.Дата = ТекущаяДата();
						//стрИстория.Статус = СтатусЗаявки;
						
						ДокументВвода_Объект.Оплачено = Истина;
					ИначеЕсли СтатусЗаявки = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена Тогда
						ДокументВвода_Объект.Статус = СтатусЗаявки;
					КонецЕсли;
					ДокументВвода_Объект.СтатусПриВходе = СтатусЗаявки;	
					ДокументВвода_Объект.СуммаДокумента = ВыборкаДетальныеЗаписи.СуммаПлатежа;

					
					//сравнение и загрузка ТЧ
					ТЗ_Общая = ДокументВвода_Объект.ИсторияСменыСтатусов.Выгрузить();
					
					Для каждого стр Из ТЗ_Общая Цикл
						стр.Дата = Строка(стр.Дата);
						стр.Статус = Строка(стр.Статус);
						стр.Заметка = Строка(стр.Заметка);
						
						Если стр.Заметка = "0" Тогда
							стр.Заметка = "";
						КонецЕсли;
						
						стр.Пользователь = Строка(стр.Пользователь);
					КонецЦикла; 
					
					ТЗ_COM = ВыборкаДетальныеЗаписи.ПлатежноеПоручениеСсылка.ИсторияСменыСтатусов.Выгрузить();   //БУХ
					
					ДокументВвода_Объект.НазначениеПлатежа = ВыборкаДетальныеЗаписи.ПлатежноеПоручениеСсылка.НазначениеПлатежа;
					
					Для каждого стрCOM Из ТЗ_COM Цикл
						
						СтатусВТЧ = Неопределено;
						
						стр_Новая = ТЗ_Общая.Добавить();
						стр_Новая.Дата = стрCOM.Дата;
						
						Если ТипЗнч(стрCOM.Статус) = Тип("COMОбъект") Тогда
							
							ИмяЗначенияПеречисленияCOMВТЧ = СоединениеБУХ.XMLстрока(стрCOM.Статус);
							
							Если ИмяЗначенияПеречисленияCOMВТЧ = "НеСогласована" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована;
							ИначеЕсли ИмяЗначенияПеречисленияCOMВТЧ = "НаПодтверждение" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НаПодтверждение;
							ИначеЕсли ИмяЗначенияПеречисленияCOMВТЧ = "НаСогласование" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НаСогласование;
							ИначеЕсли ИмяЗначенияПеречисленияCOMВТЧ = "Согласована" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована;
							ИначеЕсли ИмяЗначенияПеречисленияCOMВТЧ = "КОплате" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате;
							ИначеЕсли ИмяЗначенияПеречисленияCOMВТЧ = "Отклонена" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена;
							ИначеЕсли ИмяЗначенияПеречисленияCOMВТЧ = "Оплачена" Тогда
								СтатусВТЧ = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Оплачена;
							КонецЕсли; 
							
							стр_Новая.Статус = "" + СтатусВТЧ;	
						Иначе
							стр_Новая.Статус = стрCOM.Статус;
						КонецЕсли;
						
						Если стрCOM.Заметка = "0" Тогда
							стрCOM.Заметка = "";
						КонецЕсли;
						
						
						Если ЗначениеЗаполнено(стрCOM.Заметка) Тогда
							стр_Новая.Заметка = стрCOM.Заметка;
						Иначе	
						    стр_Новая.Заметка = "";
						КонецЕсли; 
								
						Если ТипЗнч(стрCOM.Пользователь) = Тип("COMОбъект") Тогда
							стр_Новая.Пользователь = стрCOM.Пользователь.Description;
						Иначе
							стр_Новая.Пользователь = "" + стрCOM.Пользователь;
						КонецЕсли;
						
					КонецЦикла;
					
					ТЗ_Общая.Свернуть("Дата,Статус,Пользователь,Заметка");
					ТЗ_Общая.Сортировать("Дата");
					
					ДокументВвода_Объект.ИсторияСменыСтатусов.Загрузить(ТЗ_Общая);
					
					////

					
					ДокументВвода_Объект.ДатаПлатежногоПорученияБух = ВыборкаДетальныеЗаписи.ДатаПлатежа;
					
					СтатусВРегистр = ДокументВвода_Объект.Статус;
					
					ДокументВвода_Объект.Записать(РежимЗаписиДокумента.Запись);
					
					Если ВыборкаДетальныеЗаписи.ПометкаУдаления = 1 Тогда
						Если ДокументВвода_Объект.Проведен = ИСТИНА Тогда				        
							ДокументВвода_Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения);				                
						КонецЕсли; 
						
						ДокументВвода_Объект.УстановитьПометкуУдаления(ИСТИНА);
						ПомУдаления = 1;
					Иначе
						ПомУдаления = 0;
						Если ДокументВвода_Объект.ПометкаУдаления = Истина Тогда
							ДокументВвода_Объект.УстановитьПометкуУдаления(ЛОЖЬ);
						КонецЕсли;	
					КонецЕсли;
					
					Если ДокументВвода_Объект.ПометкаУдаления = Истина Тогда
						ДокументВвода_Объект.Записать(РежимЗаписиДокумента.Запись);
					Иначе
					    ДокументВвода_Объект.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;


					
					
					НаборЗаписейБУХ = СоединениеБУХ.РегистрыСведений.Обмен_ЗаявкиНаРасходДС.СоздатьНаборЗаписей();
        			НаборЗаписейБУХ.Отбор.ПлатежноеПоручениеСсылка.Установить(ВыборкаДетальныеЗаписи.ПлатежноеПоручениеСсылка);
			        НаборЗаписейБУХ.Прочитать();
			        
			        Для каждого СтрокаНабора Из НаборЗаписейБУХ Цикл
			            СтрокаНабора.ПризнакОбработано = 1;
			        КонецЦикла; 
			        
			        НаборЗаписейБУХ.Записать(Истина);
					
					
					НаборЗаписей = РегистрыСведений.Обмен_ЗаявкиНаОплату.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.ЗаявкаСсылка.Установить(ДокументВвода_Объект.Ссылка);
					НаборЗаписей.Прочитать();
					
					Для каждого Запись Из НаборЗаписей Цикл
					    Запись.Статус = СтатусЗаявки;
						Запись.ПризнакОбработано = 1;
					
					КонецЦикла; 
					НаборЗаписей.Записать();
					
				КонецЕсли;

	        КонецЦикла;
	        
	        СоединениеБУХ = Неопределено;
	        
	    КонецЕсли;

КонецПроцедуры


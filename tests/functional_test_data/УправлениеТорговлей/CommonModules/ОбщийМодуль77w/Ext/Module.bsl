Функция КомпонентаУстановлена(ТекстОшибки, Отказ)
	
	EVatService = Неопределено;
	
	Попытка 
		#Если ВебКлиент Тогда
			ПодключитьВнешнююКомпоненту("ОбщийМакет.EInvVatService_Локализация");
			EVatService = Новый ComОбъект("EInvVatService.Connector");
		#Иначе 
			EVatService = Новый ComОбъект("EInvVatService.Connector");
		#КонецЕсли	
		
	Исключение
		ТекстОшибки = Описаниеошибки(); //Нстр("ru='Не установлена компонента для доступа к порталу ЭСЧФ'");
		Отказ = Истина;
	КонецПопытки;
	
	Возврат EVatService;
	
КонецФункции

Функция ПолучитьСоединениеМНС(СтрокаСоединения, ТекстОшибки, Отказ)
		
	EVatService = КомпонентаУстановлена(ТекстОшибки, Отказ);
	
	Если Отказ Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	ПутьКВебСервису = "https://ws.vat.gov.by:443/InvoicesWS/services/InvoicesPort";   /////РЕАЛЬНЫЙ   ПОРТАЛ
	//ПутьКВебСервису = "https://185.32.226.170:4443/InvoicesWS/services/InvoicesPort"; //// тестовый веб-сервис 
	
	Если EVatService.Login(СтрокаСоединения, 0) = 0 Тогда
		                         
		Если  EVatService.Connect(ПутьКВебСервису) = 0 Тогда 
			Возврат EVatService;
		Иначе
			ТекстОшибки = Нстр("ru='Ошибка авторизации на портале ЭСЧФ: '") + EVatService.LastError;
			Сообщить(ТекстОшибки);
		КонецЕсли;
		
	Иначе
		ТекстОшибки = Нстр("ru='Ошибка авторизации на портале ЭСЧФ: '") + EVatService.LastError; 
			Сообщить(ТекстОшибки);
	КонецЕсли;
	
	Отказ = Истина;
	
	
	Возврат Неопределено;
	
КонецФункции


Функция обПустоеЗначение(Значение) 

	ТипЗначения = ТипЗнч(Значение);

	// Сначала примитивные типы
	Если Значение = Неопределено Тогда
		Возврат Истина;
	ИначеЕсли Значение = NULL Тогда
		Возврат Истина;
	ИначеЕсли Лев(Значение,18) = "<Объект не найден>" Тогда
		Возврат Истина;
	ИначеЕсли ТипЗначения = Тип("Тип") Тогда
		Возврат Истина;
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		Возврат ПустаяСтрока(Значение);
	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		Возврат ?(Значение = 0,Истина,Ложь);
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		Возврат ?(Значение = Дата('00010101'),Истина,Ложь);
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		Возврат Ложь; // Булево будем считать не пустым всегда
	ИначеЕсли ТипЗначения = Тип("Граница") Тогда
		Возврат обПустоеЗначение(Значение.Значение);
	ИначеЕсли ТипЗначения = Тип("Массив")
				ИЛИ ТипЗначения = Тип("СписокЗначений")
				ИЛИ ТипЗначения = Тип("ТаблицаЗначений")
				ИЛИ ТипЗначения = Тип("Структура") Тогда
		Возврат ?(Значение.Количество() = 0,Истина, Ложь);
    ИначеЕсли ТипЗначения = Тип("СтрокаТаблицыЗначений") Тогда
        Возврат Ложь;	
	ИначеЕсли ТипЗначения = Тип("ЭлементСпискаЗначений") Тогда
		Возврат Ложь;
	#Если Клиент Тогда	
		ИначеЕсли ТипЗначения = Тип("Форма") Тогда
			Возврат Ложь;
	#КонецЕсли				
	Иначе
		Возврат ?(Значение = Новый(ТипЗначения),Истина,Ложь);
	КонецЕсли; 

	Возврат Ложь;
	
КонецФункции // обПустоеЗначение()


Функция Статус(СтатусПортала)
	Если СтатусПортала="COMPLETED" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.Выставлен;                                     
	ИначеЕсли СтатусПортала="COMPLETED_SIGNED" Тогда  
		Возврат Перечисления.СтатусыЭСЧФ.Выставлен_Подписан;
	ИначеЕсли СтатусПортала="IN_PROGRESS" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.ВРазработке;
	ИначеЕсли СтатусПортала="IN_PROGRESS_ERROR" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.ВРазработке_Ошибка;
	ИначеЕсли СтатусПортала="ON_AGREEMENT" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.НаСогласовании;
	ИначеЕсли СтатусПортала="CANCELLED" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.Аннулирован;
	ИначеЕсли СтатусПортала="ON_AGREEMENT_CANCEL" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.Выставлен_Аннулирование;
	ИначеЕсли СтатусПортала="ERROR" Тогда
		Возврат Перечисления.СтатусыЭСЧФ.ВРазработке_Ошибка;
	КонецЕсли; 
КонецФункции // Статус

Функция ДатаСтатуса(_Дата)
	Год = Число(лев(_Дата,4));
	Месяц = Число(сред(_Дата,6,2)); 
	День = Число(сред(_Дата,9,2));
	Возврат Дата(Год,Месяц,День);
КонецФункции // ДатаСтатуса



Функция ПолучитьКолВоЗапланированныхСтрокВЭкв(Период,Склад) Экспорт
    КолВоСтрокЭкв = 0;
	
	
	Запрос = Новый Запрос;
	Запрос.Текст =  
	
		 "ВЫБРАТЬ
		 |	ЗаказКлиентаТовары.КоличествоСтрокВЭквиваленте КАК КолВоСтрок,
		 |	ЗаказКлиентаТовары.Ссылка.Склад КАК Склад,
		 |	ЕСТЬNULL(НАЧАЛОПЕРИОДА(ЗаданиеНаПеревозкуРаспоряжения.Ссылка.ДатаВремяРейсаПланС, ДЕНЬ), ВЫБОР
		 |			КОГДА ЗаказКлиентаТовары.ДатаОтгрузки = ДАТАВРЕМЯ(1, 1, 1)
		 |				ТОГДА НАЧАЛОПЕРИОДА(ЗаказКлиентаТовары.Ссылка.Дата, ДЕНЬ)
		 |			ИНАЧЕ НАЧАЛОПЕРИОДА(ЗаказКлиентаТовары.ДатаОтгрузки, ДЕНЬ)
		 |		КОНЕЦ) КАК ДатаОтгрузки,
		 |	ЕСТЬNULL(ЗаданиеНаПеревозкуРаспоряжения.Ссылка.ДатаВремяРейсаПланС, КОНЕЦПЕРИОДА(ЗаказКлиентаТовары.Ссылка.ДатаОтгрузки, ДЕНЬ)) КАК ДатаОтг
		 |ПОМЕСТИТЬ ТАБСВОДНАЯ
		 |ИЗ
		 |	Документ.ЗаказКлиента КАК ЗаказКлиентаТовары
		 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозку.Распоряжения КАК ЗаданиеНаПеревозкуРаспоряжения
		 |		ПО ЗаказКлиентаТовары.Ссылка = ЗаданиеНаПеревозкуРаспоряжения.Распоряжение
		 |ГДЕ
		 |	ЗаказКлиентаТовары.Ссылка.Проведен = ИСТИНА
		 |	И ЕСТЬNULL(НАЧАЛОПЕРИОДА(ЗаданиеНаПеревозкуРаспоряжения.Ссылка.ДатаВремяРейсаПланС, ДЕНЬ), ВЫБОР
		 |				КОГДА ЗаказКлиентаТовары.ДатаОтгрузки = ДАТАВРЕМЯ(1, 1, 1)
		 |					ТОГДА НАЧАЛОПЕРИОДА(ЗаказКлиентаТовары.Ссылка.Дата, ДЕНЬ)
		 |				ИНАЧЕ НАЧАЛОПЕРИОДА(ЗаказКлиентаТовары.ДатаОтгрузки, ДЕНЬ)
		 |			КОНЕЦ) МЕЖДУ &ДатаНач И &ДатаОкон
		 |	И ЗаказКлиентаТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОтгрузке)
		 |
		 |ОБЪЕДИНИТЬ ВСЕ
		 |
		 |ВЫБРАТЬ
		 |	ЗаказНаПеремещениеТовары.КоличествоСтрокВЭквиваленте,

////////////////ПРОВЕРКА РЕГУЛИРУЕМЫХ ЦЕН ///////////////////

Процедура ПроверкаРегулируемыхЦен(ОбъектСсылка,Отказ) Экспорт
	Если ОбъектСсылка.Соглашение.Наименование = "Благотворительность" Тогда
    	Возврат;
 	КонецЕсли;

	
	Если НачалоДня(ОбъектСсылка.Дата) >= Дата("20221101") Тогда
		
		ЕстьРегулированиеЦен = Ложь;
		НеУстановленыЦены = Ложь;
		
		Для каждого Строка Из ОбъектСсылка.Товары Цикл
			
			ЕстьРегулированиеЦен_Строка = Ложь;
			НеУстановленыЦены_Строка = Ложь;
			
			Если ПроверитьРегулированиеЦенГосударством_Оптовых(Строка.Номенклатура,ОбъектСсылка.Дата) = Истина Тогда
				ЕстьРегулированиеЦен = Истина;
				ЕстьРегулированиеЦен_Строка = Истина;
			КонецЕсли; 
					
			
			Если ЕстьРегулированиеЦен_Строка = Истина Тогда
				
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Период КАК Период,
				|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Регистратор КАК Регистратор,
				|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Номенклатура КАК Номенклатура,
				|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Серия КАК Серия,
				|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Цена КАК Цена
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатурыПоСериям_МССО.СрезПоследних(&Период, ) КАК ЦеныНоменклатурыПоСериям_МССОСрезПоследних
				|ГДЕ
				|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Номенклатура = &Номенклатура
				|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Серия = &Серия
				|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Цена <> 0
				|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.ВидЦены = &ВидЦены";
				
				Запрос.УстановитьПараметр("Номенклатура",Строка.Номенклатура);
				Запрос.УстановитьПараметр("Серия", Строка.Серия);
				Запрос.УстановитьПараметр("ВидЦены", Строка.ВидЦены);
				Запрос.УстановитьПараметр("Период", ОбъектСсылка.Дата);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				Если РезультатЗапроса.Пустой() Тогда
					НеУстановленыЦены = Истина;
					НеУстановленыЦены_Строка = Истина;
				КонецЕсли; 
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					Если Строка.Цена > ВыборкаДетальныеЗаписи.Цена Тогда
						Сообщить("Строка "+Строка.НомерСтроки+"   "+Строка.Номенклатура+"    Цена продажи = "+Строка.Цена+"    регулированая цена = "+ВыборкаДетальныеЗаписи.Цена);
						НеУстановленыЦены = Истина;
						НеУстановленыЦены_Строка = Истина;
					ИначеЕсли Строка.Цена = ВыборкаДетальныеЗаписи.Цена Тогда	
						НеУстановленыЦены = Ложь;
						НеУстановленыЦены_Строка = Ложь;
					КонецЕсли; 	
				КонецЦикла;
				
			КонецЕсли; 
			
			Если (НеУстановленыЦены_Строка = Истина И ЕстьРегулированиеЦен_Строка = Истина) Тогда
				Сообщить("Строка "+Строка.НомерСтроки+"   "+Строка.Номенклатура+"         по номенклатуре регулируются цены Постановлением Совета Министров N713 и цена не установлена ");
			КонецЕсли; 
			
		КонецЦикла; 
		
		Если (ЕстьРегулированиеЦен = Истина И НеУстановленыЦены = Истина) Тогда
			Сообщить("В документе есть товары попадающие под регулирование цен Постановлением Совета Министров N713 и на них не установлена цена ");
			Отказ = Истина;
		КонецЕсли; 
		
	КонецЕсли; 
	
КонецПроцедуры


Процедура ПроверкаРегулируемыхЦен_Розница(ОбъектСсылка,Отказ) Экспорт
	
	//jadmin 10-01-2023 добавил условие после И
	Если (НачалоДня(ОбъектСсылка.Дата) >= Дата("20221027") И НачалоДня(ОбъектСсылка.Дата) < Дата("20230111"))
		ИЛИ НачалоДня(ОбъектСсылка.Дата) >= Дата("20230403")  Тогда
		
		ЕстьРегулированиеЦен = Ложь;
		НеУстановленыЦены = Ложь;
		
		Для каждого Строка Из ОбъектСсылка.Товары Цикл
			
			ЕстьРегулированиеЦен_Строка = Ложь;
			НеУстановленыЦены_Строка = Ложь;
			
			Если ПроверитьРегулированиеЦенГосударством_Розничных(Строка.Номенклатура,ОбъектСсылка.Дата) = Истина Тогда
				ЕстьРегулированиеЦен = Истина;
				ЕстьРегулированиеЦен_Строка = Истина;
			КонецЕсли; 
					
			
			Если ЕстьРегулированиеЦен_Строка = Истина Тогда
				УстановленыЦеныПоНоменклатуреПоСериям = ПроверитьУстановкуЦенПоНоменклатуре(Строка.Номенклатура,ОбъектСсылка.Дата) = ИСТИНА;
				Если УстановленыЦеныПоНоменклатуреПоСериям = ИСТИНА Тогда
					
					Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Период КАК Период,
					|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Регистратор КАК Регистратор,
					|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Номенклатура КАК Номенклатура,
					|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Серия КАК Серия,
					|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Цена КАК Цена
					|ИЗ
					|	РегистрСведений.ЦеныНоменклатурыПоСериям_МССО.СрезПоследних(&Период, ) КАК ЦеныНоменклатурыПоСериям_МССОСрезПоследних
					|ГДЕ
					|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Номенклатура = &Номенклатура
					|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Серия = &Серия
					|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Цена <> 0
					|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.ВидЦены = &ВидЦены";
					
					Запрос.УстановитьПараметр("Номенклатура",Строка.Номенклатура);
					Запрос.УстановитьПараметр("Серия", Строка.Серия);
					Запрос.УстановитьПараметр("ВидЦены", Справочники.ВидыЦен.НайтиПоНаименованию("Розничные"));
					Запрос.УстановитьПараметр("Период", ОбъектСсылка.Дата);
					
					РезультатЗапроса = Запрос.Выполнить();
					
					
					//Если ОбъектСсылка.ЭтоИнтернетЗаказ = Ложь Тогда
						Если РезультатЗапроса.Пустой() Тогда
							НеУстановленыЦены = Истина;
							НеУстановленыЦены_Строка = Истина;
						КонецЕсли; 
					//КонецЕсли; 
				ИначеЕсли УстановленыЦеныПоНоменклатуреПоСериям = ЛОЖЬ И Строка.Серия.ДокументПоставки.Дата >= Дата("20221101") Тогда
					НеУстановленыЦены = Истина;
					НеУстановленыЦены_Строка = Истина;
				КонецЕсли; 
				
			КонецЕсли; 
			
			Если (НеУстановленыЦены_Строка = Истина И ЕстьРегулированиеЦен_Строка = Истина) Тогда
				Сообщить("Строка "+Строка.НомерСтроки+"   "+Строка.Номенклатура+"         по номенклатуре регулируются цены Постановлением Совета Министров N713 и цена не установлена ");
			КонецЕсли; 
			
		КонецЦикла; 
		
		Если (ЕстьРегулированиеЦен = Истина И НеУстановленыЦены = Истина) Тогда
			Сообщить("В документе есть товары попадающие под регулирование цен Постановлением Совета Министров N713 и на них не установлена цена ");
			Отказ = Истина;
		КонецЕсли; 
		
	КонецЕсли; 
	
КонецПроцедуры

	
Процедура ПроверкаУстановленныхРегулируемыхЦенПоСериям_Розница(ОбъектСсылка,Отказ) Экспорт

	  Для каждого Строка Из ОбъектСсылка.Товары Цикл
		  Если (ОбъектСсылка.Дата >= Дата("20221027") И ОбъектСсылка.Дата < Дата("20230111")) 
			  ИЛИ ОбъектСсылка.Дата >= Дата("20230403") Тогда
			  Если ОбщийМодуль77w.ПроверитьРегулированиеЦенГосударством_Розничных(Строка.Номенклатура,ОбъектСсылка.Дата) = ИСТИНА Тогда
				  Если (Строка.Серия.ДокументПоставки.Дата >= Дата("20221101") И Строка.Серия.ДокументПоставки.Дата < Дата("20230111"))
					  ИЛИ Строка.Серия.ДокументПоставки.Дата >= Дата("20230331") Тогда
					  
					  Если ПроверитьУстановкуЦенПоСериям(Строка.Номенклатура,Строка.Серия, ОбъектСсылка.Дата) = ЛОЖЬ Тогда    //Цена не установлена
						  Сообщить("В строке "+Строка.НомерСтроки+ " "+Строка.Номенклатура+" серия " + Строка.Серия+ " не установлена Розничная цена на серию (цены регулируются государством)");
						  Отказ = ИСТИНА;
					  КонецЕсли;
					  
				  КонецЕсли;
			  КонецЕсли; 
		  КонецЕсли; 

			
			Если ПроверитьНедоступностьТоваров_Розница(Строка.Номенклатура,ОбъектСсылка.Дата) = ИСТИНА Тогда
				Сообщить("В строке "+Строка.НомерСтроки+ " "+Строка.Номенклатура+" установлен признак недоступно для розницы!");
				Если НЕ РольДоступна("АдминистраторСистемы") Тогда
					Отказ = ИСТИНА;	
				КонецЕсли; 
 				//Отказ = ИСТИНА;	
			КонецЕсли; 

			
			Если ПроверитьУстановкуЦенПоНоменклатуреСтандарт(Строка.Номенклатура, ОбъектСсылка.Дата) = ЛОЖЬ Тогда
				Сообщить("В строке "+Строка.НомерСтроки+ " "+Строка.Номенклатура+" не установлена розничная цена на номенклатуру!");
				Отказ = ИСТИНА;				
			КонецЕсли; 
			
	  КонецЦикла; 

КонецПроцедуры
 
Функция ПроверитьНедоступностьТоваров_Розница(Номенклатура,Дата)

	Недоступно = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РегулируемыеЦеныНаНоменклатуреСрезПоследних.Номенклатура КАК Номенклатура,
		|	РегулируемыеЦеныНаНоменклатуреСрезПоследних.НедоступноОпт КАК НедоступноРозница
		|ИЗ
		|	РегистрСведений.РегулируемыеЦеныНаНоменклатуре.СрезПоследних(&Дата, ) КАК РегулируемыеЦеныНаНоменклатуреСрезПоследних
		|ГДЕ
		|	РегулируемыеЦеныНаНоменклатуреСрезПоследних.НедоступноРозница = ИСТИНА
		|	И РегулируемыеЦеныНаНоменклатуреСрезПоследних.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Дата",Дата);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество()>0 Тогда
	
		Недоступно = ИСТИНА;
	
	КонецЕсли;

	Возврат Недоступно;

КонецФункции // ()
 

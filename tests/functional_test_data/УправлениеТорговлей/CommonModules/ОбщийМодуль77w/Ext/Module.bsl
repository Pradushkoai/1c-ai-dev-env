///РегЦены. Если рег.цена и установлена на серию выбираем её, если нет - то цену номенклатуры.
&НаСервере
Функция ПолучитьЦенуНаСервере_Розница(Номенклатура, Серия, Дата, ВидЦены = Неопределено) Экспорт

	Если ВидЦены = Неопределено Тогда
	
	
		Если Дата >= Дата("20221027") И Дата < Дата("20230111060000") 
			ИЛИ Дата >= Дата("20230403") Тогда
			
			
			ДатаНачалаРегулированияЦенГосударством = Справочники.ВидыЦен.НайтиПоНаименованию("Розничные",Истина).ДатаНачалаРегулированияЦенГосударством;
			Если ОбщийМодуль77w.ПроверитьРегулированиеЦенГосударством_Розничных(Номенклатура,Дата) = Ложь Тогда
				
				
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	ЦеныНоменклатурыСрезПоследних.Период,
				|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|	ЦеныНоменклатурыСрезПоследних.ВидЦены,
				|	ЦеныНоменклатурыСрезПоследних.Валюта,
				|	ЦеныНоменклатурыСрезПоследних.Цена
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&НаДату, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
				|ГДЕ
				|	ЦеныНоменклатурыСрезПоследних.ВидЦены = &ВидЦены
				|	И ЦеныНоменклатурыСрезПоследних.Номенклатура = &Номенклатура";
				
				Запрос.УстановитьПараметр("ВидЦены", Справочники.ВидыЦен.НайтиПоНаименованию("Розничные",Истина));
				Запрос.УстановитьПараметр("НаДату", Дата);
				Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					НайденаяЦена = ВыборкаДетальныеЗаписи.Цена;
					Возврат (НайденаяЦена);
				КонецЦикла;
				
				Сообщить("На номенклатуру " + Номенклатура + " не установлена розничная цена!");
				Возврат 0;
				
			Иначе
				
				Запрос = Новый Запрос;
				Запрос.Текст = 

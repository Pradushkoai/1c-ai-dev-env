	СтруктураКонтактнаяИнформация.Вставить("Вид");
	СтруктураКонтактнаяИнформация.Вставить("Представление");
	СтруктураКонтактнаяИнформация.Вставить("Страна");
	СтруктураКонтактнаяИнформация.Вставить("Регион");
	СтруктураКонтактнаяИнформация.Вставить("Город");
	СтруктураКонтактнаяИнформация.Вставить("АдресЭП");
	СтруктураКонтактнаяИнформация.Вставить("ДоменноеИмяСервера");
	СтруктураКонтактнаяИнформация.Вставить("НомерТелефона");
	СтруктураКонтактнаяИнформация.Вставить("НомерТелефонаБезКодов");
	СтруктураКонтактнаяИнформация.Вставить("ВидДляСписка");

	
	СтруктураТелефон = Новый Структура;
	СтруктураТелефон.Вставить("Тип");
	СтруктураТелефон.Вставить("Вид");
	СтруктураТелефон.Вставить("Представление");
	СтруктураТелефон.Вставить("Страна");
	СтруктураТелефон.Вставить("Регион");
	СтруктураТелефон.Вставить("Город");
	СтруктураТелефон.Вставить("АдресЭП");
	СтруктураТелефон.Вставить("ДоменноеИмяСервера");
	СтруктураТелефон.Вставить("НомерТелефона");
	СтруктураТелефон.Вставить("НомерТелефонаБезКодов");
	СтруктураТелефон.Вставить("ВидДляСписка");


	
	Соединение = Новый HTTPСоединение(
        "lkfl.portal.nalog.gov.by", // сервер (хост)
        443, // порт, по умолчанию для http используется 80, для https 443
        , // пользователь для доступа к серверу (если он есть)
        , // пароль для доступа к серверу (если он есть)
        , // здесь указывается прокси, если он есть
        60, // таймаут в секундах, 0 или пусто - не устанавливать
       Новый ЗащищенноеСоединениеOpenSSL()
    );

		
	Запрос = Новый HTTPЗапрос("/grp/getData?unp="+СокрЛП(УНП)+"&charset=UTF-8&type=json");
	
	//Запрос.Заголовки.Вставить("Content-type", "application/json");
	Результат = Соединение.Получить(Запрос);
	
	Попытка
    Ответ = Соединение.ОтправитьДляОбработки(Запрос);
  Исключение
    Сообщить("Ошибка при обращении к серверу (https://lkfl.portal.nalog.gov.by): "+ОписаниеОшибки());
    Возврат Неопределено;
  КонецПопытки;
  
  КодСостояния = Ответ.КодСостояния;
  
  // проверим редирект на второй сайт
  Если КодСостояния = 301 Тогда
    // посмотрим новый URL в заголовке location
    Если Ответ.Заголовки["Location"] = Неопределено Тогда
      Сообщить("Информация с сервера не получена. УНП: "+аргУНП+". Код ответа сайта: "+КодСостояния);
      Возврат КодСостояния;
    Иначе  
      Новый_URL = Ответ.Заголовки["Location"];
      мПротокол = Лев(Новый_URL, 5);
      Если мПротокол = "https" Тогда
        Новый_URL = Сред(Новый_URL, 9);
        ПозицияСлеша = СтрНайти(Новый_URL, "/");
        Новый_URL_1 = Лев(Новый_URL, ПозицияСлеша-1);
        Новый_URL = Сред(Новый_URL, ПозицияСлеша);
        ПозицияВопроса = СтрНайти(Новый_URL, "?");
        Новый_URL_2 = Лев(Новый_URL, ПозицияВопроса);
        //
        SSL = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);
        Соединение = Новый HTTPСоединение(Новый_URL_1,,,,,,SSL);
        Запрос = Новый HTTPЗапрос(Новый_URL_2 + "unp=" + СокрЛП(аргУНП) + "&charset=UTF-8&type=xml");
        Попытка
          Ответ = Соединение.ОтправитьДляОбработки(Запрос);
        Исключение
          Сообщить("Ошибка при обращении к серверу (" + Ответ.Заголовки["Location"] + "): "+ОписаниеОшибки());
          Возврат Неопределено;
        КонецПопытки;
        КодСостояния = Ответ.КодСостояния;
      Иначе
        Новый_URL = Сред(Новый_URL, 8);
        ПозицияСлеша = СтрНайти(Новый_URL, "/");
        Новый_URL_1 = Лев(Новый_URL, ПозицияСлеша-1);
        Новый_URL = Сред(Новый_URL, ПозицияСлеша);
        ПозицияВопроса = СтрНайти(Новый_URL, "?");
        Новый_URL_2 = Лев(Новый_URL, ПозицияВопроса);
        //
        Соединение = Новый HTTPСоединение(Новый_URL_1);
        Запрос = Новый HTTPЗапрос(Новый_URL_2 + "unp=" + СокрЛП(аргУНП) + "&charset=UTF-8&type=json");
        Попытка
          Ответ = Соединение.Получить(Запрос);
        Исключение
          Сообщить("Ошибка при обращении к серверу (" + Ответ.Заголовки["Location"] + "): "+ОписаниеОшибки());
          Возврат Неопределено;
        КонецПопытки;
        КодСостояния = Ответ.КодСостояния;
      КонецЕсли;  
    КонецЕсли;  
  КонецЕсли;  
  
  Если КодСостояния = 400 Тогда
    Сообщить("По УНП "+аргУНП + " данные не найдены.");
    Возврат КодСостояния;
  Иначе  
    Если КодСостояния <> 200 Тогда      
      Если КодСостояния <> 403 Тогда
        // 403 = Forbidden, возникает, когда сервер считает, что превышено число запросов с ip
        // его отрабатываем отдельно и соответсвенно не сообщаем пользователю
        Сообщить("Информация с сервера не получена. УНП: "+аргУНП+". Код ответа сайта: "+КодСостояния);
      КонецЕсли;
      Возврат КодСостояния;      
    Иначе
      //Сообщить("ОК. УНП: "+аргУНП);
    КонецЕсли;
  КонецЕсли;
  
  ТекстОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8"); 
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстОтвета);
		Ответ = ПрочитатьJSON(ЧтениеJSON);	
		ЧтениеJSON.Закрыть();
		
		
		Если ТипЗнч(Ответ) = Тип("Структура")  Тогда
			СтрокаДанные = Ответ.ROW;
			СтрКонтрагент.ИНН = УНП;
			
			СтрКонтрагент.НаименованиеПолное = СтрокаДанные.VNAIMP;
			СтрКонтрагент.Наименование = СтрокаДанные.VNAIMK;
			СтрКонтрагент.НаименованиеСокращенное = СтрКонтрагент.НаименованиеПолное;

			СтрКонтрагент.Адрес = СтрокаДанные.VPADRES;
			
			СтатусКонтрагента = СтрокаДанные.VKODS;
			
			Если СокрЛП(СтатусКонтрагента) = "Действующий" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.Действующий;
			ИначеЕсли СокрЛП(СтатусКонтрагента) = "Ликвидирован" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.Ликвидирован;
			ИначеЕсли СокрЛП(СтатусКонтрагента) = "В процессе ликвидации" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.ВПроцессеЛиквидации;
			ИначеЕсли СокрЛП(СтатусКонтрагента) = "В процессе санации" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.ВПроцессеСанации;	
			ИначеЕсли СокрЛП(СтатусКонтрагента) = "В процедуре банкротства" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.ВПроцедуреБанкротства;
			КонецЕсли;

			СтрКонтрагент.Статус = СтатусНалогоплательщиков;
			СтрКонтрагент.СостояниеНалогоплательщика = СтатусНалогоплательщиков;

			
			ДатаЛиквидации = "";
			ДатаЛиквидации = СтрокаДанные.DLIKV;
			Если ЗначениеЗаполнено(ДатаЛиквидации) Тогда
			    ДатаЛиквидации = СтрЗаменить(ДатаЛиквидации,"-","");
				СтрКонтрагент.ДатаЛиквидации = Дата(ДатаЛиквидации);
			Иначе

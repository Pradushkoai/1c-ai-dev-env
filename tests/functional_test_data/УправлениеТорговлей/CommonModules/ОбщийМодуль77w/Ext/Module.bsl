Процедура ПроверкаСерийДляИнвентаризацииРегулируемыхЦен_Розница(ОбъектСсылка,Отказ) Экспорт
	
	 // jadmin 10-01-2023 добавил условие
	Если (НачалоДня(ОбъектСсылка.Дата) >= Дата("20221027") И ОбъектСсылка.Дата < Дата("20230111"))
		ИЛИ НачалоДня(ОбъектСсылка.Дата) >= Дата("20230403") Тогда
				
		Для каждого Строка Из ОбъектСсылка.Товары Цикл
			
			ЕстьРегулированиеЦен = Ложь;
			
			Если ПроверитьРегулированиеЦенГосударством_Розничных(Строка.Номенклатура,ОбъектСсылка.Дата) = Истина Тогда
				ЕстьРегулированиеЦен = Истина;
			КонецЕсли; 
					
			
			Если ЕстьРегулированиеЦен = Истина Тогда
				УстановленыЦеныПоНоменклатуреПоСериям = ПроверитьУстановкуЦенПоНоменклатуре(Строка.Номенклатура,ОбъектСсылка.Дата) = ИСТИНА;
				Если УстановленыЦеныПоНоменклатуреПоСериям = ИСТИНА Тогда	
					 Если НЕ ЗначениеЗаполнено(Строка.Серия) Тогда
					 	  Сообщить("Строка " + Строка.НомерСтроки + " " + Строка.Номенклатура + " не заполнена серия (цены регулируются госудаством и установлены цены на серию)");	
						  Отказ = ИСТИНА;
					 КонецЕсли; 
				КонецЕсли; 	
			КонецЕсли; 
						
		КонецЦикла; 
				
	КонецЕсли; 
	
КонецПроцедуры


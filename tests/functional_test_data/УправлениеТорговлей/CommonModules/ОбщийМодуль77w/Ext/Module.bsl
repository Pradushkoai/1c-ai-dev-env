				ДокУстЦен.Записать(РежимЗаписиДокумента.Проведение);
				Сообщить("   "+ДокУстЦен.Ссылка);	
		ИначеЕсли ТипЗнч(ВыборкаДетальныеЗаписи.ДокументПереоценки) = Тип("ДокументСсылка.ЗаказКлиента") Тогда  
				ДокУстЦен = ВыборкаДетальныеЗаписи.ДокументПереоценки.ПолучитьОбъект();
				ДокУстЦен.Записать(РежимЗаписиДокумента.Проведение);
				Сообщить("   "+ДокУстЦен.Ссылка);
		КонецЕсли;
		
	КонецЦикла;
	

КонецПроцедуры




&НаСервере
Процедура ПечатьЦенникаНаСервере_A5(ТабДок,Склад, СписокТоваров,Дата,ПечатьАкционныхЦенников=Неопределено,ПечатьСУчетомОстатков=ЛОЖЬ,ПечатьВсехОстатков=ЛОЖЬ) Экспорт
	Перем КомпонентШК;
	НачДата = Дата;
	ВыбСклад = Склад;
	ВыбНоменклатура = СписокТоваров;
	
	ТабДок = Новый ТабличныйДокумент;
  //ТабДок.ОриентацияСтраницы=ОриентацияСтраницы.Ландшафт;
	ТабДок.ОриентацияСтраницы=ОриентацияСтраницы.Портрет;
 // ТабДок.АвтоМасштаб = Истина; 
  ТабДок.ОтображатьЗаголовки = Ложь;
  ТабДок.ОтображатьСетку = Ложь;
  //ТабДок.ПолеСлева = 10;
  //ТабДок.ПолеСправа = 10;
	ВыбЗначениеЦен = ВыбСклад.РозничныйВидЦены;
	
	
	ВсегоКолонок = 2;
	
	ВсегоСтрок   = 1;  //Для ценников 40x70
	
	ТекКолонка = 1;
	ТекСтрока  = 1;
	
	столбик=1;
	ряд=0;
	
	ТЗ_Товары = Новый ТаблицаЗначений;
	ТЗ_Товары.Колонки.Добавить("НоменклатураСсылка");

	ТЗ_Товары.Колонки.Добавить("Номенклатура");
	ТЗ_Товары.Колонки.Добавить("Номенклатура1");
	
	ТЗ_Товары.Колонки.Добавить("ЦенаТовара");
	ТЗ_Товары.Колонки.Добавить("ЦенаУпаковкиТовара");
	ТЗ_Товары.Колонки.Добавить("ЦенаСоСкидкой");
	ТЗ_Товары.Колонки.Добавить("ЦенаУпаковкиТовараСоСкидкой");
	ТЗ_Товары.Колонки.Добавить("ЦенаТовара1шт");
	ТЗ_Товары.Колонки.Добавить("ЦенаСоСкидкой1шт");

	ТЗ_Товары.Колонки.Добавить("ЦенаТовараСтрока");
	ТЗ_Товары.Колонки.Добавить("ЦенаУпаковкиТовараСтрока");
	ТЗ_Товары.Колонки.Добавить("ЦенаСоСкидкойСтрока");
	ТЗ_Товары.Колонки.Добавить("ЦенаУпаковкиТовараСоСкидкойСтрока");
	ТЗ_Товары.Колонки.Добавить("ЦенаТовара1штСтрока");
	ТЗ_Товары.Колонки.Добавить("ЦенаСоСкидкой1штСтрока");

	
	
	
	ТЗ_Товары.Колонки.Добавить("КолВоВУпак");
	ТЗ_Товары.Колонки.Добавить("КолВоВУпакСтрока");
	ТЗ_Товары.Колонки.Добавить("НоменклатураСтрока1");
	ТЗ_Товары.Колонки.Добавить("НоменклатураСтрока2");
	
	ТЗ_Товары.Колонки.Добавить("ЕдИзмТовара");
	ТЗ_Товары.Колонки.Добавить("Партия");
	ТЗ_Товары.Колонки.Добавить("НомерДок");
	ТЗ_Товары.Колонки.Добавить("ДатаДок");
	ТЗ_Товары.Колонки.Добавить("Страна");
	ТЗ_Товары.Колонки.Добавить("Штрихкод");

	
	
	
	
	ТЗ_ТоварыУпак = ТЗ_Товары.Скопировать();
	ТЗ_ТоварыШТ =  ТЗ_Товары.Скопировать();
	ТЗ_ТоварыУпакСкидка = ТЗ_Товары.Скопировать();
	ТЗ_ТоварыШТСкидка =  ТЗ_Товары.Скопировать();
	
	Для каждого СтрокаТовары Из  ВыбНоменклатура Цикл
		

		Номенклатура = СтрокаТовары.Значение;
		
		Если Номенклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда
		
			Продолжить;
		
		КонецЕсли; 
		
		Если Номенклатура.ЭтоГруппа Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	Номенклатура.Ссылка В ИЕРАРХИИ(&Ссылка)
			|	И Номенклатура.ПометкаУдаления = ЛОЖЬ
			|	И Номенклатура.ЭтоГруппа = ЛОЖЬ";
			
			Запрос.УстановитьПараметр("Ссылка", Номенклатура);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НоваяСтрокаТЗ = ТЗ_Товары.Добавить();
				НоваяСтрокаТЗ.Номенклатура =  ВыборкаДетальныеЗаписи.Ссылка;
			КонецЦикла;
		Иначе
			НоваяСтрокаТЗ = ТЗ_Товары.Добавить();
			НоваяСтрокаТЗ.Номенклатура =  Номенклатура;
		КонецЕсли; 
	КонецЦикла;
	
	
	Для каждого СтрокаТовары Из ТЗ_Товары Цикл
					
			Если ПечатьСУчетомОстатков = ИСТИНА Тогда
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
				|	ТоварыНаСкладахОстатки.Склад КАК Склад,
				|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток,0)) КАК ВНаличииОстаток
				|ИЗ
				|	РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОстатков, ) КАК ТоварыНаСкладахОстатки
				|ГДЕ
				|	ТоварыНаСкладахОстатки.Номенклатура = &Номенклатура
				|	И ТоварыНаСкладахОстатки.Склад = &Склад 
				//|	И ТоварыНаСкладахОстатки.ВНаличииОстаток > 0 
				// |	И ТоварыНаСкладахОстатки.Серия = &Серия
				|
				|СГРУППИРОВАТЬ ПО
				|	ТоварыНаСкладахОстатки.Номенклатура,
				|	ТоварыНаСкладахОстатки.Склад";
				
				Запрос.УстановитьПараметр("ДатаОстатков", Дата-1);
				Запрос.УстановитьПараметр("Номенклатура", СтрокаТовары.Номенклатура);
				//Запрос.УстановитьПараметр("Серия", СтрокаТовары.Серия);
				Запрос.УстановитьПараметр("Склад", Склад);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				ОстатокМеньшеПредела = Ложь; 
				НулевойОстатокНаСкладе = ЛОЖЬ;
				Если НЕ РезультатЗапроса.Пустой() Тогда		
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл   
						//Проверяем на минимальный остаток на магазине
						Если ПечатьВсехОстатков = ЛОЖЬ Тогда
							
							Если ВыборкаДетальныеЗаписи.ВНаличииОстаток >= 10 Тогда				
								ОстатокМеньшеПредела = ИСТИНА; 		
							КонецЕсли;       
						Иначе
							Если ВыборкаДетальныеЗаписи.ВНаличииОстаток<=0 Тогда	
								НулевойОстатокНаСкладе = Истина;	
							КонецЕсли; 
						КонецЕсли;	
						
					КонецЦикла;  
				Иначе
					НулевойОстатокНаСкладе = ИСТИНА;  
					ОстатокМеньшеПредела = ИСТИНА;
				КонецЕсли;
				
				Если ОстатокМеньшеПредела = ИСТИНА Тогда
					Продолжить;
				КонецЕсли;
				
				Если НулевойОстатокНаСкладе = ИСТИНА Тогда
				    Продолжить;
				КонецЕсли;

			КонецЕсли; 
		
		Номенклатура = СтрокаТовары.Номенклатура;
		СтрокаТовары.НоменклатураСсылка = Номенклатура;
		
		ЦенникПоСериям = ЛОЖЬ;
		Партия = "";
		УстЦен = "";
		Цена = 0;
		ЕдИзмТовара = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
		КолВоВУпак = 0 ;  
		
		ЦенаТовара = 0;
		ЦенаУпаковкиТовара = 0;
		ЦенаСоСкидкой = 0;
		ЦенаУпаковкиТовараСоСкидкой =  0;
		
		
		//jadmin 10-01-2023
		ОбщийМодуль77w.ПолучитьЦенуИУстановкуЦен_Розница(СтрокаТовары.Номенклатура,Справочники.СерииНоменклатуры.ПустаяСсылка(),НачДата,УстЦен,ЕдИзмТовара,Цена);
		///
		ЦенаТовара = Цена;
		
		
		Если Цена = Неопределено Тогда
			
			Сообщить("Не найдена цена товара " + СтрокаТовары.Номенклатура);
			Продолжить;
		КонецЕсли;
		//Скидка 	
		sale_percent = 0; //ПроцентСкидки
		sale_price = 0; //ЦенаСоСкидкой
		ЦенаСоСкидкой = 0;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РозничныеСкидкиМССОСрезПоследних.Период КАК Период,
		|	РозничныеСкидкиМССОСрезПоследних.Регистратор КАК Регистратор,
		|	РозничныеСкидкиМССОСрезПоследних.НомерСтроки КАК НомерСтроки,
		|	РозничныеСкидкиМССОСрезПоследних.Активность КАК Активность,
		|	РозничныеСкидкиМССОСрезПоследних.Магазин КАК Магазин,
		|	РозничныеСкидкиМССОСрезПоследних.Номенклатура КАК Номенклатура,
		|	РозничныеСкидкиМССОСрезПоследних.ШтрихКод КАК ШтрихКод,
		|	РозничныеСкидкиМССОСрезПоследних.Скидка КАК Скидка,
		|	РозничныеСкидкиМССОСрезПоследних.РазмерСкидки КАК РазмерСкидки,
		|	РозничныеСкидкиМССОСрезПоследних.ДатаНачала КАК ДатаНачала,
		|	РозничныеСкидкиМССОСрезПоследних.ДатаОкончания КАК ДатаОкончания,
		|	РозничныеСкидкиМССОСрезПоследних.Статус КАК Статус,
		|	РозничныеСкидкиМССОСрезПоследних.РозничнаяЦена КАК РозничнаяЦена,
		|	РозничныеСкидкиМССОСрезПоследних.РозничнаяЦенаСоСкидкой КАК РозничнаяЦенаСоСкидкой,
		|	РозничныеСкидкиМССОСрезПоследних.Скидка.Ссылка КАК СкидкаСсылка
		|ИЗ
		|	РегистрСведений.РозничныеСкидкиМССО.СрезПоследних КАК РозничныеСкидкиМССОСрезПоследних
		|ГДЕ
		|	РозничныеСкидкиМССОСрезПоследних.Номенклатура = &Номенклатура
		|	И РозничныеСкидкиМССОСрезПоследних.ДатаНачала <= &Дата
		|	И РозничныеСкидкиМССОСрезПоследних.ДатаОкончания >= &Дата
		|	И РозничныеСкидкиМССОСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДействияСкидок.Действует)
		|	И РозничныеСкидкиМССОСрезПоследних.Магазин = &Магазин
		|
		|УПОРЯДОЧИТЬ ПО
		|	РазмерСкидки УБЫВ";
		
		Запрос.УстановитьПараметр("Дата", НачДата);
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДействияСкидок.Действует);
		Запрос.УстановитьПараметр("Магазин", ВыбСклад);
		
		
		РезЗпрСкидка = Запрос.Выполнить().Выгрузить();
		
		Если РезЗпрСкидка.Количество() > 0 Тогда
			
			Если РезЗпрСкидка[0].СкидкаСсылка = Справочники.РозничныеСкидки_МССО.НайтиПоНаименованию("Специальная цена",ИСТИНА) Тогда    //код 000000003
				
				ЦенаСоСкидкой = РезЗпрСкидка[0].РозничнаяЦенаСоСкидкой;
				ЦенаТовараВременная = ЦенаСоСкидкой;
			ИначеЕсли РезЗпрСкидка[0].СкидкаСсылка = Справочники.РозничныеСкидки_МССО.НайтиПоНаименованию("Скидка (наценка) процентом",ИСТИНА) Тогда    //код 000000002
				
				sale_percent = РезЗпрСкидка[0].РазмерСкидки;
				ЦенаСоСкидкой = Окр(Цена * (1 - sale_percent/100),2,РежимОкругления.Окр15как10);
				ЦенаТовараВременная = ЦенаСоСкидкой;
			КонецЕсли;
		КонецЕсли;
		
		
		КолВоВУпак = 1;
		Если СтрНайти(СтрокаТовары.Номенклатура.ЕдиницаДляОтчетов.Наименование, "упак") > 0  Тогда
			Если СтрокаТовары.Номенклатура.КоэффициентЕдиницыДляОтчетов > 1 Тогда
				КолВоВУпак =  СтрокаТовары.Номенклатура.КоэффициентЕдиницыДляОтчетов;
				
				ЦенаУпаковкиТовараСоСкидкой = ЦенаСоСкидкой * КолВоВУпак;					
				ЦенаУпаковкиТовара = Цена * КолВоВУпак;
			КонецЕсли;
		КонецЕсли; 
		
		
		Если ЦенаТовара <= 0 ИЛИ ЦенаТовара = Неопределено Тогда
			Сообщить("Не найдена цена "+СокрЛП(Номенклатура.НаименованиеПолное));
			Продолжить;
		КонецЕсли; 
		
		СтрокаТовары.ЦенаТовара = ЦенаТовара;
		СтрокаТовары.ЦенаУпаковкиТовара = ЦенаУпаковкиТовара;
		СтрокаТовары.ЦенаСоСкидкой = ЦенаСоСкидкой;
		СтрокаТовары.ЦенаУпаковкиТовараСоСкидкой = ЦенаУпаковкиТовараСоСкидкой;
		
		
		
		СтрокаТовары.ЦенаТовараСтрока = ПолучитьЦенуТовараСтрокой(ЦенаТовара);
		СтрокаТовары.ЦенаСоСкидкойСтрока = ПолучитьЦенуТовараСтрокой(ЦенаСоСкидкой);
		
		
		
		СтрокаТовары.ЦенаСоСкидкой1ШтСтрока ="Цена за шт " + ПолучитьЦенуТовараСтрокой(ЦенаСоСкидкой);
		
		СтрокаТовары.ЦенаУпаковкиТовараСоСкидкойСтрока = "Цена за упаковку " +  ПолучитьЦенуТовараСтрокой(ЦенаУпаковкиТовараСоСкидкой);
		
		Если ЦенаУпаковкиТовараСоСкидкой > 0 Тогда
			СтрокаТовары.ЦенаТовара1штСтрока ="" + ПолучитьЦенуТовараСтрокой(ЦенаТовара) + " /шт";;
			СтрокаТовары.ЦенаУпаковкиТовараСтрока = "" + ПолучитьЦенуТовараСтрокой(ЦенаУпаковкиТовара) + " /упак";
		Иначе	
			СтрокаТовары.ЦенаТовара1штСтрока ="Цена за шт " + ПолучитьЦенуТовараСтрокой(ЦенаТовара);
			СтрокаТовары.ЦенаУпаковкиТовараСтрока = "Цена за упак. " + ПолучитьЦенуТовараСтрокой(ЦенаУпаковкиТовара);
		КонецЕсли;
		
		
		
		
		
		Если КолВоВУпак <> 0 Тогда
			СтрокаТовары.КолВоВУпакСтрока = ""+"Количество в одной упаковке "+КолВоВУпак+" шт";
		КонецЕсли; 
		
		СтрокаТовары.КолВоВУпак = КолВоВУпак;
		
		///////
		
		
		
		Если ЦенникПоСериям = ИСТИНА И ЗначениеЗаполнено(Партия) Тогда
			СтрокаТовары.Партия = ""+ Партия;
		Иначе	
			СтрокаТовары.Партия = ""+ " Уст.цен "+УстЦен;
		КонецЕсли;
		
		
		
		
		///// 
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
		|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура
		|	И ШтрихкодыНоменклатуры.ОсновнойШК = ИСТИНА";
		
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		
		ШтрихКод = Неопределено;
		ШтрихКод = Выборка.Штрихкод;	
		
		ШКДляДжестори = "";
		ШКДляДжестори = Номенклатура.ШКДляДжестори.Код;
		
		Если ЗначениеЗаполнено(ШКДляДжестори) Тогда
			ШтрихКод = Формат(ШКДляДжестори,"ЧГ=0");
		КонецЕсли; 
		
		Если ШтрихКод = Неопределено Тогда
			Сообщить("Не заполнен штрих-код у номенклатуры: "+СтрокаТовары.Номенклатура);
			Продолжить;
		КонецЕсли; 
		
		Если НЕ ЗначениеЗаполнено(ШтрихКод)Тогда
			Продолжить;
		КонецЕсли; 
		
		
		СтрокаТовары.ШтрихКод = ШтрихКод; 
		

Функция ДобавитьРабочиеДни(Дата,КолВоДнейВперед) Экспорт
	 	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	НоваяДата = Дата;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 30
		|	ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь КАК ПроизводственныйКалендарь,
		|	ДанныеПроизводственногоКалендаря.Дата КАК Дата,
		|	ДанныеПроизводственногоКалендаря.Год КАК Год,
		|	ДанныеПроизводственногоКалендаря.ВидДня КАК ВидДня
		|ИЗ
		|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
		|ГДЕ
		|	ДанныеПроизводственногоКалендаря.Дата >= &Дата
		|	И ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &ПроизводственныйКалендарь
		|	И (ДанныеПроизводственногоКалендаря.ВидДня = &ВидДня
		|		ИЛИ ДанныеПроизводственногоКалендаря.ВидДня = &ВидДняПредпраздничный)";
	
	Запрос.УстановитьПараметр("ВидДня", Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий);
	Запрос.УстановитьПараметр("ВидДняПредпраздничный", Перечисления.ВидыДнейПроизводственногоКалендаря.Предпраздничный);
	Запрос.УстановитьПараметр("Дата", НачалоДня(Дата));
	Запрос.УстановитьПараметр("ПроизводственныйКалендарь", Справочники.ПроизводственныеКалендари.НайтиПоКоду("РБ"));
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	НоваяДата = РезультатЗапроса[КолВоДнейВперед].Дата;
	
	Возврат НоваяДата;

КонецФункции

 


Функция ПроверкаНаСрокАнализовДляЛука(Объект,ТоварыТЧ) Экспорт
	///////////77w qaws
	Отказов = 0;
	
	СекундДоСрока = Константы.СрокКонтроляДействияАнализа.Получить() *60 * 60 * 24;
	ПодошелСрокДатыАнализа = Дата(1, 1, 1);
	СрокДействияАнализа = Дата(1, 1, 1);	
	
	Если ТоварыТЧ.Количество() > 0 Тогда
		
		Для каждого ВыборкаПоТовару Из ТоварыТЧ Цикл
			
			СрокДействияАнализа = "";
			Партия_МССО_Ссылка = ВыборкаПоТовару.Серия.Партия_МССО;
			Если ВыборкаПоТовару.Номенклатура.ВесКонтроль = ИСТИНА Тогда
			
				Если Партия_МССО_Ссылка.Анализы.Количество() > 0 Тогда
					
					Для Каждого СтрокаАнализы Из Партия_МССО_Ссылка.Анализы Цикл
						
						СрокДействияАнализаЕсть = СтрокаАнализы.СрокДействияАнализа;
						
						Если НЕ ЗначениеЗаполнено(СрокДействияАнализаЕсть) Тогда
							Продолжить;
						КонецЕсли;
						
						Если ЗначениеЗаполнено(СрокДействияАнализаЕсть) Тогда
							СрокДействияАнализа = СрокДействияАнализаЕсть;
						Иначе
							СрокДействияАнализа = Дата(1, 1, 1);
						КонецЕсли;
						
					КонецЦикла;
				Иначе
					СрокДействияАнализаЕсть = Партия_МССО_Ссылка.СрокДействияАнализа;
					
						Если НЕ ЗначениеЗаполнено(СрокДействияАнализаЕсть) Тогда
						   	Отказов = Отказов +1;
						КонецЕсли;
						
						Если ЗначениеЗаполнено(СрокДействияАнализаЕсть) Тогда
							СрокДействияАнализа = СрокДействияАнализаЕсть;
						Иначе
							СрокДействияАнализа = Дата(1, 1, 1);
						   	Отказов = Отказов +1;
						КонецЕсли;
					
				КонецЕсли;
			
							
			
			КонецЕсли; 
			
			Попытка
				ПодошелСрокДатыАнализа = НачалоДня(СрокДействияАнализа - СекундДоСрока);
				Если Объект.Соглашение.Наименование <> "Благотворительность" Тогда
					Если (СрокДействияАнализа - Объект.Дата)<=(СрокДействияАнализа - ПодошелСрокДатыАнализа) Тогда
						Сообщить("Строка № "+ВыборкаПоТовару.НомерСтроки+"  СРОК АНАЛИЗА ИСТЕК (ИСТЕКАЕТ): "+ВыборкаПоТовару.Номенклатура+"  ПАРТИЯ  "+ВыборкаПоТовару.Серия);
						Если ВыборкаПоТовару.Номенклатура.ВесКонтроль = ИСТИНА Тогда  //////лук
							Отказов = Отказов +1;
						КонецЕсли; 
					КонецЕсли; 
				КонецЕсли;
			
			Исключение
				
			КонецПопытки; 
		КонецЦикла; 
		
		
	КонецЕсли; 
	
	Если Отказов > 0 Тогда
		Возврат Истина;
	Иначе	
		Возврат Ложь;
	КонецЕсли; 
	

КонецФункции




Функция BKP_ПолучитьКолВоСтрокЭквивалент(ТЧ_Товары,Склад,ДатаДок) Экспорт
	СтрокВЭквиваленте = 0;
	
	Запрос = Новый Запрос;
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТЗ_Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_ТЗ_ТОВАРЫ
		|ИЗ
		|	&ТЗ_Товары КАК ТЗ_Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыТЧ.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТАБЗаказ
		|ИЗ
		|	ВТ_ТЗ_ТОВАРЫ КАК ТоварыТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасценкиКладовщикиСрезПоследних.Цена КАК Цена,
		|	РасценкиКладовщикиСрезПоследних.Номенклатура КАК Номенклатура,
		|	КОЛИЧЕСТВО(РасценкиКладовщикиСрезПоследних.Номенклатура) КАК КолВоСтрок,
		|	РасценкиКладовщикиСрезПоследнихБАЗА.Цена КАК ЦенаЭкв,
		|	РасценкиКладовщикиСрезПоследних.Цена / РасценкиКладовщикиСрезПоследнихБАЗА.Цена КАК Коэф,
		|	ВЫРАЗИТЬ(КОЛИЧЕСТВО(РасценкиКладовщикиСрезПоследних.Номенклатура) * РасценкиКладовщикиСрезПоследних.Цена / РасценкиКладовщикиСрезПоследнихБАЗА.Цена КАК ЧИСЛО(15, 1)) КАК КолВоСтрокЭквивалент
		|ИЗ
		|	ТАБЗаказ КАК ЗаказКлиентаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РасценкиКладовщики.СрезПоследних(&ДатаДок, ) КАК РасценкиКладовщикиСрезПоследних
		|		ПО (ЗаказКлиентаТовары.Номенклатура.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура
		|				ИЛИ ЗаказКлиентаТовары.Номенклатура.Родитель.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура
		|				ИЛИ ЗаказКлиентаТовары.Номенклатура.Родитель.Родитель.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура
		|				ИЛИ ЗаказКлиентаТовары.Номенклатура.Родитель.Родитель.Родитель.Родитель = РасценкиКладовщикиСрезПоследних.Номенклатура),
		|	РегистрСведений.РасценкиКладовщики.СрезПоследних(&ДатаДок, ) КАК РасценкиКладовщикиСрезПоследнихБАЗА
		|ГДЕ
		|	РасценкиКладовщикиСрезПоследнихБАЗА.Номенклатура = &БазоваяНоменклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	РасценкиКладовщикиСрезПоследних.Цена,
		|	РасценкиКладовщикиСрезПоследних.Номенклатура,
		|	РасценкиКладовщикиСрезПоследнихБАЗА.Цена";
	
	Запрос.Текст = ТекстЗапроса;
	Если Склад = Справочники.Склады.Склад3 Тогда
		Запрос.УстановитьПараметр("БазоваяНоменклатура", Справочники.Номенклатура.НайтиПоКоду("00-00000001"));  ///1. Семена овощей
	Иначе
		Запрос.УстановитьПараметр("БазоваяНоменклатура", Справочники.Номенклатура.НайтиПоКоду("00-00000024"));  ///8.удобрения
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаДок", ДатаДок);
	Запрос.УстановитьПараметр("ТЗ_Товары", ТЧ_Товары);
	//Запрос.УстановитьПараметр("ТипСклада", ТипСклада);

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	

	СтрокВЭквиваленте = Окр(РезультатЗапроса.Итог("КолВоСтрокЭквивалент"),0);
	Возврат СтрокВЭквиваленте;
	
КонецФункции

Функция BKP_ДоступноСтрокКСборке(Склад, ДатаОтгрузки, ДатаДок, ПриоритетСборки = Неопределено,СпособДоставки) Экспорт
	

	
	

Процедура СебестоимостьПоСтавкамНДСБлаготворительность(Источник, Отказ, РежимПроведения) Экспорт
	
	Если Источник.Благотворительность ИЛИ Источник.БезвозмезднаяПередача Тогда
		
		
		Движения = РегистрыНакопления.ВыручкаИСебестоимостьПродаж.СоздатьНаборЗаписей();
		Движения.Отбор.Регистратор.Значение = Источник.Ссылка;
		Движения.Прочитать(); 
		
		ТЗ_Марина = Движения.Выгрузить();
		
		ТЗ_Марина.Колонки.Добавить("ВидТМЦНаименование");
		ТЗ_Марина.Колонки.Добавить("ВидТМЦСчет");
		
		ТЗ_Марина.Колонки.Добавить("СтавкаНДС");
		
		Для каждого Строка_ТЗ_Марина Из ТЗ_Марина Цикл
			Строка_ТЗ_Марина.СтавкаНДС = ""+СокрЛП(Строка_ТЗ_Марина.АналитикаУчетаНоменклатуры.Номенклатура.СтавкаНДС);
			Строка_ТЗ_Марина.ВидТМЦНаименование = ""+СокрЛП(Строка_ТЗ_Марина.АналитикаУчетаНоменклатуры.Номенклатура.ВидТМЦ.Наименование);
			Строка_ТЗ_Марина.ВидТМЦСчет = ""+СокрЛП(Строка_ТЗ_Марина.АналитикаУчетаНоменклатуры.Номенклатура.ВидТМЦ.Счет); 
		КонецЦикла; 
		
		ТЗ_Марина.Свернуть("ВидТМЦСчет,СтавкаНДС","СуммаВыручкиРегл");
		
		Источник.СебестоимостьПоСтавкамНДСБлаготворительность.Очистить();
		
		Если ТЗ_Марина.Количество() > 0 Тогда
			Для каждого Строка Из ТЗ_Марина Цикл
				//Источник.СебестоимостьПоСтавкамНДСБлаготворительность.Очистить();
				Нов = Источник.СебестоимостьПоСтавкамНДСБлаготворительность.Добавить();
				ЗаполнитьЗначенияСвойств(Нов,Строка);
				Нов.СебестоимостьРегл  = Строка.СуммаВыручкиРегл;
			КонецЦикла; 
		КонецЕсли; 
		
		Источник.Записать();
	КонецЕсли; 
	
КонецПроцедуры	




Процедура ПродажиНижеСебестоимостиПоСтавкамНДС(Источник, Отказ, РежимПроведения) Экспорт
	
	Если ТипЗнч(Источник.Ссылка) = ТИП("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		///Заполненение реквизита в заказе ВыписанаНакладаная
		Если Источник.РеализацияПоЗаказам Тогда
				
			ТЗ_Заказов = Источник.Товары.Выгрузить();
			ТЗ_Заказов.Свернуть("ЗаказКлиента","");

		   	Для каждого СтрокаТЗ Из ТЗ_Заказов Цикл
				ЗаказОбъект = СтрокаТЗ.ЗаказКлиента.Ссылка.ПолучитьОбъект();
									
				Если НЕ ЗаказОбъект.ВыписанаНакладная = Источник.Ссылка Тогда				
					ЗаказОбъект.ВыписанаНакладная = Источник.Ссылка;
					ЗаказОбъект.ОбменДанными.Загрузка = Истина;
					ЗаказОбъект.Записать();
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;  
	КонецЕсли;

	/////
	
	Если Источник.Соглашение <> Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Благотворительность") Тогда
		
		
		Движения = РегистрыНакопления.ВыручкаИСебестоимостьПродаж.СоздатьНаборЗаписей();
		Движения.Отбор.Регистратор.Значение = Источник.Ссылка;
		Движения.Прочитать(); 
		
		
		Источник.ТоварыНижеСебестоимости.Очистить();
		
		Для каждого Строка Из Движения Цикл
			
			НачислятьСебестоимость = ЛОЖЬ;
			
			Если Источник.Ссылка.Дата < Дата("20230901") Тогда		
				Если (Строка.СебестоимостьРегл - Строка.СуммаДополнительныхРасходовБезНДС) > Строка.СуммаВыручкиРегл Тогда
					НачислятьСебестоимость = ИСТИНА;
				КонецЕсли;
			Иначе
				Если (Строка.СебестоимостьРегл) > Строка.СуммаВыручкиРегл Тогда					
					НачислятьСебестоимость = ИСТИНА;					
				КонецЕсли;

			КонецЕсли; 
			
			Если НачислятьСебестоимость = ИСТИНА Тогда				
				
				ДатаПоставкиСерии = Дата(1,1,1);			
				
				Если ТипЗнч(Строка.АналитикаУчетаНоменклатуры.Серия.ДокументПоставки) = Тип("ДокументСсылка.СборкаТоваров") Тогда 
					
					ДокСборки = Строка.АналитикаУчетаНоменклатуры.Серия.ДокументПоставки.Ссылка;
					
					ДатаПоставкиСерии = НачалоДня(ДокСборки.Товары[0].Серия.ДокументПоставки.Дата);
				Иначе
					ДатаПоставкиСерии = НачалоДня(Строка.АналитикаУчетаНоменклатуры.Серия.ДокументПоставки.Дата);
				КонецЕсли;
				
				РазницаВДнях = (НачалоДня(Источник.Дата) - НачалоДня(ДатаПоставкиСерии)) / (60 * 60 * 24);
				
				Если РазницаВДнях > 365 Тогда
					Продолжить;
				КонецЕсли; 
				
				Если Источник.Контрагент <> Справочники.Контрагенты.ПустаяСсылка() Тогда	
					Нов = Источник.ТоварыНижеСебестоимости.Добавить();
					Нов.Номенклатура = Строка.АналитикаУчетаНоменклатуры.Номенклатура;
					Нов.СтавкаНДС =  Строка.АналитикаУчетаНоменклатуры.Номенклатура.СтавкаНДС; 
					Нов.СуммаСебестоимости  = Строка.СебестоимостьРегл;
					Нов.Сумма   = Строка.СуммаВыручкиРегл;
				КонецЕсли;	
			КонецЕсли; 
			
			
		КонецЦикла; 
		
		
		Источник.Записать();
		
		
		Если Источник.ТоварыНижеСебестоимости.Количество() > 0 Тогда
			
				//Если Источник.Склад.ТипСклада = Перечисления.ТипыСкладов.ОптовыйСклад 
				Если Источник.Контрагент <> Справочники.Контрагенты.ПустаяСсылка() Тогда
				
					НаборЗаписей = РегистрыНакопления.ЭСЧФДляВыставленияПродажиНижеСебестоимости.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Регистратор.Установить(Источник.Ссылка);
					
					Запись = НаборЗаписей.ДобавитьПриход();
					Запись.Регистратор = Источник.Ссылка;
					Запись.Период = Источник.Дата;
					Запись.Контрагент   = Источник.Контрагент;
					Запись.ДокументОснование = Источник.Ссылка;
					Запись.Состояние   = 1;
					
					НаборЗаписей.Записать();
									
				КонецЕсли;		
				//КонецЕсли;	
				
		КонецЕсли; 
	КонецЕсли; 

КонецПроцедуры	


////////////////ЗАПРЕТ ОТГРУЗКИ ///////////////////

Процедура ПроверкаЗапретаОтгрузки(ОбъектСсылка,Отказ)    Экспорт
	
	ЕстьТоварыСЗапретомОтгрузки = Отказ;
	
	Если ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда 
		ТЗ_Товары = ОбъектСсылка.ОтгружаемыеТовары;
	Иначе
		ТЗ_Товары = ОбъектСсылка.Товары;
	КонецЕсли;
	
	Если ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.ПеремещениеТоваров") 
		ИЛИ ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.АктОРасхожденияхПослеПеремещения") 
		ИЛИ ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда 
		Если ОбъектСсылка.СкладОтправитель.ТипСклада = Перечисления.ТипыСкладов.ОптовыйСклад 
					И ОбъектСсылка.СкладПолучатель.ТипСклада = Перечисления.ТипыСкладов.РозничныйМагазин Тогда
					
			Склад = ОбъектСсылка.СкладОтправитель;
		    СкладПолучатель = ОбъектСсылка.СкладПолучатель; 
		Иначе
			Склад = ОбъектСсылка.СкладПолучатель;
		    СкладПолучатель = ОбъектСсылка.СкладОтправитель;
		КонецЕсли;

	Иначе
		Склад = ОбъектСсылка.Склад;
	    СкладПолучатель = ОбъектСсылка.Склад;
	КонецЕсли;
	
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументЗапретаОтгрузки.Ссылка КАК Ссылка,
		|	ДокументЗапретаОтгрузки.Склад КАК Склад
		|ИЗ
		|	Документ.ДокументЗапретаОтгрузки КАК ДокументЗапретаОтгрузки
		|ГДЕ
		|	&ТекДата МЕЖДУ ДокументЗапретаОтгрузки.НачалоДействия И ДокументЗапретаОтгрузки.ОкончаниеДействия
		|	И ДокументЗапретаОтгрузки.Проведен = ИСТИНА
		|	И (ДокументЗапретаОтгрузки.Склад = &Склад
		|		ИЛИ ДокументЗапретаОтгрузки.Склад = &СкладПолучатель)";

	
	Запрос.УстановитьПараметр("ТекДата", ОбъектСсылка.Дата);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("СкладПолучатель", СкладПолучатель);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	
		Для каждого  стрТовар Из ТЗ_Товары Цикл
	
			Запрос1 = Новый Запрос;
			Запрос1.Текст = 
				"ВЫБРАТЬ
				|	ДокументЗапретаОтгрузкиТовары.Ссылка КАК Ссылка,
				|	ДокументЗапретаОтгрузкиТовары.Номенклатура КАК Номенклатура
				|ИЗ
				|	Документ.ДокументЗапретаОтгрузки.Товары КАК ДокументЗапретаОтгрузкиТовары
				|ГДЕ
				|	ДокументЗапретаОтгрузкиТовары.Номенклатура = &Номенклатура
				|	И &ТекДата МЕЖДУ ДокументЗапретаОтгрузкиТовары.Ссылка.НачалоДействия И ДокументЗапретаОтгрузкиТовары.Ссылка.ОкончаниеДействия
				|	И ДокументЗапретаОтгрузкиТовары.Ссылка.Проведен = ИСТИНА
				|	И (ДокументЗапретаОтгрузкиТовары.Ссылка.Склад = &Склад
				|		ИЛИ ДокументЗапретаОтгрузкиТовары.Ссылка.Склад = &СкладПолучатель)";
			
			Запрос1.УстановитьПараметр("ТекДата", ОбъектСсылка.Дата);
			Запрос1.УстановитьПараметр("Номенклатура", стрТовар.Номенклатура);
			Запрос1.УстановитьПараметр("Склад", Склад);
			Запрос1.УстановитьПараметр("СкладПолучатель", СкладПолучатель);
			
			РезультатЗапроса1 = Запрос1.Выполнить();
			
			Если НЕ РезультатЗапроса1.Пустой() Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Строка " + стрТовар.НомерСтроки + "  " +стрТовар.Номенклатура + " установлен запрет отгрузки!",ОбъектСсылка,,,Отказ);
				ЕстьТоварыСЗапретомОтгрузки = ИСТИНА;
			КонецЕсли;
		
		КонецЦикла; 	
	КонецЦикла;

	Отказ = ЕстьТоварыСЗапретомОтгрузки;
	
КонецПроцедуры



					ИЛИ (ДеньНедели(Период) = 3 И Запись.Среда = ИСТИНА)
					ИЛИ (ДеньНедели(Период) = 4 И Запись.Четверг = ИСТИНА)
					ИЛИ (ДеньНедели(Период) = 5 И Запись.Пятница = ИСТИНА)
					ИЛИ (ДеньНедели(Период) = 6 И Запись.Суббота = ИСТИНА)
					ИЛИ (ДеньНедели(Период) = 7 И Запись.Воскресение = ИСТИНА) Тогда	
					
					МенеджерЗаписи = РегистрыСведений.ГрафикДоставкиТоваровПоКалендарю.СоздатьМенеджерЗаписи();

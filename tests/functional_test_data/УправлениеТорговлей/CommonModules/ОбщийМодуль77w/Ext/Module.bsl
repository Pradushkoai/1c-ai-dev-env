Процедура ПроверитьПравонарушенияНаСервере() Экспорт
	
	
	
	
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |	Контрагенты.ИНН КАК ИНН,
        |	Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |	Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |	Контрагенты.ПометкаУдаления = ЛОЖЬ
        |	И Контрагенты.ИНН <> """"";
    
    РезультатЗапроса = Запрос.Выполнить();
    
    ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
    
    
    РегистрРеестрПравонарушений = РегистрыСведений.РеестрПравонарушений_Локализация;
  	
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		УНП = "";
        УНП = ВыборкаДетальныеЗаписи.ИНН;
				
        Если СтрДлина(УНП) <> 9 Тогда
            Продолжить;
        КонецЕсли;	
		
				
		СтатусНалогоплательщиков = Неопределено;
    	Статус_ЕГР = Неопределено;
		
		ЮрЛицо = Истина;
		Статус_ЕГР =ДанныеКонтрагентаПоУНП(ЮрЛицо, УНП);
		
		
		Если Статус_ЕГР = Неопределено Тогда
			Продолжить;	
		КонецЕсли; 
		
		Если Статус_ЕГР = 400 Тогда
			Сообщить("По УНП "+УНП+ " данные не найдены.");
			Продолжить;	
		КонецЕсли;

		
		
		
		Если Статус_ЕГР <> Неопределено 
			  И ТипЗнч(Статус_ЕГР) = Тип("Структура") Тогда
			
			Если СокрЛП(Статус_ЕГР.Статус) = "Действующий" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.Действующий;
			ИначеЕсли СокрЛП(Статус_ЕГР.Статус) = "Ликвидирован" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.Ликвидирован;
			ИначеЕсли СокрЛП(Статус_ЕГР.Статус) = "В процессе ликвидации" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.ВПроцессеЛиквидации;
			ИначеЕсли СокрЛП(Статус_ЕГР.Статус) = "В процессе санации" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.ВПроцессеСанации;	
			ИначеЕсли СокрЛП(Статус_ЕГР.Статус) = "В процедуре банкротства" Тогда
				СтатусНалогоплательщиков = Перечисления.СостоянияНалогоплательщиков.ВПроцедуреБанкротства;
			КонецЕсли;

			Если Статус_ЕГР.ДатаЛиквидации <> "01.01.0001" Тогда
				ДатаЛиквидации = Статус_ЕГР.ДатаЛиквидации;
			Иначе
				ДатаЛиквидации = "";
			КонецЕсли;
            
            //Если СокрЛП(Статус_ЕГР.Статус) <> "Действующий" Тогда
			Если СокрЛП(Статус_ЕГР.Статус) = "Ликвидирован" 
				или СокрЛП(Статус_ЕГР.Статус) = "В процессе ликвидации" Тогда
				
				Сообщить(""+Статус_ЕГР.Наименование+"  "+Статус_ЕГР.Статус);
				
				Запись = РегистрРеестрПравонарушений.СоздатьМенеджерЗаписи();
				Запись.Статус = СтатусНалогоплательщиков;
				Запись.УНП = УНП;
				Запись.ДатаПроверки = ТекущаяДата();
				Запись.ДатаЛиквидации = ДатаЛиквидации;
				Запись.Контрагент = ВыборкаДетальныеЗаписи.Ссылка;
				Запись.Записать(ИСТИНА);
		
			КонецЕсли; 
        КонецЕсли; 
		
		Банкрот = Ложь;
		Банкрот = ОбщийМодуль77w.ПроверитьВхождениеВРеесстрОБанкротсве(УНП);
		
		Если Статус_ЕГР <> Неопределено 
			И ТипЗнч(Статус_ЕГР) = Тип("Структура") Тогда
			
			Если СокрЛП(Статус_ЕГР.Статус) = "Действующий" Тогда
				
				//Банкрот = ОбщийМодуль77w.ПроверитьВхождениеВРеесстрОБанкротсве(УНП);
				
				Если Банкрот = ИСТИНА Тогда
					Сообщить( "Внимание! Контрагент включен в ""Единый государственный реестр сведений о банкротстве!""");
					
					Запись = РегистрРеестрПравонарушений.СоздатьМенеджерЗаписи();
					Запись.Контрагент = ВыборкаДетальныеЗаписи.Ссылка;
					Запись.Статус = СтатусНалогоплательщиков;
					Запись.УНП = УНП;
					Запись.ДатаЛиквидации = ДатаЛиквидации;
					Запись.ДатаПроверки = ТекущаяДата();
					Запись.Банкрот = Истина;
					Запись.ПовышенныйРиск = Истина;
					
					Запись.Записать(ИСТИНА);
				КонецЕсли; 
			Иначе
				//Банкрот = ОбщийМодуль77w.ПроверитьВхождениеВРеесстрОБанкротсве(УНП);
				
				Если Банкрот = ИСТИНА Тогда
					Сообщить( "Внимание! Контрагент включен в ""Единый государственный реестр сведений о банкротстве!""");
					
					Запись = РегистрРеестрПравонарушений.СоздатьМенеджерЗаписи();
					Запись.Контрагент = ВыборкаДетальныеЗаписи.Ссылка;
					Запись.Статус = СтатусНалогоплательщиков;
					Запись.УНП = УНП;
					Запись.ДатаЛиквидации = ДатаЛиквидации;
					Запись.ДатаПроверки = ТекущаяДата();
					Запись.Банкрот = Истина;	
					Запись.Записать(ИСТИНА);
				КонецЕсли; 

			КонецЕсли;
		Иначе
				Если Банкрот = ИСТИНА Тогда
					Сообщить( "Внимание! Контрагент включен в ""Единый государственный реестр сведений о банкротстве!""");
					
					Запись = РегистрРеестрПравонарушений.СоздатьМенеджерЗаписи();
					Запись.Контрагент = ВыборкаДетальныеЗаписи.Ссылка;
					Запись.Статус = СтатусНалогоплательщиков;
					Запись.УНП = УНП;
					Запись.ДатаЛиквидации = "";
					Запись.ДатаПроверки = ТекущаяДата();
					Запись.Банкрот = Истина;
					
					Запись.Записать(ИСТИНА);
				КонецЕсли; 

		КонецЕсли;
		
				
		Если СтатусНалогоплательщиков <> Неопределено Тогда
			
			КонтрагентОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонтрагентОбъект.СостояниеНалогоплательщика = СтатусНалогоплательщиков;
			
			Попытка
				КонтрагентОбъект.ОбменДанными.Загрузка = ИСТИНА;
				КонтрагентОбъект.Записать();
				
			Исключение
				
			КонецПопытки;	
			
		КонецЕсли; 		
		
	КонецЦикла;
	
КонецПроцедуры




Функция ПроверитьБСОНаПортале(ТипБСО,СерияБСО,НомерБСО) Экспорт
	
	СтрОтветБСО = Новый Структура;
	СтрОтветБСО.Вставить("НекорректныйЗапрос",Ложь);
	СтрОтветБСО.Вставить("НайденБСО",0);
	СтрОтветБСО.Вставить("НаименованиеОрганизации","");
	СтрОтветБСО.Вставить("ДатаРеализацииБСО","");
	СтрОтветБСО.Вставить("УНПОрганизации","");
	СтрОтветБСО.Вставить("ТекстОшибки","");

	
	
	  //http://ws.blank.bisc.by/FindBlankWSHttp.aspx?method=FindBlankWS&pTB=402961&pSB=ФЕ&pNB=6871292
	Соединение = Новый HTTPСоединение(
		"ws.blank.bisc.by", // сервер (хост)
		80, // порт, по умолчанию для http используется 80, для https 443
		, // пользователь для доступа к серверу (если он есть)
		, // пароль для доступа к серверу (если он есть)
		, // здесь указывается прокси, если он есть
		30, // таймаут в секундах, 0 или пусто - не устанавливать
		);
	
	Запрос = Новый HTTPЗапрос("/FindBlankWSHttp.aspx?method=FindBlankWS&pTB=" + ТипБСО + "&pSB=" + ПереобразоватьЮникод(СерияБСО)+ "&pNB=" + НомерБСО);
	
	Попытка
	
		Результат = Соединение.Получить(Запрос);
	
	
	//ожидание jadmin
	ДатаКон = ТекущаяДата() + 2;//1 секундой больше
	Пока ТекущаяДата() < ДатаКон Цикл
		 //пока выполняется цикл поток прерван
	КонецЦикла;
	
	Если Результат.КодСостояния = 200 Тогда
		
		//ЧтениеJSON = Новый ЧтениеJSON;
		//ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку("UTF-8"));
		//Ответ = ПрочитатьJSON(ЧтениеJSON);	
		//ЧтениеJSON.Закрыть();
		
		
		
		
		
		ЧтениеXML = Новый ЧтениеXML;
		
		ЧтениеXML.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку("UTF-8")); 
		
		Пока ЧтениеXML.Прочитать() Цикл
			
			Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
				
				
				Если ЧтениеXML.Имя = "IsFound" Тогда
					ЧтениеXML.Прочитать();
					СтрОтветБСО.НайденБСО = Число(ЧтениеXML.Значение);
					Если СтрОтветБСО.НайденБСО = 0  Тогда
						Возврат СтрОтветБСО;
					КонецЕсли;
				КонецЕсли;
				
				Если ЧтениеXML.Имя = "error" Тогда
					СтрОтветБСО.НекорректныйЗапрос = Истина;
					Возврат СтрОтветБСО;
				КонецЕсли;
				
				Если ЧтениеXML.Имя = "Date" Тогда
					ЧтениеXML.Прочитать();
					СтрОтветБСО.ДатаРеализацииБСО = ЧтениеXML.Значение;
				КонецЕсли;
				
				Если ЧтениеXML.Имя = "Name" Тогда
					ЧтениеXML.Прочитать();
					СтрОтветБСО.НаименованиеОрганизации = ЧтениеXML.Значение;
				КонецЕсли;
				
				Если ЧтениеXML.Имя = "UNP" Тогда
					ЧтениеXML.Прочитать();
					СтрОтветБСО.УНПОрганизации = ЧтениеXML.Значение;
				КонецЕсли;
			КонецЕсли ;
		КонецЦикла;

	КонецЕсли ;
	
	Исключение
	    СтрОтветБСО.Вставить("ТекстОшибки",ОписаниеОшибки());
	КонецПопытки;
	
	Возврат СтрОтветБСО;
	
КонецФункции // ()
 


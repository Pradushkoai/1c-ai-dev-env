функция ПолучитьСтатусПолучателя(Статус)
	
	Если Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Покупатель Тогда
		СтатусПолучателя = "CUSTOMER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Потребитель Тогда
		СтатусПолучателя = "CONSUMER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комитент Тогда
		СтатусПолучателя = "CONSIGNOR";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комиссионер Тогда
		СтатусПолучателя = "COMMISSIONAIRE";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПолучающийВычеты Тогда
		СтатусПолучателя = "TAX_DEDUCTION_RECIPIENT";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПокупательОбъектаУИностраннойОрганизации Тогда
		СтатусПолучателя = "FOREIGN_ORGANIZATION_BUYER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПолучающийОборотыПоРеализации Тогда
		СтатусПолучателя = "TURNOVERS_ON_SALE_RECIPIENT";
	КонецЕсли;
	
	Возврат СтатусПолучателя;
	
КонецФункции

функция ПолучитьСтатусПоставщика(Статус)
	
	Если Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Продавец Тогда
		СтатусПоставщика = "SELLER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комитент Тогда
		СтатусПоставщика = "CONSIGNOR";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комиссионер Тогда
		СтатусПоставщика = "COMMISSIONAIRE";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ИностраннаяОрганизация Тогда
		СтатусПоставщика = "FOREIGN_ORGANIZATION";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Посредник Тогда
		СтатусПоставщика = "AGENT";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Заказчик Тогда
		СтатусПоставщика = "DEVELOPER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ДоверительныйУправляющий Тогда
		СтатусПоставщика = "TRUSTEE";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПередающийВычеты Тогда
		СтатусПоставщика = "TAX_DEDUCTION_PAYER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПередающийОборотыПоРеализации Тогда
		СтатусПоставщика = "TURNOVERS_ON_SALE_PAYER";
	КонецЕсли;
	Возврат СтатусПоставщика;
	
КонецФункции


Процедура СформироватьЭСЧФ() Экспорт
	
	КомандаОбновитьСОС= "C:\Program Files (x86)\Avest\AvPCM_nces\get_crl.bat";
	         
	Shell = Новый COMОбъект("WScript.Shell");
	WshExec = Shell.Exec(КомандаОбновитьСОС);
	OutStream = WshExec.StdOut;  
	    
	Str = "";
	Пока Не OutStream.AtEndOfStream Цикл
	   Str = СокрЛП(OutStream.ReadLine());
	КонецЦикла;
	
	
	КаталогРазмещенияФайлов = "\\192.168.0.111\eInvVat";
	
	Соединение = Неопределено;
	Отказ = ложь;
	ТекстОшибки = "";
	СтрокаСоединения = "";
	
	//СтрокаСоедиенения = "PUB_KEY_ID=" + СокрЛП(СтрЗаменить(НастройкиПодключенияОрг.Ключ, " ", "")) + ";PASSWORD_KEY=" + НастройкиПодключенияОрг.Пароль;
	СтрокаСоединения = "UNP=600052664" + ";PASSWORD_KEY=293358595";
	
	
	Соединение = ПолучитьСоединениеМНС(СтрокаСоединения, ТекстОшибки, Отказ);
	
	Если Соединение <> Неопределено Тогда
		
		ПараметрыПодключения = Новый Соответствие;
		ПараметрыПодключения.Вставить("Соединение",Соединение);
		
		EVatService = ПараметрыПодключения.Получить("Соединение");
	Иначе
		Возврат;
	КонецЕсли;	
	
	
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЭСЧФДляВыставленияОстатки.ДокументОснование КАК ДокументОснование,
	|	СУММА(ЭСЧФДляВыставленияОстатки.СостояниеОстаток) КАК СостояниеОстаток
	|ИЗ
	|	РегистрНакопления.ЭСЧФДляВыставления.Остатки(&ДатаКонОст, ) КАК ЭСЧФДляВыставленияОстатки
	|ГДЕ
	|	ЭСЧФДляВыставленияОстатки.ДокументОснование.Проведен = &Проведен
	|	И ЭСЧФДляВыставленияОстатки.ДокументОснование.Дата МЕЖДУ &ДатаНач И &ДатаКон
	|	И ЭСЧФДляВыставленияОстатки.СостояниеОстаток > 0
	|	И ТИПЗНАЧЕНИЯ(ЭСЧФДляВыставленияОстатки.ДокументОснование.Ссылка) = ТИП(Документ.РеализацияТоваровУслуг)
	//|	И ЭСЧФДляВыставленияОстатки.ДокументОснование.БезвозмезднаяПередача = ЛОЖЬ
	|
	|СГРУППИРОВАТЬ ПО
	|	ЭСЧФДляВыставленияОстатки.ДокументОснование";
	
    //Запрос.УстановитьПараметр("ДатаНач", НачалоМесяца(ТекущаяДата())-1296000);   
    //Запрос.УстановитьПараметр("ДатаКон", НачалоДня(ТекущаяДата()-432000)); /////// 5 дней ранее
    
	Запрос.УстановитьПараметр("ДатаНач", НачалоМесяца(ТекущаяДата()-2592000));   ////1296000
	Запрос.УстановитьПараметр("ДатаКон", НачалоДня(ТекущаяДата()-432000)); /////// 5 дней ранее
    
    
	Запрос.УстановитьПараметр("ДатаКонОст", КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Проведен", Истина);                     
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	
	
	Если РезультатЗапроса.Пустой() Тогда
		Сообщить("Нет данных для формирования ЭСЧФ.");
		//ПроверитьСтатусыНаСервере();
		Возврат;
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	
	Основание = Неопределено;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Основание = ВыборкаДетальныеЗаписи.ДокументОснование;
		
		Если ТипЗнч(Основание.ссылка) <> Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Продолжить;
		КонецЕсли; 	
		
		
		Если Основание <> Неопределено Тогда
			
			Новая_ЭСЧФ = Документы.ЭСЧФИсходящий.СоздатьДокумент();
			Новая_ЭСЧФ.Организация = Основание.Организация;
			Новая_ЭСЧФ.Автор = ПараметрыСеанса.ТекущийПользователь;
			Новая_ЭСЧФ.Дата = ТекущаяДатаСеанса();
			//Новая_ЭСЧФ.НомерЭСЧФ = ""+"600052664-"+Формат(Год(ТекущаяДатаСеанса()),"ЧГ=0")+"-"+СокрЛП(Основание.НомерБСО); 
			
			
			Префикс ="";
			
			лНомер = СокрЛП(Основание.НомерБСО);
			// Префикс убираем 
			Если Не ПустаяСтрока(Префикс) Тогда
				лНомер = СтрЗаменить(лНомер,Префикс,"");

////Сообщить(ГенерацияСлучайногоСимвола(ТекущаяУниверсальнаяДатаВМиллисекундах(),6,ЛОЖЬ)); ПримерВызоваПроцедуры
///ДлинаЗначения - длина генерации случайного числа из 6-ти символов, например "d0c8Yf"   
///СУчетомРегистра - С учетом регистра или без
&НаСервере
Функция ГенерацияСлучайногоСимвола(ДлинаЗначения,СУчетомРегистра = ЛОЖЬ) Экспорт 
	
	
    ГСЧ = Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());    
    СлучайнаяСтрока = "";
    // генерируем случайное число из 6-ти символов, например "d0c8Yf"
	Для Сч = 1 по ДлинаЗначения Цикл    
		
		
		Если СУчетомРегистра = ИСТИНА Тогда
	       Набор = ГСЧ.СлучайноеЧисло(1,3);  
		Иначе
		   Набор = ГСЧ.СлучайноеЧисло(1,2);  
		КонецЕсли; 
		
        Если Набор = 1 Тогда
            // это число
            СлучайныйСимвол = ГСЧ.СлучайноеЧисло(0,9);
		ИначеЕсли Набор = 2 Тогда
            // это маленькая буква латиницы
            СлучайныйСимвол = Символ(ГСЧ.СлучайноеЧисло(97,122));
        ИначеЕсли Набор = 3 Тогда
            // это Большая буква латиницы
            СлучайныйСимвол = Символ(ГСЧ.СлучайноеЧисло(65,90));
        КонецЕсли;
        СлучайнаяСтрока = СлучайнаяСтрока + СлучайныйСимвол;
    КонецЦикла;      
    Возврат(СлучайнаяСтрока);    
КонецФункции


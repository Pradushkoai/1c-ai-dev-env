Функция ПроверитьВхождениеВРеесстрОБанкротсвеИзРегистра(УНП)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеестрПравонарушений_Локализация.УНП КАК УНП,
		|	РеестрПравонарушений_Локализация.Контрагент КАК Контрагент,
		|	РеестрПравонарушений_Локализация.Статус КАК Статус,
		|	РеестрПравонарушений_Локализация.Банкрот КАК Банкрот,
		|	РеестрПравонарушений_Локализация.ПовышенныйРиск КАК ПовышенныйРиск
		|ИЗ
		|	РегистрСведений.РеестрПравонарушений_Локализация КАК РеестрПравонарушений_Локализация
		|ГДЕ
		|	РеестрПравонарушений_Локализация.УНП = &УНП";
	
	Запрос.УстановитьПараметр("УНП", УНП);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ИСТИНА;
	КонецЦикла;
	
	Возврат ЛОЖЬ;


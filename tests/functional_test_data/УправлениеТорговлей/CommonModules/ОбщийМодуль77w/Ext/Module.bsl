		ДанныеДатаНачалаВыгрузки = Дата(1,1,1);
		ДанныеДатаКонцаВыгрузки = Дата(1,1,1);
		
		ЧислоДняТекДаты = Число(Формат(ТекущаяДата(),"ДФ=dd"));
		ДанныеДатаКонцаВыгрузки = КонецДня(ТекущаяДата());
		
		Если ЧислоДняТекДаты > Константы.яЧислоПредыдущихДнейДляВыгрузкиВБух.Получить() Тогда
			ДанныеДатаНачалаВыгрузки = НачалоМесяца(ТекущаяДата());
		Иначе
			ДанныеДатаНачалаВыгрузки = НачалоМесяца(ДобавитьМесяц(ТекущаяДата(),-1));
		КонецЕсли; 
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СуммыПереоценкиРозницы.ДокументПереоценки КАК ДокументПереоценки
		|ИЗ
		|	РегистрСведений.СуммыПереоценкиРозницы КАК СуммыПереоценкиРозницы
		|ГДЕ
		|	СуммыПереоценкиРозницы.ДатаПереоценки МЕЖДУ &НачДата И &КонДата
		|
		|СГРУППИРОВАТЬ ПО
		|	СуммыПереоценкиРозницы.ДокументПереоценки
		|
		|УПОРЯДОЧИТЬ ПО
		|	СуммыПереоценкиРозницы.ДокументПереоценки.Дата";
		
		Запрос.УстановитьПараметр("НачДата", ДанныеДатаНачалаВыгрузки);
		Запрос.УстановитьПараметр("КонДата", ДанныеДатаКонцаВыгрузки);
		
		РезультатЗапроса = Запрос.Выполнить();
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		КоличествоДокументов = 0;
		КоличествоДокументов = РезультатЗапроса.Количество();
		

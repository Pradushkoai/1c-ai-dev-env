			count = стр.КолВоДетей;
		КонецЕсли;
		
		prefix = стр.Уровень;

		
		Если ЗначениеЗаполнено(стр.Уникальность) Тогда			
			uniq = стр.Уникальность;
		КонецЕсли; 


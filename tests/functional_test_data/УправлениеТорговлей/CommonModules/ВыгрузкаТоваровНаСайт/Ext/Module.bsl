//Установка признака популярные товары
&НаСервере
Процедура УстановкаПризнакаНоменклатуреПопулярный()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГруппаДляСайта.Ссылка КАК Ссылка,
		|	ГруппаДляСайта.ПометкаУдаления КАК ПометкаУдаления,
		|	ГруппаДляСайта.Код КАК Код,
		|	ГруппаДляСайта.Наименование КАК Наименование,
		|	ГруппаДляСайта.МинКолВоДляОтбораПопулярных КАК МинКолВоДляОтбораПопулярных
		|ИЗ
		|	Справочник.ГруппаДляСайта КАК ГруппаДляСайта
		|ГДЕ
		|	ГруппаДляСайта.ПометкаУдаления = ЛОЖЬ
		|	И ГруппаДляСайта.Родитель = ЗНАЧЕНИЕ(Справочник.ГруппаДляСайта.ПустаяСсылка)";
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока РезультатЗапроса.Следующий() Цикл
		
		
		МинКолВоДляОтбораПопулярных = РезультатЗапроса.МинКолВоДляОтбораПопулярных;
		
		Запрос1 = Новый Запрос;
		Запрос1.УстановитьПараметр("ОсновнаяГруппа",РезультатЗапроса.Ссылка);
		Запрос1.УстановитьПараметр("ТипСклада",Перечисления.ТипыСкладов.РозничныйМагазин);
		Запрос1.УстановитьПараметр("ДатаНач",ТекущаяДата()-86400*15);
		Запрос1.УстановитьПараметр("ДатаКон",ТекущаяДата()-86400*1);
		
		Запрос1.Текст = 
			"ВЫБРАТЬ
			|	СУММА(ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот) КАК СуммаВыручкиОборот,
			|	СУММА(ВыручкаИСебестоимостьПродажОбороты.КоличествоОборот) КАК Количество,
			|	ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаНоменклатуры.Номенклатура.Ссылка КАК АналитикаУчетаНоменклатурыНоменклатураСсылка,
			|	ГруппыДляСайта.ГруппаДляСайта КАК ГруппаДляСайта
			|ИЗ
			|	РегистрСведений.ГруппыДляСайта КАК ГруппыДляСайта
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(&ДатаНач, &ДатаКон, , ) КАК ВыручкаИСебестоимостьПродажОбороты
			|		ПО (ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаНоменклатуры.Номенклатура = ГруппыДляСайта.Номенклатура)
			|ГДЕ
			|	ВыручкаИСебестоимостьПродажОбороты.Склад.ТипСклада = &ТипСклада
			|	И ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаНоменклатуры.Номенклатура.НеВыгружатьНаСайт = ЛОЖЬ
			|	И ГруппыДляСайта.ОсновнаяГруппа = ИСТИНА
			|	И ГруппыДляСайта.ГруппаДляСайта.ПометкаУдаления = ЛОЖЬ
			|	И ГруппыДляСайта.Номенклатура.ПометкаУдаления = ЛОЖЬ
			|	И ГруппыДляСайта.ГруппаДляСайта В ИЕРАРХИИ(&ОсновнаяГруппа)
			|
			|СГРУППИРОВАТЬ ПО
			|	ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаНоменклатуры.Номенклатура.Ссылка,
			|	ГруппыДляСайта.ГруппаДляСайта
			|
			|УПОРЯДОЧИТЬ ПО
			|	Количество УБЫВ";
		
		РезЗпр = Запрос1.Выполнить().Выгрузить();
		
		Если РезЗпр.Количество()> 0 Тогда
			Если РезЗпр.Итог("Количество") >= МинКолВоДляОтбораПопулярных Тогда
			
				ТоварыКолВо = Окр(РезЗпр.Количество() * 20/100, 0) - 1;
				Для i=0 По ТоварыКолВо Цикл
									
					//записываем в регистр
					МенеджерЗаписи = РегистрыСведений.ПопулярныеТовары.СоздатьМенеджерЗаписи();
					МенеджерЗаписи.Период = ТекущаяДата();
					МенеджерЗаписи.Номенклатура = РезЗпр[i].АналитикаУчетаНоменклатурыНоменклатураСсылка;
					МенеджерЗаписи.ТекущийПопулярный = Истина;
					МенеджерЗаписи.Записать();
				
				КонецЦикла;
			Иначе
				Продолжить;	
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ВыгрузитьПаролиОпт()
	
		
		Путь = ПолучитьПуть();
		КаталогВыгрузки_login_opt = ""+сокрлп(Путь)+"logins.csv";
		
		
		Файл_login_opt = Новый ЗаписьТекста(КаталогВыгрузки_login_opt,КодировкаТекста.UTF8);
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Партнеры.Ссылка КАК Ссылка,
		|	Партнеры.Код КАК Код,
		|	Партнеры.Наименование КАК Наименование,
		|	Партнеры.ДоступНаСайт КАК ДоступНаСайт,
		|	Партнеры.ПарольДляСайта КАК ПарольДляСайта,
		|	Партнеры.ПарольДляСайтаMD5 КАК ПарольДляСайтаMD5
		|ИЗ
		|	Справочник.Партнеры КАК Партнеры
		|ГДЕ
		|	Партнеры.ДоступНаСайт = ИСТИНА";
		
		
		РезЗпр = Запрос.Выполнить().Выбрать();

		
		id = 0;
		
		Файл_login_opt.ЗаписатьСтроку("1;Admin;e49b17ebce3ea69cb0f0f6d9c9ee2c99;Admin;");

		Пока РезЗпр.Следующий() Цикл
			
			id = РезЗпр.Код;
			id = Прав(id,8);
			id = Число(id);
			id = СтрЗаменить(id,Символы.НПП,"");
			id = СтрЗаменить(id," ","");
			
			name = id;
			login = id;
			
			pass = РезЗпр.ПарольДляСайтаMD5;
			pass = СтрЗаменить(pass," ","");
			
			Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(РезЗпр.Наименование, ИСТИНА);
			Регистратор = Неопределено;
			СкидкаОбщая = 0;
			СкидкаОбщая = ПолучитьРазмерСкидки_Опт(Контрагент);
			//ОбщийМодуль77w.РасчитатьСкидкуКлиента(Контрагент,Регистратор,,,СкидкаОбщая);
			
			РазмерСкидки = СкидкаОбщая/100;
			РазмерСкидки = СтрЗаменить(РазмерСкидки,",",".");
			
			Файл_login_opt.ЗаписатьСтроку(""+id+";"+login+";"+pass+";"+name+";"+РазмерСкидки);
			
			
			Пока СтрДлина(id) <> 6 Цикл
				id = "0" + id;
			КонецЦикла; 
			
			Для стрИД = 1 По 5 Цикл
				ДопИД = ""+стрИД + "0" + id;
				ДопИД = СтрЗаменить(ДопИД,Символы.НПП,"");
				Файл_login_opt.ЗаписатьСтроку(""+ДопИД+";"+ДопИД+";"+pass+";"+name+";"+РазмерСкидки);
			КонецЦикла;
		КонецЦикла;
		
		Файл_login_opt.Закрыть();
		//Сообщить("Выгрузка завершена.");
		
КонецПроцедуры
//
Функция ПолучитьРазмерСкидки_Опт(Контрагент)
	
	СкидкаОбщая = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкидкиКлиентов_Опт.Контрагент КАК Контрагент,
		|	СкидкиКлиентов_Опт.СкидкаОбщая КАК СкидкаОбщая
		|ИЗ
		|	РегистрСведений.СкидкиКлиентов_Опт КАК СкидкиКлиентов_Опт
		|ГДЕ
		|	СкидкиКлиентов_Опт.Контрагент = &Контрагент";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СкидкаОбщая = ВыборкаДетальныеЗаписи.СкидкаОбщая;
	КонецЦикла;
	
	Возврат СкидкаОбщая;


КонецФункции // ()


Процедура ЗаписатьСкидкиКлиентов_Опт_В_РС()   ЭКСПОРТ

	    Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Партнеры.Ссылка КАК Ссылка,
		|	Партнеры.Код КАК Код,
		|	Партнеры.Наименование КАК Наименование,
		|	Партнеры.ДоступНаСайт КАК ДоступНаСайт,
		|	Партнеры.ПарольДляСайта КАК ПарольДляСайта,
		|	Партнеры.ПарольДляСайтаMD5 КАК ПарольДляСайтаMD5
		|ИЗ
		|	Справочник.Партнеры КАК Партнеры
		|ГДЕ
		|	Партнеры.ДоступНаСайт = ИСТИНА";
		
		
		РезЗпр = Запрос.Выполнить().Выбрать();

		

		Пока РезЗпр.Следующий() Цикл
					
			Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(РезЗпр.Наименование, ИСТИНА);
			СкидкаОбщая = 0;
			Регистратор = Неопределено;
			ОбщийМодуль77w.РасчитатьСкидкуКлиента(Контрагент,Регистратор,,,СкидкаОбщая);

			МенеджерЗаписей = РегистрыСведений.СкидкиКлиентов_Опт.СоздатьМенеджерЗаписи();
			МенеджерЗаписей.Контрагент = Контрагент;
			МенеджерЗаписей.СкидкаОбщая = СкидкаОбщая;
			МенеджерЗаписей.Записать(ИСТИНА);
	
		КонецЦикла;
		
КонецПроцедуры
 



Процедура ПроверитьОплатуИнтернетЗаказов() 

	
	////Проверка оплаты ЕРИП
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИнтернетЗаказРозничный.Ссылка КАК Ссылка,
		|	ИнтернетЗаказРозничный.Проведен КАК Проведен,
		|	ИнтернетЗаказРозничный.Статус КАК Статус,
		|	ИнтернетЗаказРозничный.СуммаДокумента КАК СуммаДокумента,
		|	ИнтернетЗаказРозничный.НомерЕРИП КАК НомерЕРИП,
		|	ИнтернетЗаказРозничный.ФормаОплаты КАК ФормаОплаты
		|ИЗ
		|	Документ.ИнтернетЗаказРозничный КАК ИнтернетЗаказРозничный
		|ГДЕ
		|	ИнтернетЗаказРозничный.Проведен = ИСТИНА
		|	И ИнтернетЗаказРозничный.Статус = &Статус
		|	И ИнтернетЗаказРозничный.НомерЕРИП <> """"
		|	И ИнтернетЗаказРозничный.ПризнакОплатыСчета = ЛОЖЬ
		|	И ИнтернетЗаказРозничный.ФормаОплаты = &ФормаОплаты";
	
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЗаказовКлиентов.КОтгрузке);
	Запрос.УстановитьПараметр("ФормаОплаты", Перечисления.ФормыОплаты.ЕРИП);

	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	ТокенЕРИП = "5e729f70f4b447e4a1b044ea08080ce5";
	Пока РезультатЗапроса.Следующий() Цикл
		НомерЕРИП = РезультатЗапроса.НомерЕРИП;
		
		
		ЗаписьJSON = Новый ЗаписьJSON;

			
		тПараметрыJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, " ", Истина);  
		ЗаписьJSON.УстановитьСтроку(тПараметрыJSON); 
		
		
		МассивДанныхJSON = Новый Массив;
		//СтруктураДанныхJSON = Новый Структура; 
		
		
		тДанные = Новый Структура;                             
			тДанные.Вставить("token", ТокенЕРИП);
			тДанные.Вставить("invoiceNo", ""+НомерЕРИП+"");
		МассивДанныхJSON.Добавить(тДанные);
		

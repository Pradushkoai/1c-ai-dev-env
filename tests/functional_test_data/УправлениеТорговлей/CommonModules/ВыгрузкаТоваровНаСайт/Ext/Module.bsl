&НаСервере
Процедура КомандаОбработатьДанныеНаСервереАПИ_ОПТ(ТекстПерваяСтрока,ТекстВтораяСтрока,ТекстТовары,Комментарий,ИДЗаказа)

	
	Попытка

		Разделитель = ";";
		
		ДанныеЗаказа = СтрРазделить(ТекстПерваяСтрока,Разделитель);     
		
		
		СтрокаЗаказ = СтрРазделить(ТекстВтораяСтрока,Разделитель);
		КодКлиента = СтрокаЗаказ[2 -1];
		КодКлиента = СтрЗаменить(КодКлиента, "login:", "");
		КодКлиента = СтрЗаменить(КодКлиента, " ", "");
		
		Если КодКлиента = "" Тогда
		
			Возврат;
		
		КонецЕсли;
		
		ПризнакДоставки = СтрокаЗаказ[3 -1];
		ПризнакДоставки = Число(СтрЗаменить(ПризнакДоставки, "Признак доставки:", ""));       
		
		//если значение Признак доставки 1 то самовывоз, 2 то доставка
		Если ПризнакДоставки = 2 Тогда
		
			АдресДоставки = СтрокаЗаказ[4 -1];	
		    АдресДоставки = СтрЗаменить(АдресДоставки, "Адрес:", "");
			
		КонецЕсли; 
		
		Если СтрДлина(КодКлиента) >= 8 Тогда
		     КодКлиента = Прав(КодКлиента,6);		
		КонецЕсли; 
		
		Пока СтрДлина(КодКлиента) <> 8 Цикл
			КодКлиента = "0" + КодКлиента;
		КонецЦикла; 
		КодКлиента = "00-" + КодКлиента;
		
		Партнер = Справочники.Партнеры.НайтиПоКоду(КодКлиента);
		Склад = Справочники.Склады.Склад3;
		ЗаказНомер = СтрокаЗаказ[1 -1];
		

			Заказ = Документы.ИнтернетЗаказКлиента.СоздатьДокумент();
			Заказ.Партнер = Партнер;
			Заказ.Контрагент = Партнер;
			Заказ.ОсновнойМенеджер = Партнер.ОсновнойМенеджер;

			//Заказ.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Оптовые",Истина);
			
			Заказ.Дата = ТекущаяДата();
			Заказ.ЗаказТребуетВниманияМенеджера = Истина;
			Заказ.ИнтернетЗаказ = Истина;
			//Заказ.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению;			
			Заказ.Статус = Перечисления.СтатусыЗаказовКлиентов.НеСогласован; //jadmin
			
		   	Заказ.Приоритет = Справочники.Приоритеты.НайтиПоНаименованию("Средний",Истина);
			Заказ.Склад = Склад.Родитель;
			
			Если ПризнакДоставки = 2 Тогда
				
				Заказ.СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента;
				Заказ.АдресДоставкиСайт = АдресДоставки;
				
			Иначе
				
			    Заказ.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;

			КонецЕсли; 
			
			Заказ.ИДЗаказа = ИДЗаказа;
			
			Заказ.Комментарий = "Интернет" + ЗаказНомер + ", " + ТекстПерваяСтрока;
			Комментарий = Заказ.Комментарий;
			//СуммаИтого = 0;          
			
			МассивТовары = РазложитьСтрокуНаПодстроки(ТекстТовары,Символы.ПС);
			
			Для каждого Строка Из МассивТовары Цикл
				
				Если Строка = "" Тогда
				
					Продолжить;	
				
				КонецЕсли;
				//Строка = ПрочитанныйФайл.ПолучитьСтроку(НомерСтроки);
			
				//Если Найти(Строка, "Итого ") > 0 Тогда
				//	
				//	СтрокаИтого = СтрРазделить(Строка,Разделитель);
				//	СуммаИтого = СтрокаИтого[2 -1];				
				//	Заказ.СуммаДокумента = СуммаИтого;
				//	
				//	Прервать;				//	
				//	Прервать;
				//
				//КонецЕсли;

				Если Найти(Строка, "Итого ") > 0 Тогда
					
					СтрокаИтого = СтрРазделить(Строка,Разделитель);
					СуммаИтого = СтрокаИтого[2 -1];				
					Заказ.СуммаДокумента = СуммаИтого;
					
					Прервать;
					
				КонецЕсли;
								
				МассивКол = СтрРазделить(Строка,Разделитель);
				
				КодТовара = МассивКол[2-1];
				Наименование =  МассивКол[4-1]; 
				КолВо = МассивКол[5-1];
				Цена = МассивКол[6-1];
				Сумма = МассивКол[7-1];
			
				
				
				Пока СтрДлина(КодТовара) <> 8 Цикл
					КодТовара = "0" + КодТовара;
				КонецЦикла; 
				КодТовара = "00-" + КодТовара;

				Номенклатура = Справочники.Номенклатура.НайтиПоКоду(КодТовара);
			
				Товар = Заказ.Товары.Добавить();
				Товар.Номенклатура = Номенклатура;
				Товар.Упаковка = Номенклатура.ЕдиницаИзмерения;
				Товар.Количество = Число(КолВо);
				Товар.КоличествоУпаковок = Число(КолВо);
				Товар.ВидЦены = Справочники.ВидыЦен.НайтиПоНаименованию("Оптовые",Истина);
				Товар.Цена = ПолучитьЦену(Номенклатура); 
				Товар.Сумма = Товар.Количество * Товар.Цена;
				Товар.СтатусУказанияСерий = 14;
				Товар.Склад = ПолучитьСклад(Номенклатура);
				Товар.СтавкаНДС = Номенклатура.СтавкаНДС;
				Товар.ДатаОтгрузки = НачалоДня(ТекущаяДата());
				Товар.КлючСвязи = Товар.НомерСтроки;
				//СуммаИтого = СуммаИтого + Товар.Сумма;				
				
			КонецЦикла;
		//
		//		СтрокаИтого = СтрРазделить(ПрочитанныйФайл.ПолучитьСтроку(ПрочитанныйФайл.КоличествоСтрок()),Разделитель);
		//		СуммаИтого = СтрокаИтого[2 -1];
		//		
		//		Заказ.СуммаДокумента = СуммаИтого;
            ЗаказНайден = ПроверитьЗаказНаСуществование_ОПТ(ИДЗаказа);
				
			Если ЗаказНайден = ЛОЖЬ Тогда
				
				Заказ.Записать(РежимЗаписиДокумента.Запись);		
				
				
				
				УчетнаяЗаписьПочта = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
				
				ПрофильПодключения = Новый ИнтернетПочтовыйПрофиль;
				ПрофильПодключения.АдресСервераSMTP = УчетнаяЗаписьПочта.СерверИсходящейПочты;
				
				ПрофильПодключения.ИспользоватьSSLSMTP=УчетнаяЗаписьПочта.ИспользоватьЗащищенноеСоединениеДляИсходящейПочты;
				
				ПрофильПодключения.ПортSMTP = УчетнаяЗаписьПочта.ПортСервераИсходящейПочты;
				
				ПрофильПодключения.ПользовательSMTP = УчетнаяЗаписьПочта.АдресЭлектроннойПочты;
				Пароли = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(УчетнаяЗаписьПочта, "Пароль, ПарольSMTP");
				
				ПрофильПодключения.ПарольSMTP = Пароли.Пароль;
				
				
				//Создаем объект ИнтернетПочта
				Почта = Новый ИнтернетПочта;
				
				//Пытаемся подключится к серверу используя наши настройки.
				Попытка
					Почта.Подключиться(ПрофильПодключения);
				Исключение
					Сообщить("Не удалось подключиться к серверу smtp");
					Сообщить(ОписаниеОшибки());
				КонецПопытки;
				
				//Определяемся с текстом письма
				Тело="Добрый день!
				|Получен новый интернет-заказ:
				|
				|"+Комментарий+" Сумма заказа: "+СуммаИтого;
				
				//Создаем сообщение
				Письмо = Новый ИнтернетПочтовоеСообщение;
				
				//Добавляем наш текст в письмо
				Письмо.Тексты.Добавить(Тело);
				
				//Добавляем тему
				Письмо.Тема = "Новый интернет-заказ";
				
				////Добавляем ту же почту, через которую подключаемся к серверу
				
				Письмо.Отправитель = "seedgatovo@msso.by";
				
				//Добавляем имя отправителя
				Письмо.ИмяОтправителя = "Новый интернет-заказ";
				
				////Добавляем получателя
				ЕmailМенеджера = "";
				
				Попытка
					ЕmailМенеджера = ""+СокрЛП(Партнер.ОсновнойМенеджер.ФизическоеЛицо.КонтактнаяИнформация[0].Представление);
				Исключение
					//ОписаниеОшибки()
				КонецПопытки; 
				
				Письмо.Получатели.Добавить(ЕmailМенеджера);
				
				Попытка
					Почта.Послать(Письмо);
				Исключение
					Сообщить("Не удалось отправить письмо ");
					Сообщить(ОписаниеОшибки());
				КонецПопытки;	
				
				//Обязательно отключаемся от почтового сервера по завершении отправки письма.	
				Почта.Отключиться();

				УстановитьСтатусНаСайтеОбработан_ОПТ(ИДЗаказа);				
			Иначе
				УстановитьСтатусНаСайтеОбработан_ОПТ(ИДЗаказа);	
			КонецЕсли; 	
	Исключение
		////пишем в телеграм ошибку
		//Ошибка = ОписаниеОшибки();
		//Команда1 = "C:\cURL\curl.exe https://api.telegram.org/bot977867589:AAF0xKkESIU4XcTzIJF3DsFVfnGExEACK3Y/sendMessage?chat_id=-338090218=&text=""*ОШИБКА ПРИ СОЗДАНИИ ИНТЕРНЕТ ЗАКАЗОВ ОПТА* %0A " + Ошибка + " ""&parse_mode=Markdown";  
		//Shell = Новый COMОбъект("WScript.Shell");
		//WshExec = Shell.Exec(Команда1);
		//OutStream = WshExec.StdOut;
		
		//пишем в телеграм ошибку обмена
		ЗаголовокОшибки = "ОШИБКА ПРИ СОЗДАНИИ ИНТЕРНЕТ ЗАКАЗОВ ОПТ"; 
		Ошибка = ОписаниеОшибки();

		А = МССО_РассылкиУведомления.ОтправитьУведомлениеВТелеграм(ЗаголовокОшибки, Ошибка);

	КонецПопытки;
		
КонецПроцедуры

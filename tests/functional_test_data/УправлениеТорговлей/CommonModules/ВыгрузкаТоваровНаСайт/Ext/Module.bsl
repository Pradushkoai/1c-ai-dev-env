		Файл = Новый Файл(ИмяФайла);
		Если Файл.Существует() Тогда
			УдалитьФайлы(ИмяФайла);
		КонецЕсли;
	Иначе
		Сообщить("Ошибка соединения с сайтом "+ Результат.КодСостояния);
	КонецЕсли;		
	
КонецПроцедуры // ()

&НаСервере
Процедура СформироватьФайлОПС()
	
	Путь = ПолучитьПуть();
	КаталогВыгрузки = ""+сокрлп(Путь)+"OPS_Europost.csv";
		
	// записываем в файл с символами BOM в начале файле	
	ТекстовыйФайлUTF8_Bom = Новый ТекстовыйДокумент();
	
	СтрокаФайла = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕвроПочтаОПС.ИД_ОПС КАК ИД_ОПС,
	|	ЕвроПочтаОПС.Наименование_ОПС КАК Наименование_ОПС,
	|	ЕвроПочтаОПС.Longitude КАК Longitude,
	|	ЕвроПочтаОПС.Latitude КАК Latitude,
	|	ЕвроПочтаОПС.ИД_Области КАК ИД_Области,
	|	ЕвроПочтаОПС.Наименование_Области КАК Наименование_Области,
	|	ЕвроПочтаОПС.ПризнакНовое КАК ПризнакНовое,
	|	ЕвроПочтаОПС.Примечание КАК Примечание
	|ИЗ
	|	РегистрСведений.ЕвроПочтаОПС КАК ЕвроПочтаОПС";
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();	
		
		Пока РезультатЗапроса.Следующий() Цикл
			ИД_ОПС="";
			Наименование_ОПС = "";
			Longitude = 0;
			Latitude = 0;
			ИД_Области = "";

			////Записываем строчку в файл	Пустую строку для обхода ошибки при импорте mysql
			Если СтрокаФайла = 1 Тогда
				СтрСтрокаФайла = 99999;
				СтрСтрокаФайла = СтрЗаменить(СтрСтрокаФайла,Символы.НПП,"");
				
				СтрокаТекст = "'"+СтрСтрокаФайла + "';'" +Строка(Наименование_ОПС)+"';'"+Строка(ИД_Области)+"';";
				
				СтрокаТекст = СтрЗаменить(СтрокаТекст,Символы.НПП,"");
				ТекстовыйФайлUTF8_Bom.ДобавитьСтроку(СтрокаТекст);			
			КонецЕсли; 
		
			ИД_ОПС=РезультатЗапроса.ИД_ОПС;
			Наименование_ОПС = РезультатЗапроса.Наименование_ОПС;
			Longitude = РезультатЗапроса.Longitude;
			Latitude = РезультатЗапроса.Latitude;
			ИД_Области = РезультатЗапроса.ИД_Области;

			////Записываем строчку в файл	
			СтрокаФайла = СтрокаФайла + 1;	
			СтрСтрокаФайла = СтрЗаменить(СтрокаФайла,Символы.НПП,"");
			
			СтрокаТекст = "'"+СтрСтрокаФайла + "';'" +Строка(Наименование_ОПС)+"';'"+Строка(ИД_Области)+"';";
			
			СтрокаТекст = СтрЗаменить(СтрокаТекст,Символы.НПП,"");
			ТекстовыйФайлUTF8_Bom.ДобавитьСтроку(СтрокаТекст);	
		КонецЦикла;
		
	ТекстовыйФайлUTF8_Bom.Записать(КаталогВыгрузки,"UTF-8");
	
	// открываем файл и считываем символы после символов BOM
	Данные = Новый ДвоичныеДанные(КаталогВыгрузки);
	Строка64=Base64Строка(Данные);
	Строка64=Прав(Строка64,СтрДлина(Строка64)-4);
	ДанныеНаЗапись=Base64Значение(Строка64);
	ДанныеНаЗапись.Записать(КаталогВыгрузки); // записываем
	//Сообщить("Выгрузка завершена.");

	
КонецПроцедуры

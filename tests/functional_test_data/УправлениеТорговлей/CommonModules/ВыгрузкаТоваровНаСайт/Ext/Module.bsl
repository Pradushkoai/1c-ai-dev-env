Процедура УстановитьСнятьПризнакНовинкаНоменклатуре()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВерсииОбъектов.Объект КАК Объект,
		|	ВерсииОбъектов.НомерВерсии КАК НомерВерсии,
		|	ВерсииОбъектов.ДатаВерсии КАК ДатаВерсии,
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.Родитель КАК Родитель,
		|	Номенклатура.ПризнакНовинка КАК ПризнакНовинка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
		|		ПО (ВерсииОбъектов.Объект = Номенклатура.Ссылка)
		|ГДЕ
		|	ВерсииОбъектов.НомерВерсии = 1
		|	И Номенклатура.ПометкаУдаления = ЛОЖЬ
		|	И Номенклатура.ЭтоГруппа = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		НоменклатураСсылка = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		
		ПризнакНовинкаНоменклатуры = ВыборкаДетальныеЗаписи.ПризнакНовинка;
		
		ПризнакНовинка = ЛОЖЬ;
		Если ВыборкаДетальныеЗаписи.Родитель = Справочники.Номенклатура.НайтиПоКоду("00-00000002")   //1.1.1.  Овощные культуры (пакетированные)
			ИЛИ ВыборкаДетальныеЗаписи.Родитель = Справочники.Номенклатура.НайтиПоКоду("00-00000003") //1.1.2.  Цветочные культуры (пакетированные)
			
			ИЛИ ВыборкаДетальныеЗаписи.Родитель.Родитель = Справочники.Номенклатура.НайтиПоКоду("00-00000002")   //1.1.1.  Овощные культуры (пакетированные)
			ИЛИ ВыборкаДетальныеЗаписи.Родитель.Родитель = Справочники.Номенклатура.НайтиПоКоду("00-00000003") //1.1.2.  Цветочные культуры (пакетированные)
			
			ИЛИ ВыборкаДетальныеЗаписи.Родитель.Родитель.Родитель = Справочники.Номенклатура.НайтиПоКоду("00-00000002")   //1.1.1.  Овощные культуры (пакетированные)
			ИЛИ ВыборкаДетальныеЗаписи.Родитель.Родитель.Родитель = Справочники.Номенклатура.НайтиПоКоду("00-00000003") //1.1.2.  Цветочные культуры (пакетированные)
			
			Тогда
			    ПризнакНовинка =  ПризнакНовинкаНоменклатуры;
				Продолжить;    //jadmin признак не проставляется (по просьбе Мисюченко)
			
			ДатаСозданияНоменклатуры = ВыборкаДетальныеЗаписи.ДатаВерсии;
			Если Месяц(ДатаСозданияНоменклатуры) >= 1 И Месяц(ДатаСозданияНоменклатуры) <= 4 Тогда
				ДатаОтсчета = НачалоДня(ДатаСозданияНоменклатуры);
			Иначе
				ДатаОтсчета = НачалоГода(ДатаСозданияНоменклатуры + 86400*365);

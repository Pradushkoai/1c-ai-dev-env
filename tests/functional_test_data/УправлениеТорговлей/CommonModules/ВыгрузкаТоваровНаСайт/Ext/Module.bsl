Функция ПроверитьВхождениеТовараВЗаказПоступления(Номенклатура)

	НоменклатураПрисутствуетВЗаказе = ЛОЖЬ;
 
 	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПредзаказНаСайтеДляИнтМаг.ЗаказПоставщику КАК ЗаказПоставщику,
		|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрСведений.ПредзаказНаСайтеДляИнтМаг КАК ПредзаказНаСайтеДляИнтМаг
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
		|		ПО ПредзаказНаСайтеДляИнтМаг.ЗаказПоставщику = ЗаказПоставщикуТовары.Ссылка
		|ГДЕ
		|	ЗаказПоставщикуТовары.Ссылка.Проведен = ИСТИНА
		|	И ЗаказПоставщикуТовары.Номенклатура = &Номенклатура
		|	И ПредзаказНаСайтеДляИнтМаг.Действует = ИСТИНА";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество()>0 Тогда
	
		НоменклатураПрисутствуетВЗаказе = ИСТИНА;
	
	КонецЕсли;

	Возврат НоменклатураПрисутствуетВЗаказе;

КонецФункции // ()


Функция ПроверитьЗаказНаСуществование(ИнтЗаказНомер)

	ЗаказНайден = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИнтернетЗаказРозничный.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ИнтернетЗаказРозничный КАК ИнтернетЗаказРозничный
		|ГДЕ
		|	ИнтернетЗаказРозничный.Проведен = &ИСТИНА
		|	И ИнтернетЗаказРозничный.ИнтЗаказНомер = &ИнтЗаказНомер";
	
	Запрос.УстановитьПараметр("ИнтЗаказНомер", ИнтЗаказНомер);
	Запрос.УстановитьПараметр("ИСТИНА", ИСТИНА);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество()>0 Тогда
	
		ЗаказНайден = ИСТИНА;
	
	КонецЕсли;
	
	Возврат ЗаказНайден;

КонецФункции // ПроверитьЗаказНаСуществование(Заказ.ИнтЗаказНомер)()



&НаСервере
Процедура УбратьПризнакПопулярный() 

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПопулярныеТоварыСрезПоследних.Период КАК Период,
		|	ПопулярныеТоварыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ПопулярныеТоварыСрезПоследних.ТекущийПопулярный КАК ТекущийПопулярный
		|ИЗ
		|	РегистрСведений.ПопулярныеТовары.СрезПоследних КАК ПопулярныеТоварыСрезПоследних
		|ГДЕ
		|	ПопулярныеТоварыСрезПоследних.ТекущийПопулярный = ИСТИНА";
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
		  Набор = РегистрыСведений.ПопулярныеТовары.СоздатьНаборЗаписей();
		  Набор.Отбор.Номенклатура.Установить(ВыборкаДетальныеЗаписи.Номенклатура);
		  Набор.Отбор.Период.Установить(ВыборкаДетальныеЗаписи.Период);
	  	  Набор.Прочитать();
		  
		  Для Каждого Запись Из Набор Цикл
			  Запись.ТекущийПопулярный = ЛОЖЬ;
		  КонецЦикла;

		  Набор.Записать();

	КонецЦикла;
	
КонецПроцедуры

Процедура ПерераспределениеСуммОплат(СуммаПредоплаты)

	ЗаказСсылка = ЭтотОбъект.Ссылка;
	
	Оплачено = ПроверкаСуммОплат(ЗаказСсылка);
	
	Если Оплачено > СуммаПредоплаты Тогда
	    ПредоплатаСверхЗаказа = Оплачено - СуммаПредоплаты;
		ОтрегулироватьОплатыПоЗаказу(ЗаказСсылка,ПредоплатаСверхЗаказа);
	КонецЕсли; 

КонецПроцедуры


Процедура ОтрегулироватьОплатыПоЗаказу(ЗаказСсылка,ПредоплатаСверхЗаказа)
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка КАК Ссылка,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ КАК Заказ,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Сумма КАК Сумма,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа
		|ГДЕ
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен = ИСТИНА
		|	И ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ = &ЗаказСсылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата УБЫВ";
	
	Запрос.УстановитьПараметр("ЗаказСсылка", ЗаказСсылка);
	
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
    
		
		Пока РезультатЗапроса.Следующий() Цикл
			
			Если ПредоплатаСверхЗаказа = 0 Тогда			
				Прервать;
			КонецЕсли;
			
			
			ПоступлениеДССсылка = РезультатЗапроса.Ссылка.ПолучитьОбъект();
			
			НС = ПоступлениеДССсылка.РасшифровкаПлатежа.Количество()-1;
			
			Для стр = -НС По 0 Цикл
				
				СуммаУменьшенияНашегоДолга = 0;
				стрДС = ПоступлениеДССсылка.РасшифровкаПлатежа[-стр];
	
			    Если стрДС.Заказ = ЗаказСсылка Тогда
			
					Если ПредоплатаСверхЗаказа > стрДС.Сумма  Тогда
					   СуммаУменьшенияНашегоДолга = стрДС.Сумма;
				    Иначе
					   СуммаУменьшенияНашегоДолга = ПредоплатаСверхЗаказа;		
					КонецЕсли;

					Если стрДС.Сумма - СуммаУменьшенияНашегоДолга = 0 Тогда
						ПоступлениеДССсылка.РасшифровкаПлатежа.Удалить(стрДС);
						
					Иначе
						стрДС.Сумма = стрДС.Сумма - СуммаУменьшенияНашегоДолга;
						стрДС.СуммаВзаиморасчетов = стрДС.Сумма;

					КонецЕсли;
					
						стрДСНовая = ПоступлениеДССсылка.РасшифровкаПлатежа.Добавить();
						ЗаполнитьЗначенияСвойств(стрДСНовая,стрДС);
						
						стрДСНовая.Сумма = СуммаУменьшенияНашегоДолга;
						стрДСНовая.ОснованиеПлатежа= Документы.ЗаказКлиента.ПустаяСсылка();
						стрДСНовая.Заказ = ЭтотОбъект.Договор;
						стрДСНовая.СуммаВзаиморасчетов = СуммаУменьшенияНашегоДолга;

					ПредоплатаСверхЗаказа = ПредоплатаСверхЗаказа - СуммаУменьшенияНашегоДолга;
					
					Если ПредоплатаСверхЗаказа = 0 Тогда			
						Прервать;
					КонецЕсли;

				КонецЕсли;
		
			КонецЦикла; 
			
			//ПоступлениеДССсылка.СуммаДокумента = ПоступлениеДССсылка.РасшифровкаПлатежа.Итог("Сумма");
			
			//Если ПоступлениеДССсылка.СуммаДокумента = 0 Тогда
			//	
			//    ПоступлениеДССсылка.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			//	ПоступлениеДССсылка.УстановитьПометкуУдаления(Истина);

			//Иначе
				ПоступлениеДССсылка.Записать(РежимЗаписиДокумента.Проведение);
			//КонецЕсли;

		КонецЦикла; 
	
КонецПроцедуры




Функция ПроверкаСуммОплат(ЗаказСсылка) //jadmin

	Оплачено = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СостоянияЗаказовКлиентов.Заказ КАК Заказ,
		|	СостоянияЗаказовКлиентов.Состояние КАК Состояние,
		|	СостоянияЗаказовКлиентов.ДатаСобытия КАК ДатаСобытия,
		|	СостоянияЗаказовКлиентов.СуммаОплаты КАК СуммаОплаты,
		|	СостоянияЗаказовКлиентов.ПроцентОплаты КАК ПроцентОплаты,
		|	СостоянияЗаказовКлиентов.СуммаОтгрузки КАК СуммаОтгрузки,
		|	СостоянияЗаказовКлиентов.ПроцентОтгрузки КАК ПроцентОтгрузки,
		|	СостоянияЗаказовКлиентов.СуммаДолга КАК СуммаДолга,
		|	СостоянияЗаказовКлиентов.ПроцентДолга КАК ПроцентДолга,
		|	СостоянияЗаказовКлиентов.ЕстьРасхожденияОрдерНакладная КАК ЕстьРасхожденияОрдерНакладная
		|ИЗ
		|	РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|ГДЕ
		|	СостоянияЗаказовКлиентов.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", ЗаказСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Оплачено =  Оплачено + ВыборкаДетальныеЗаписи.СуммаОплаты; 
	КонецЦикла;
	
	Возврат Оплачено;
	
КонецФункции // ()
 


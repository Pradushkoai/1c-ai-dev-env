Процедура ЗаполнитьСрокДействияЗаказа()

	Если ЭтотОбъект.Партнер.ВидПартнераКонтрагента.Наименование = "Торговые сети"  ТОГДА
		
	Иначе
		
		Если ЗначениеЗаполнено(ЭтотОбъект.Ссылка) Тогда	
			ДатаОплатыПлан = НачалоДня(ЭтотОбъект.Дата);
		Иначе
			ДатаОплатыПлан = НачалоДня(ТекущаяДата());	
		КонецЕсли; 
		
		Если ЭтотОбъект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным Тогда	
			Для каждого стр Из ЭтотОбъект.ЭтапыГрафикаОплаты Цикл
				Если стр.ВариантОплаты = Перечисления.ВариантыОплатыКлиентом.ПредоплатаДоОтгрузки Тогда
					ДатаОплатыПлан = ДобавитьРабочиеДни(стр.ДатаПлатежа,2);
					Прервать;
				КонецЕсли; 
			КонецЦикла;	
		КонецЕсли;
		
		ЭтотОбъект.СрокДействияЗаказа = ДобавитьРабочиеДни(ДатаОплатыПлан,2);
		
	КонецЕсли;

КонецПроцедуры
 
Функция ДобавитьРабочиеДни(Дата,КолВоДнейВперед)
	 	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА

Функция ПолучитьКоличествоВУпаковке(Номенклатура,Дата) Экспорт

		//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВзвешенныеТоварыКоличествоВУпаковкеСрезПоследних.Период КАК Период,
		|	ВзвешенныеТоварыКоличествоВУпаковкеСрезПоследних.Номенклатура КАК Номенклатура,
		|	ВзвешенныеТоварыКоличествоВУпаковкеСрезПоследних.КолВо КАК КолВо
		|ИЗ
		|	РегистрСведений.ВзвешенныеТоварыКоличествоВУпаковке.СрезПоследних(&Дата, ) КАК ВзвешенныеТоварыКоличествоВУпаковкеСрезПоследних
		|ГДЕ
		|	ВзвешенныеТоварыКоличествоВУпаковкеСрезПоследних.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	КолВоВУпак = Неопределено;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КолВоВУпак = ВыборкаДетальныеЗаписи.КолВо;
	КонецЦикла;
	
	Возврат КолВоВУпак;
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА


КонецФункции // ()


Процедура ЗаполнитьДляОбменаСБух()

	 	//jadmin Заполняем Заказы по предоплате для выгрузки в бух
		
		Если ЭтотОбъект.ПометкаУдаления = ЛОЖЬ Тогда
			ПомУдал = 0;
		Иначе
			ПомУдал = 1;
		КонецЕсли;

		
			НаборЗаписей = РегистрыСведений.Обмен_ЗаказыПоПредоплате.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.ЗаказСсылка.Установить(ЭтотОбъект.Ссылка);
			НаборЗаписей.Прочитать();
			
			Если НаборЗаписей.Количество() > 0 Тогда
				
				ЕстьИзменения = ЛОЖЬ;
				Для каждого стр Из НаборЗаписей Цикл
					
					
					Если НачалоДня(стр.ДатаОтгрузки) <> НачалоДня(ЭтотОбъект.ДатаОтгрузки) Тогда
						стр.ДатаОтгрузки = ЭтотОбъект.ДатаОтгрузки;
						ЕстьИзменения = ИСТИНА;				
					КонецЕсли;

					Если НачалоДня(стр.ДатаЗаказа) <> НачалоДня(ЭтотОбъект.Дата) Тогда
						стр.ДатаЗаказа = ЭтотОбъект.Дата;
						ЕстьИзменения = ИСТИНА;				
					КонецЕсли;
					
					Если стр.УНП <> СокрЛП(ЭтотОбъект.Контрагент.ИНН) Тогда
						стр.УНП = СокрЛП(ЭтотОбъект.Контрагент.ИНН);
						ЕстьИзменения = ИСТИНА;
					КонецЕсли;
					
					Если стр.КодФилиалаКонтрагента <> ЭтотОбъект.Контрагент.КодФилиала Тогда
						стр.КодФилиалаКонтрагента = ЭтотОбъект.Контрагент.КодФилиала;
						ЕстьИзменения = ИСТИНА;
					КонецЕсли;
					
					Если стр.ПредоплатаСумма <> ЭтотОбъект.СуммаПредоплатыДоОтгрузки Тогда
						стр.ПредоплатаСумма = ЭтотОбъект.СуммаПредоплатыДоОтгрузки;
						ЕстьИзменения = ИСТИНА;
					КонецЕсли;
					
					Если стр.UID_DOG <> ЭтотОбъект.Договор.Ссылка.УникальныйИдентификатор() Тогда
						стр.UID_DOG = ЭтотОбъект.Договор.Ссылка.УникальныйИдентификатор();
						ЕстьИзменения = ИСТИНА;
					КонецЕсли;
					
					Если стр.ПорядокРасчетов <> ЭтотОбъект.ПорядокРасчетов Тогда
						стр.ПорядокРасчетов = ЭтотОбъект.ПорядокРасчетов;
						ЕстьИзменения = ИСТИНА;
					КонецЕсли;
							
					
					Если ЭтотОбъект.Статус <> Перечисления.СтатусыЗаказовКлиентов.КОтгрузке
						И ЭтотОбъект.Статус <> Перечисления.СтатусыЗаказовКлиентов.КОбеспечению Тогда
							ЕстьИзменения = ИСТИНА;
						 	ПомУдал = 1;
					КонецЕсли;

					
					//Проверка на изменение условий оплаты
					Если ЭтотОбъект.ПорядокРасчетов <> Перечисления.ПорядокРасчетов.ПоЗаказамНакладным
						//ИЛИ ЭтотОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению 
						Тогда
					     ЕстьИзменения = ИСТИНА;
						 ПомУдал = 1;
					КонецЕсли;
					 
					Если стр.ПометкаУдаления <> ПомУдал Тогда
						стр.ПометкаУдаления = ПомУдал;
						ЕстьИзменения = ИСТИНА;
					КонецЕсли;

					
					Если ЕстьИзменения = ИСТИНА Тогда
						стр.ПризнакОбработано = 0;
					КонецЕсли;
					
				КонецЦикла; 
				
				Если ЕстьИзменения = ИСТИНА Тогда
					НаборЗаписей.Записать(ИСТИНА);
				КонецЕсли;
				
			Иначе
				
			//Если ЭтотОбъект.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Оптовые")
			//	И ЭтотОбъект.Партнер.ВидПартнераКонтрагента <> Справочники.ВидПартнераКонтрагента.НайтиПоКоду("000000007") 
			//	Тогда
				
				//Если ЭтотОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению 
				//	ИЛИ ЭтотОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОтгрузке Тогда
					
				Если ЭтотОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОтгрузке
					ИЛИ ЭтотОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению Тогда
					
					Если ЭтотОбъект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным Тогда
						Если ЭтотОбъект.СуммаПредоплатыДоОтгрузки > 0 Тогда
							МенеджерЗаписей = РегистрыСведений.Обмен_ЗаказыПоПредоплате.СоздатьМенеджерЗаписи();
							МенеджерЗаписей.ЗаказСсылка = ЭтотОбъект.Ссылка;
							
							МенеджерЗаписей.НомерЗаказа = ""+ЭтотОбъект.Номер;
							
							МенеджерЗаписей.ДатаЗаказа = ЭтотОбъект.Дата;


							МенеджерЗаписей.ДатаОтгрузки = ЭтотОбъект.ДатаОтгрузки;
							
							
							МенеджерЗаписей.ЗаказСтрока = ""+ЭтотОбъект.Ссылка;
							
							МенеджерЗаписей.ПредоплатаСумма = ЭтотОбъект.СуммаПредоплатыДоОтгрузки;
							
							МенеджерЗаписей.UID_DOC = ЭтотОбъект.Ссылка.УникальныйИдентификатор();
							МенеджерЗаписей.UID_DOG = ЭтотОбъект.Договор.Ссылка.УникальныйИдентификатор();
							МенеджерЗаписей.УНП = ""+СокрЛП(ЭтотОбъект.Контрагент.ИНН);
							МенеджерЗаписей.КодФилиалаКонтрагента = ""+ЭтотОбъект.Контрагент.КодФилиала;
							МенеджерЗаписей.ПорядокРасчетов = ЭтотОбъект.ПорядокРасчетов;
							
							МенеджерЗаписей.ПометкаУдаления = ПомУдал;
							МенеджерЗаписей.ПризнакОбработано = 0;
							
							МенеджерЗаписей.Регистратор = ЭтотОбъект.Ссылка;
							МенеджерЗаписей.Записать(ИСТИНА);
						КонецЕсли; 				
					КонецЕсли;					
				КонецЕсли; 
				
			//КонецЕсли; 
		КонецЕсли;
	///


КонецПроцедуры





&НаСервере
Процедура ПечатьСчетНаСервере(ТабДок) Экспорт
	
	   //ОбработкаВопроса_77w();
	//Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
	//	
	//	ТекстВопроса = Нстр("ru = 'Данные еще не записаны.
	//	|Печать возможна только после записи документа.
	//	|Данные будут записаны.'");
	//	
	//	ПоказатьВопрос(Новый ОписаниеОповещения("ОткрытьФормуСегментовЗапретаОтгрузкиЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
	//	Возврат;
	//	
	//КонецЕсли;
	
	Объект = ЭтотОбъект.Ссылка;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.ОтображатьЗаголовки = Ложь;
	ТабДок.ТолькоПросмотр = Истина;	
    ТабДок.ДвусторонняяПечать = ТипДвустороннейПечати.ПереворотВлево;
	//Макет = ПолучитьМакетНаСервере("СчетМССО");
	
	Макет = ЭтотОбъект.ПолучитьМакет("СчетМССО");
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	
	Если Объект.Склад.ТипСклада = Перечисления.ТипыСкладов.РозничныйМагазин Тогда
		
		Разделитель = "-";
		СтрокаНомер = СтрРазделить(СокрЛ(Объект.Номер),Разделитель);
		НомерПеч = СтрокаНомер[2-1];
			
		Префикс = Объект.Склад.НомерМагазинаДляОтчетов;

		Пока СтрДлина(Префикс) <> 4 Цикл
			Префикс = "0" + Префикс;
		КонецЦикла; 
 
		НомерСчФактуры = ""+Префикс+"-"+НомерПеч; 

		
	Иначе 
		
		НомерСчФактуры = СокрЛ(Объект.Номер)	
	
	КонецЕсли; 
	
	ОбластьШапка.Параметры.ПРОТОКОЛ = "ПРОТОКОЛ (СЧЕТ-ФАКТУРА) № "+ НомерСчФактуры + " от "+Формат(Объект.Дата,"ДЛФ=DD") + "согласования отпускных цен.";
	

	Попытка
	ПараметрыСеанса.ВременныйАдресПочты = СокрЛП(Объект.Контрагент.КонтактнаяИнформация[3].АдресЭП);
	Исключение
	    //ОписаниеОшибки()
	КонецПопытки; 
	
	ФирмаПеч = "";
	
	ОбластьШапка.Параметры.Заполнить(Объект);
	ФирмаПеч = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , ), "ПолноеНаименование,,,,,,,");
	АдресПеч = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , ), ",,ЮридическийАдрес,,,,,");
	//ОбластьШапка.Параметры.НаименованиеФирмы = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , Объект.БанковскийСчет), "ПолноеНаименование,ИНН,ЮридическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет");
	ОбластьШапка.Параметры.Фирма = ФирмаПеч;
	ОбластьШапка.Параметры.Адрес  = АдресПеч;
	ОбластьШапка.Параметры.ИНН = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , ), ",ИНН,,,,,,");
	//ОбластьШапка.Параметры.НомерСчета = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , ), ",,,,НомерСчета,Банк,БИК,");
	
	
	
	
	Если ЗНАЧЕНИЕЗАПОЛНЕНО(Объект.БанковскийСчет.НомерСчета) Тогда
		
		ОбластьШапка.Параметры.НомерСчета = Объект.БанковскийСчет.НомерСчета;
		ОбластьШапка.Параметры.Банк = Объект.БанковскийСчет.Банк;
		ОбластьШапка.Параметры.БанкКод = Объект.БанковскийСчет.Банк.Код;	
	Иначе
		ИщемСчет = ""+"BY47BAPB30122768700100000000";
		НашлиНашСчет = Справочники.БанковскиеСчетаОрганизаций.НайтиПоРеквизиту("НомерСчета",ИщемСчет,,Объект.Организация);
		Если НашлиНашСчет <> Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка() Тогда
			Объект.БанковскийСчет = НашлиНашСчет;
			
		ОбластьШапка.Параметры.НомерСчета = Объект.БанковскийСчет.НомерСчета;
		ОбластьШапка.Параметры.Банк = Объект.БанковскийСчет.Банк;
		ОбластьШапка.Параметры.БанкКод = Объект.БанковскийСчет.Банк.Код;	
			
		КонецЕсли; 
		
		
	КонецЕсли; 	
	
	
	
	
	ОбластьШапка.Параметры.Покупатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата, , ), "ПолноеНаименование,,,,,,,");
	
	ОбластьШапка.Параметры.РасшифровкаКонтрагента = Объект.Контрагент;  /////// 77w qaws  для рассшифровки ячейки
	
	ОбластьШапка.Параметры.ПокупательАдрес = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата, , ), ",,ЮридическийАдрес,,,,,");
	Если ЗначениеЗаполнено(Объект.АдресДоставки) Тогда
	
		ОбластьШапка.Параметры.ПокупательАдрес = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата, , ), ",,ЮридическийАдрес,,,,,")+", "+ Объект.АдресДоставки;
	
	КонецЕсли;
	

	
	ОбластьШапка.Параметры.ПокупательИНН = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата, , ), ",ИНН,,,,,,");
	//ОбластьШапка.Параметры.НомерСчетаПокупатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата, , ), ",,,,НомерСчета,Банк,БИК,");
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка КАК Счет,
	|	БанковскиеСчета.НомерСчета КАК НомерСчета,
	|	БанковскиеСчета.Банк КАК Банк,
	|	БанковскиеСчета.Банк.Код КАК БанкКод
	|ИЗ
	|	Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчета
	|ГДЕ
	|	БанковскиеСчета.Владелец = &Владелец
	|	И БанковскиеСчета.Закрыт = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Владелец",Объект.Контрагент);
	Выборка = Запрос.Выполнить().Выгрузить();
	

Функция ПреверкаОбещанногоПлатежа(Заказ)

	ЕстьОбещанныйПлатеж = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбещанныйПлатежЗаказы.Заказ.Ссылка КАК ЗаказСсылка,
		|	ОбещанныйПлатежЗаказы.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ОбещанныйПлатеж.Заказы КАК ОбещанныйПлатежЗаказы
		|ГДЕ
		|	ОбещанныйПлатежЗаказы.Заказ.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() > 0 Тогда
	
		ЕстьОбещанныйПлатеж = ИСТИНА;
	
	КонецЕсли; 
	
	Возврат ЕстьОбещанныйПлатеж;

КонецФункции // ПреверкаОбещанногоПлатежа(Заказ)()
 

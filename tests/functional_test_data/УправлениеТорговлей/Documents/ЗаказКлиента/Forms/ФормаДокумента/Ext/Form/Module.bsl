				 Элементы.Готовность.ТолькоПросмотр = ЛОЖЬ;
	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
	
	Если РольДоступна("АдминистраторСистемы") Тогда

	Иначе
		
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		    Элементы.Контрагент.Доступность = Ложь;  
		    Элементы.Партнер.Доступность = Ложь; 
			Элементы.ГруппаПартнер.ТолькоПросмотр = Истина;
		КонецЕсли;
	КонецЕсли;	
	
	
	Если Объект.Партнер = Справочники.Партнеры.НайтиПоНаименованию("Магазин N12",ИСТИНА) Тогда
		Если СтрНайти(Строка(ТекущийПользователь), "Поплавская") = 1 
			ИЛИ СтрНайти(Строка(ТекущийПользователь), "Проскурнин") = 1 
			ИЛИ СтрНайти(Строка(ТекущийПользователь), "Афанасьев Алексей") = 1 
			ИЛИ РольДоступна("АдминистраторСистемы") Тогда
		
		Иначе

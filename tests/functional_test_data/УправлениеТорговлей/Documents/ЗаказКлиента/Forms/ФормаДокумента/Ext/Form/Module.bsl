&НаКлиенте
Перем КэшированныеЗначения; //используется механизмом обработки изменения реквизитов ТЧ

&НаКлиенте
Перем ТекущиеДанныеИдентификатор; //используется для передачи текущей строки в обработчик ожидания

&НаКлиенте
Перем ДатаМесяцДокументаПриОткрытии; //используется для передачи текущей строки в обработчик ожидания

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПараметрыСеанса.ВременныйАдресПочты = "";   ////// 77w qaws
	ЗаказТребуетВниманияМенеджераСтатус = Объект.ЗаказТребуетВниманияМенеджера;
	УстановитьУсловноеОформление();
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;

	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);

	// Обработчик механизма "ВерсионированиеОбъектов"
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	
	// Обработчик подсистемы "Внешние обработки"
	ДополнительныеОтчетыИОбработки.ПриСозданииНаСервере(ЭтаФорма);
	
	// Обработчик механизма "Свойства"
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Объект", Объект);
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	ДополнительныеПараметры.Вставить("ОтложеннаяИнициализация", Истина);
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, ДополнительныеПараметры);
	
	ИспользоватьПодразделения = ПолучитьФункциональнуюОпцию("ИспользоватьПодразделения");
	ИспользоватьРучныеСкидкиВПродажах         = ПолучитьФункциональнуюОпцию("ИспользоватьРучныеСкидкиВПродажах");
	ИспользоватьАвтоматическиеСкидкиВПродажах = ПолучитьФункциональнуюОпцию("ИспользоватьАвтоматическиеСкидкиВПродажах");
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	
	ИспользоватьОграниченияРучныхСкидок = ПолучитьФункциональнуюОпцию("ИспользоватьОграниченияРучныхСкидокВПродажахПоПользователям")
	                                      Или ПолучитьФункциональнуюОпцию("ИспользоватьОграниченияРучныхСкидокВПродажахПоСоглашениям");
	ИспользоватьПричиныОтменыЗаказовКлиентов = ПолучитьФункциональнуюОпцию("ИспользоватьПричиныОтменыЗаказовКлиентов");
	
	ПараметрыВыбораРеквизитов = ЭтапыОплатыСервер.ПараметрыВыбораРеквизитовОплаты(Метаданные.Документы.ЗаказКлиента);
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		ПриЧтенииСозданииНаСервере();
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
		Если ЗначениеЗаполнено(Объект.Партнер) Тогда
			ЗаполнитьУстановитьРеквизитыДоставкиСервер("Партнер");
		КонецЕсли;
		
		Объект.Готовность = Ложь;
		Объект.ЕстьЗаданиеНаПеревозку = Ложь;
		Объект.ВыписанаНакладная = Документы.РеализацияТоваровУслуг.ПустаяСсылка();
		
		Если Объект.ТоварыДоКорректировкиОрдером.Количество() > 0 Тогда
			Объект.ТоварыДоКорректировкиОрдером.Очистить();
		КонецЕсли; 
		
		
		Если Объект.ОтсутствующиеПозицииНоменклатуры.Количество() > 0 Тогда
			Объект.ОтсутствующиеПозицииНоменклатуры.Очистить();
		КонецЕсли; 
		
		Объект.ИнтернетЗаказ = Ложь;
		Объект.СформированТСД = Ложь;
		Объект.ВзятВРаботу = Ложь;
        Объект.ПунктРазгрузкиПогрузкиКлиента = "";
		Объект.АдресДоставки = "";  
		Объект.КоличествоДоверенностей = 0;
		//ТекстСуммаПросроченоНажатиеНаСервере();
		
		Объект.БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.НайтиПоРеквизиту("НомерСчета","BY98PJCB30120551901000000933");  //ПриорБанк
		
		//////77w qaws
		
		Если Параметры.ЗначениеКопирования <> Документы.ЗаказКлиента.ПустаяСсылка() Тогда
			Объект.СпособДоставки = Параметры.ЗначениеКопирования.СпособДоставки;
			
			ЗаполнитьУстановитьРеквизитыДоставкиСервер("СпособДоставки");
			
			Объект.АдресДоставки  = Параметры.ЗначениеКопирования.АдресДоставки;
			Объект.ЗонаДоставки   = Параметры.ЗначениеКопирования.ЗонаДоставки;
			
			Объект.ОтгрузкаТолькоПоПредоплате = Ложь;
			Объект.ОтгрузкаНеОсуществляется = Ложь;
			
			//ТекстСуммаПросроченоНажатиеНаСервере();
		КонецЕсли; 
		
		Объект.СерииДоступныДляРедактирования = ЛОЖЬ;    
		
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
			Если Объект.Партнер.ВидПартнераКонтрагента.Ссылка.Код = "000000007" Тогда
				Объект.СерииДоступныДляРедактирования = ИСТИНА;    
			КонецЕсли;
		
		КонецЕсли;
		
		//ОснСклад = Справочники.Склады.НайтиПоНаименованию("склад N 3 Готовой продукции");     ///////77w qaws
		//Если ОснСклад <> Справочники.Склады.ПустаяСсылка() Тогда
		//	 Объект.Склад = ОснСклад;
		//КонецЕсли; 
	КонецЕсли;
	
	
    
	//jadmin заменяем счет на приорбанк принудительно по условию
	Если НачалоДня(Объект.Дата) >= Дата("20221201000000") Тогда
		Объект.БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.НайтиПоРеквизиту("НомерСчета","BY98PJCB30120551901000000933");
	КонецЕсли;

	Если Объект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОтгрузке 
		И Объект.Проведен = ИСТИНА Тогда
		Объект.ДатаОтгрузкиПриВходе = Объект.ДатаОтгрузки;	
	Иначе
		Объект.ДатаОтгрузкиПриВходе = Дата(1,1,1);
	КонецЕсли;

    
    ///77w 
	КолВоДнейОтрочки = 0;
	СкидкаИндивидуальнаяРазмер = 0;
	ПолучитьКоличествоДнейОтсрочкиПоДоговору(КолВоДнейОтрочки,СкидкаИндивидуальнаяРазмер);
   //Объект.КоличествоДнейОтсрочкиПоДоговору = ПолучитьКоличествоДнейОтсрочкиПоДоговору();
   Объект.КоличествоДнейОтсрочкиПоДоговору = КолВоДнейОтрочки;
   Объект.СкидкаИндивидуальнаяПроцент = СкидкаИндивидуальнаяРазмер;
   

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РасходныйОрдерНаТоварыОснования.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыОснования
		|ГДЕ
		|	РасходныйОрдерНаТоварыОснования.Распоряжение = &ВыбЗаказ
		|	И РасходныйОрдерНаТоварыОснования.Ссылка.Проведен = ИСТИНА";
		
		Запрос.УстановитьПараметр("ВыбЗаказ", Объект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НашлиОрдер = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЦикла;	 
		
		
//jadmin Установка запрета редактирования табличной части если найден ордер
Если НашлиОрдер <> Неопределено 
	ИЛИ Объект.ВзятВРаботу = ИСТИНА Тогда
	//Сообщить("Установлен запрет на редактирование заявки, т.к выписан расходный ордер:"+Символы.ПС+НашлиОрдер);
	//ЭтаФорма.ТолькоПросмотр = Истина;
	//Элементы.Товары.Доступность = Ложь;
	Элементы.ТоварыЗаполнитьСерииПо_FIFO_МССО.Доступность = Ложь;
	Элементы.ТоварыОткрытьПодбор.Доступность = Ложь;
	Элементы.ТоварыГруппаЗаполнить.Доступность = Ложь;
	Элементы.Товары.ТОлькоПросмотр = ИСТИНА;            //jadmin
	Элементы.Статус.ТолькоПросмотр = ИСТИНА;
	
	Элементы.АдресДоставкиПеревозчика.ТолькоПросмотр = ИСТИНА;
	Элементы.АдресДоставкиПолучателя.ТолькоПросмотр = ИСТИНА;
	Элементы.АдресДоставкиПолучателя1.ТолькоПросмотр = ИСТИНА;
	Элементы.АдресДоставкиПолучателя2.ТолькоПросмотр = ИСТИНА;
	Элементы.АдресДоставкиСамовывоз.ТолькоПросмотр = ИСТИНА;
	//Элементы.ресДоставки.ТолькоПросмотр = ИСТИНА;
	
	
	
	Элементы.Партнер.ТолькоПросмотр = ИСТИНА;
	Элементы.Контрагент.ТолькоПросмотр = ИСТИНА;
	
	
	Если РольДоступна("АдминистраторСистемы") Тогда
		Элементы.Товары.ТОлькоПросмотр = Ложь; 
		Элементы.Статус.ТолькоПросмотр = ЛОЖЬ;
		
		Элементы.Партнер.ТолькоПросмотр = ЛОЖЬ;
		Элементы.Контрагент.ТолькоПросмотр = ЛОЖЬ;
		
		Элементы.АдресДоставкиПеревозчика.ТолькоПросмотр = ЛОЖЬ;
		Элементы.АдресДоставкиПолучателя.ТолькоПросмотр = ЛОЖЬ;
		Элементы.АдресДоставкиПолучателя1.ТолькоПросмотр = ЛОЖЬ;
		Элементы.АдресДоставкиПолучателя2.ТолькоПросмотр = ЛОЖЬ;
		Элементы.АдресДоставкиСамовывоз.ТолькоПросмотр = ЛОЖЬ;
		//Элементы.АдресДоставки.ТолькоПросмотр = ЛОЖЬ;
		Элементы.ОтсутвующиеПозиции.ТолькоПросмотр = ЛОЖЬ;
		
	КонецЕсли;	
	
	Если РольДоступна("MSSO_Директор") Тогда
		Элементы.Товары.ТОлькоПросмотр = Ложь;  
		Элементы.Статус.ТолькоПросмотр = ИСТИНА;
	КонецЕсли;
	
	Если ПроверитьВыписанаНакладная(Объект.Ссылка) = Ложь Тогда
		ЕстьВозможностьИзмененияЗаказаДляОрдера = ВозможностьИзмененияЗаказаДляОрдера();
		
		Если ЕстьВозможностьИзмененияЗаказаДляОрдера = Истина Тогда
			Элементы.Товары.ТОлькоПросмотр = Ложь;  
		КонецЕсли; 
		
	КонецЕсли;
Иначе
	Объект.ВзятВРаботу = ЛОЖЬ;
	
КонецЕсли; 
		
		
		
		
		
		
		
		///Проверка выписана ли накладная
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
			Если ПроверитьВыписанаНакладная(Объект.Ссылка) = ИСТИНА Тогда
				Если РольДоступна("АдминистраторСистемы") Тогда
					
				Иначе					
				    ЭтаФорма.ТолькоПросмотр = ИСТИНА;
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;
		
		
		
  
		
		
		//jadmin Заполнение ЗнП из регистра
	    НомерЗнП = ПолучитьНомерЗнП(Объект.Ссылка);
		Если НомерЗнП <> Объект.ЕстьЗаданиеНаПеревозку Тогда
		    Объект.ЕстьЗаданиеНаПеревозку = НомерЗнП;
		КонецЕсли; 
		///	
		//jadmin Заполнение ЗнП из регистра
	    ВыписанаНакладнаяИзРегистра = ПолучитьНакладнуюИзРегистра(Объект.Ссылка);
		Если ВыписанаНакладнаяИзРегистра <> Объект.ВыписанаНакладная Тогда
		    Объект.ВыписанаНакладная = ВыписанаНакладнаяИзРегистра;
		КонецЕсли; 

		
		
        Если (Объект.КоличествоДнейОтсрочки = 0) И (Объект.КоличествоДнейОтсрочкиПоДоговору > 0) Тогда
        	Объект.КоличествоДнейОтсрочки = Объект.КоличествоДнейОтсрочкиПоДоговору;
        КонецЕсли; 
		
		
		////jadmin скидка для скл1
		//Если Объект.Склад = Справочники.Склады.НайтиПоНаименованию("склад N 1 Центральный",ИСТИНА)   Тогда
		//	Объект.СкидкаЗаПредоплату = ИСТИНА; 
		//	Объект.СкидкаЗаПредоплатуПроцент = 0;
		//	Объект.СкидкаОборот = ЛОЖЬ; 
		//	Объект.СкидкаОборотПроцент = 0;
		//	Объект.СкидкаСезонная = ЛОЖЬ; 
		//	Объект.СкидкаСезоннаяПроцент = 0;
		//	
		//	СкидкаСезоннаяРазмер = 0;
		//	СкидкаЗаПредоплатуРазмер = 0;
		//	СкидкаОборотРазмер = 0;
		//КонецЕсли; 

		
    Иначе    
        Объект.КоличествоДнейОтсрочки = Объект.КоличествоДнейОтсрочкиПоДоговору;
        
	КонецЕсли;
	
	
	Если ТекущийВариантИнтерфейсаКлиентскогоПриложения() = ВариантИнтерфейсаКлиентскогоПриложения.Версия8_2 Тогда
		Элементы.ГруппаИтого.ЦветФона = Новый Цвет();
	КонецЕсли;
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДокументОснование", "Видимость", ЗначениеЗаполнено(Объект.ДокументОснование));
	ПродажиСервер.УстановитьОтметкуНезаполненногоДоговора(Элементы, "Договор");
	ПродажиСервер.УстановитьРежимВыбораГруппЭлементовСклада(Элементы.Склад);
	ПравоНаЧтениеВидаЦены = ПравоДоступа("Просмотр", Метаданные.Документы.ЗаказКлиента.ТабличныеЧасти.Товары.Реквизиты.ВидЦены);
	
	НаправлениеДеятельностиОбязательно = НаправленияДеятельностиСервер.УказаниеНаправленияДеятельностиОбязательно(Объект.ХозяйственнаяОперация);
	
	СкидкиНаценкиСервер.НастроитьКомандуПоказатьСообщения(Объект, Элементы.ПоказатьСообщения);
	
	Элементы.ДекорацияДатаОтгрузки.Видимость = НЕ ПолучитьФункциональнуюОпцию("ИспользоватьПострочнуюОтгрузкуВЗаказеКлиента") И Объект.НеОтгружатьЧастями;
	
	Элементы.ТоварыГруппаОтмена.Видимость                        = ПолучитьФункциональнуюОпцию("ИспользоватьПричиныОтменыЗаказовКлиентов");
	Элементы.ТоварыОтмененоПричиныОтменыНеИспользуются.Видимость = Не ПолучитьФункциональнуюОпцию("ИспользоватьПричиныОтменыЗаказовКлиентов");
	
	Перечисления.СтатусыЗаказовКлиентов.ЗаполнитьСписокВыбора(Элементы.Статус.СписокВыбора, Объект.Статус);
	
	Элементы.ЗакрытьЗаказ.Доступность = ПравоДоступа("Изменение",Метаданные.Документы.ЗаказКлиента);
	
	
	УстановитьДоступностьКомандБуфераОбмена();
	
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС);
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо);
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС1);
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо1);
	            	
	// СтандартныеПодсистемы.Печать
	УправлениеПечатью.ПриСозданииНаСервере(ЭтаФорма, Элементы.ПодменюПечать);
	// Конец СтандартныеПодсистемы.Печать

	ВводНаОсновании.ПриСозданииНаСервере(ЭтаФорма, Элементы.ПодменюСоздатьНаОсновании);
	
	МенюОтчеты.ПриСозданииНаСервере(ЭтаФорма, Элементы.ПодменюОтчеты);
	
	// ИнтеграцияС1СДокументооборотом
	ИнтеграцияС1СДокументооборот.ПриСозданииНаСервере(ЭтаФорма);
	// Конец ИнтеграцияС1СДокументооборотом

	// Подсистема "ОбменСКонтрагентами".
	ПараметрыЭДОПриСоздании= ОбменСКонтрагентами.ПараметрыПриСозданииНаСервере_ФормаДокумента();
	ПараметрыЭДОПриСоздании.Форма = ЭтотОбъект;
	ПараметрыЭДОПриСоздании.ДокументССылка = Объект.Ссылка;
	ПараметрыЭДОПриСоздании.ДекорацияСостояниеЭДО = Элементы.ДекорацияСостояниеЭДО;
	ПараметрыЭДОПриСоздании.ГруппаСостояниеЭДО = Элементы.ГруппаСостояниеЭДО;
	
	ОбменСКонтрагентами.ПриСозданииНаСервере_ФормаДокумента(Отказ, СтандартнаяОбработка, ПараметрыЭДОПриСоздании);
	// Конец подсистема "ОбменСКонтрагентами".
	

		КонецЕсли;
		
		
		
		Лук_СМеханическимиПовреждениями = Партия_МССО_Ссылка.Лук_СМеханическимиПовреждениями; 

		Если Лук_СМеханическимиПовреждениями > 0 Тогда
			Дополнительно_Лук = Дополнительно_Лук + ", с механическими повреждениями , проросших, оголенных (при осеннем исп-и) "+Лук_СМеханическимиПовреждениями+"%"; 	
		КонецЕсли;
		
		
		Лук_Примеси = Партия_МССО_Ссылка.Лук_Примеси; 


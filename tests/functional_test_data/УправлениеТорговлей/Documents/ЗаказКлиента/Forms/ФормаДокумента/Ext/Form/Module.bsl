				КонецЕсли;
				
				Масса1000семянЕсть = СтрокаАнализы.Масса1000семян;
				Если ЗначениеЗаполнено(Масса1000семянЕсть) Тогда
					Масса1000семян = ", масса 1000 семян "+Масса1000семянЕсть+"г";
				Иначе
					Масса1000семян = "";
				КонецЕсли;
				
				
				Болезни_Вредители_КарантинныеОбъекты = "";
				
				Болезни = ", зараженность болезнями " + СтрокаАнализы.БолезниПроцент+ "%";
				Вредители = ", зараженность вредителями " + СтрокаАнализы.БолезниПроцент+ "%";
				КарантинныеОбъекты = ", карантинные объекты " + СтрокаАнализы.КарантинныеОбъекты+ " 0 шт/кг";
				
				Болезни_Вредители_КарантинныеОбъекты = ""+Болезни+Символы.ПС+Вредители+Символы.ПС+КарантинныеОбъекты;
				
				Область_Секция_8.Параметры.Болезни_Вредители = Болезни_Вредители_КарантинныеОбъекты;
				
				//Если ЗначениеЗаполнено(СтрокаАнализы.Примечание) = Истина Тогда
					Область_Секция_8.Параметры.Прочее = ""+Символы.ПС+СтрокаАнализы.Примечание;
				//КонецЕсли; 
				
				УдостоверениеОКондиционностиЕсть = СтрокаАнализы.УдостоверениеОКондиционности;
				Если ЗначениеЗаполнено(УдостоверениеОКондиционностиЕсть) Тогда
					УдостоверениеОКондиционности = "Удостоверение о качестве семян № "+УдостоверениеОКондиционностиЕсть;
				Иначе

&НаСервере
Процедура ЗаказТребуетВниманияМенеджераПриИзмененииНаСервере(Заказ)
	Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |	РасходныйОрдерНаТоварыОснования.Ссылка
        |ИЗ
        |	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыОснования
        |ГДЕ
        |	РасходныйОрдерНаТоварыОснования.Распоряжение = &ВыбЗаказ";
 
    Запрос.УстановитьПараметр("ВыбЗаказ", Заказ);
 
    РезультатЗапроса = Запрос.Выполнить();
 
    ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
 
    Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
        НашлиОрдер = ВыборкаДетальныеЗаписи.Ссылка;
		
		НашлиОрдерОбъект = НашлиОрдер.ПолучитьОбъект();
		
		НашлиОрдерОбъект.ЗаказТребуетВниманияМенеджера = Ложь;
		НашлиОрдерОбъект.Записать();
		
        Сообщить(НашлиОрдер);
	КонецЦикла;
	
КонецПроцедуры


			СтрокаОП.КоличествоПервоначальное = СтрокаТЗ.КоличествоУпаковок;
			
			СтрокаОП.КоличествоВНаличии = СтрокаТЗ.КоличествоУпаковок - КоличествоОсталосьСписать;
			
			Если СтрокаТЗ.КоличествоУпаковок - КоличествоОсталосьСписать = 0 Тогда
				СтрокаОП.Причина = "Отсутствует на складе";
			Иначе
				СтрокаОП.Причина = "Недостаточно на складе";
			КонецЕсли; 
			
		КонецЕсли; 
		
		
	КонецЦикла;
	
	НоменклатураСервер.УстановитьУсловноеОформлениеСерийНоменклатуры(ЭтаФорма, "СерииВсегдаВТЧТовары");
	УстановитьУсловноеОформление();
КонецПроцедуры
 



&НаСервере
Функция ПолучитьРегулировануюЦену(Номенклатура,Серия,ВидЦены,ЦенаСтроки)   //рег цены
	
		ЕстьРегулированиеЦен_Строка = Ложь;
		
		Если ОбщийМодуль77w.ПроверитьРегулированиеЦенГосударством_Оптовых(Номенклатура,Объект.Дата) = Истина Тогда
			ЕстьРегулированиеЦен_Строка = Истина;
		КонецЕсли; 
		
		
		
		Если ЕстьРегулированиеЦен_Строка = Истина Тогда
			
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Период КАК Период,
			|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Регистратор КАК Регистратор,
			|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Номенклатура КАК Номенклатура,
			|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Серия КАК Серия,
			|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Цена КАК Цена
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатурыПоСериям_МССО.СрезПоследних(&Период, ) КАК ЦеныНоменклатурыПоСериям_МССОСрезПоследних
			|ГДЕ
			|	ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Номенклатура = &Номенклатура
			|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Серия = &Серия
			|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.Цена <> 0
			|	И ЦеныНоменклатурыПоСериям_МССОСрезПоследних.ВидЦены = &ВидЦены";
			
			Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
			Запрос.УстановитьПараметр("Серия", Серия);
			Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
			Запрос.УстановитьПараметр("Период", Объект.Дата);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Цена = 0;
			
			Если РезультатЗапроса.Пустой() Тогда
				Цена = 0;
			КонецЕсли; 
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Цена = ВыборкаДетальныеЗаписи.Цена;
			КонецЦикла;
			
			Возврат Цена;
		Иначе
			Возврат ЦенаСтроки;
		КонецЕсли; 
			
КонецФункции
 



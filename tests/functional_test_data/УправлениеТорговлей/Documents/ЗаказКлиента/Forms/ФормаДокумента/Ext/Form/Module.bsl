Функция ПроверитьНаличиеПрисоединенныхФайлов()
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |   ЗаказКлиентаПрисоединенныеФайлы.Ссылка КАК Ссылка
    |ИЗ
    |   Справочник.ЗаказКлиентаПрисоединенныеФайлы КАК ЗаказКлиентаПрисоединенныеФайлы
    |ГДЕ
    |   ЗаказКлиентаПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла";
    
    Запрос.УстановитьПараметр("ВладелецФайла", Объект.Ссылка);
    
    РезультатЗапроса = Запрос.Выполнить();
    
    
    Если РезультатЗапроса.Пустой() Тогда
        Возврат Ложь;
    Иначе
        Возврат Истина;
    КонецЕсли; 
КонецФункции
 

&НаСервере
Процедура ДоговорПриИзмененииСервер()
	
	ПродажиСервер.ЗаполнитьБанковскиеСчетаПоДоговору(Объект.Договор, Объект.БанковскийСчет, Объект.БанковскийСчетКонтрагента);
	
	ВзаиморасчетыСервер.ЗаполнитьПорядокРасчетовВФорме(ЭтаФорма, Ложь);	
	
	ЗаполнитьГруппуФинУчета();
	
	ОбновитьОграничениеЗадолженности();
	
	Если ИспользоватьНаправленияДеятельности Тогда
		НаправленияДеятельностиСервер.ЗаполнитьНаправлениеПоУмолчанию(Объект.НаправлениеДеятельности, Объект.Соглашение, Объект.Договор);
	КонецЕсли;
	НаправленияДеятельностиСервер.ПриИзмененииНаправленияДеятельностиСервер(ЭтаФорма);
	
	ЗаполнитьПодчиненныеСвойстваПоСтатистике("Договор");
	
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		Объект.ПорядокОплаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор,"ПорядокОплаты");
	КонецЕсли;
    
    
	//Объект.КоличествоДнейОтсрочкиПоДоговору = ПолучитьКоличествоДнейОтсрочкиПоДоговору(); 
	
	КолВоДнейОтсрочки = 0;
	СкидкаИндивидуальнаяРазмер = 0;
	ПолучитьКоличествоДнейОтсрочкиПоДоговору(КолВоДнейОтсрочки,СкидкаИндивидуальнаяРазмер);
	
	//Объект.КоличествоДнейОтсрочкиПоДоговору = ПолучитьКоличествоДнейОтсрочкиПоДоговору();
	
	Объект.КоличествоДнейОтсрочкиПоДоговору = КолВоДнейОтсрочки;
	
    Объект.КоличествоДнейОтсрочки  = Объект.КоличествоДнейОтсрочкиПоДоговору;

	Если СкидкаИндивидуальнаяРазмер > 0
		ИЛИ Объект.Договор.СкидкаИндивидуальная = ИСТИНА Тогда
		
		Объект.СкидкаИндивидуальная = Истина;
		Элементы.ГруппаИндивидуальная.ТолькоПросмотр = ЛОЖЬ;
		Элементы.СкидкаИндивидуальная.ТолькоПросмотр = ИСТИНА;
		
		Объект.СкидкаИндивидуальнаяПроцент = СкидкаИндивидуальнаяРазмер;

		Объект.СкидкаСезонная = ЛОЖЬ; 
		Объект.СкидкаСезоннаяПроцент = 0;

		Объект.СкидкаОборот = ЛОЖЬ;
	Иначе
		Объект.СкидкаИндивидуальная = ЛОЖЬ;
		Объект.СкидкаИндивидуальнаяПроцент = 0;
	КонецЕсли;

	
    
КонецПроцедуры





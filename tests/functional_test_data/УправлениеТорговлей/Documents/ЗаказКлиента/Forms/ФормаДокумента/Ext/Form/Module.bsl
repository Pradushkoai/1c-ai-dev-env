                |ГДЕ
                |	ЦеныНоменклатурыСрезПоследних.ВидЦены = &ВидЦены
                |	И ЦеныНоменклатурыСрезПоследних.Номенклатура = &Номенклатура";
                
                
                
                Запрос.УстановитьПараметр("ВидЦены", Справочники.ВидыЦен.НайтиПоНаименованию("Оптовые",Истина));
                Запрос.УстановитьПараметр("НаДату", Объект.Дата);

&НаКлиенте
Процедура ПечатьОП(ИдентификаторКоманды, ТабДок) Экспорт
	//ТабДок = ПолучитьТабличныйДокументПриказаТ5(МассивОбъектов);
	//ТабДок = ПолучитьТабличныйДокументПриказаТ5(МассивОбъектов);
    //Типовая часть вывода в стандартное окно++
    ИдентификаторПечатнойФормы = "СвидетельствоНаСеменаПечатьОтсутствующихПозиций";
    НазваниеПечатнойФормы = НСтр("ru = 'Печать отсутствующих позиций'");
    
    Если Не ОбщегоНазначенияКлиент.ПодсистемаСуществует("СтандартныеПодсистемы.Печать") Тогда
        ТабДок.Показать(НазваниеПечатнойФормы);
        ДокументыПечатались = Истина;
        Возврат;
    КонецЕсли;     
    МодульУправлениеПечатьюКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеПечатьюКлиент");     
    КоллекцияПечатныхФорм = МодульУправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(ИдентификаторПечатнойФормы);
    ПечатнаяФорма = МодульУправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, ИдентификаторПечатнойФормы);
    ПечатнаяФорма.СинонимМакета = НазваниеПечатнойФормы;
    ПечатнаяФорма.ТабличныйДокумент = ТабДок;
    ПечатнаяФорма.ИмяФайлаПечатнойФормы = НазваниеПечатнойФормы;
    
    ОбластиОбъектов = Новый СписокЗначений;
    МодульУправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм, ОбластиОбъектов);

    ДокументыПечатались = Истина;
КонецПроцедуры

&НаСервере
Процедура ПечатьОтсутствующихПозицийНаСервере(ТабДок)
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.ОтображатьЗаголовки = Ложь;
	ТабДок.ТолькоПросмотр = Истина;	
	Макет = ПолучитьМакетНаСервере("ПечатьОтсутствующихПозиций");
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	
	ЗаголовокОП = "";
	
	ЗаголовокОП = "Отсутствующие позиции номенклатуры"+Символы.ПС+""+ЭтотОбъект.Объект.Ссылка+Символы.ПС+"("+ЭтотОбъект.Объект.Контрагент+")"; 
	
	ОбластьШапка.Параметры.ЗаголовокОП = ЗаголовокОП;
	ТабДок.Вывести(ОбластьШапка);
	Номер = 0;
	Для каждого Строка Из Объект.ОтсутствующиеПозицииНоменклатуры Цикл
		Номер = Номер +1;
		ОбластьСтрока  = Макет.ПолучитьОбласть("Строка");
		Номенклатура = Строка.Номенклатура;
		
		
		ОбластьСтрока.Параметры.Номер = Номер;
		ОбластьСтрока.Параметры.Номенклатура = Номенклатура;
		
		Количество = Строка.КоличествоПервоначальное - Строка.КоличествоВНаличии;
		ОбластьСтрока.Параметры.Количество = Количество;
		ОбластьСтрока.Параметры.Причина = Строка.Причина;
		ТабДок.Вывести(ОбластьСтрока);
	КонецЦикла; 
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПечатьОтсутствующихПозиций(Команда)
	ТабДок = Новый ТабличныйДокумент;
	ПечатьОтсутствующихПозицийНаСервере(ТабДок);
	
	ПечатьОП(,ТабДок);	 ///////// для отображения стандартного диалога печати (КНОПКА ПЕЧАТЬ)
КонецПроцедуры


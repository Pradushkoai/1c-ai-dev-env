			ИначеЕсли ПолучитьТипСклада(Объект.Склад) = ПредопределенноеЗначение("Перечисление.ТипыСкладов.ОптовыйСклад") Тогда    //jadmin РегЦены
				
				ТекущаяСтрока.Цена = ПолучитьРегулировануюЦену(ТекущаяСтрока.Номенклатура,ТекущаяСтрока.Серия,ТекущаяСтрока.ВидЦены,ТекущаяСтрока.Цена); //jadmin		

		КонецЕсли;
	КонецЕсли;
	
	РазукраситьТоварыНаСервере();
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма); 
	

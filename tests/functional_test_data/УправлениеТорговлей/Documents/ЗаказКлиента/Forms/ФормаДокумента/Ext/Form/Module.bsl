		КонецЕсли;          
		
		Область_Секция_8.Параметры.Дополнительно_Картофель = Дополнительно_Картофель; 
		
		//////// картофель \\\\\\\\\
		
		
		
		
		
		///// Удостоверение о качестве семян № [ТаблицаВ.ДК], выданное [ТаблицаВ.ДЛ], срок действия до [ТаблицаВ.СД]
		 
		    
		Область_Секция_8.Параметры.Всхожесть = Всхожесть;

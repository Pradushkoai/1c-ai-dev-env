                Запрос.УстановитьПараметр("ВидЦены",ВидЦенДоставки);
                Запрос.УстановитьПараметр("НаДату", Объект.Дата);
                Запрос.УстановитьПараметр("Номенклатура", Строка.Номенклатура);
                
                РезультатЗапроса = Запрос.Выполнить();
                
                ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
                
                Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
                    ЦенаДоставки = ВыборкаДетальныеЗаписи.Цена;
                КонецЦикла;
                
                Если ЦенаДоставки > 0 Тогда
                    Строка.ВидЦены = ВидЦенДоставки;
                    Строка.Цена = ЦенаДоставки;
                    Строка.ЦенаСоСкидкой = ЦенаДоставки;
                КонецЕсли; 
                
            КонецЦикла;
            
        Иначе
            Для каждого Строка Из Объект.Товары Цикл
				
				Если ОбщийМодуль77w.ПроверитьРегулированиеЦенГосударством_Оптовых(Строка.Номенклатура,Объект.Дата) = Истина Тогда
                	 Продолжить;
				КонецЕсли; 
				
				
                Если Строка.Номенклатура.ПлатнаяДоставка = Ложь Тогда
                	 Продолжить;
                КонецЕсли; 
                
                ЦенаДоставки = 0;
                
                Запрос = Новый Запрос;
                Запрос.Текст = 
                "ВЫБРАТЬ
                |	ЦеныНоменклатурыСрезПоследних.Период,
                |	ЦеныНоменклатурыСрезПоследних.Номенклатура,
                |	ЦеныНоменклатурыСрезПоследних.ВидЦены,
                |	ЦеныНоменклатурыСрезПоследних.Валюта,
                |	ЦеныНоменклатурыСрезПоследних.Цена

&НаСервере
Процедура СкидкаЗаПредоплатуПриИзмененииНаСервере()
	// ПРИМЕНИТЬ СКИДКУ ЗА ПРЕДПОЛАТУ  И ИЗМЕНИТЬ УСЛОВИЯ ОПЛАТЫ
	
	//СкидкаЗаПредоплату = 0;
	
	Если Объект.СкидкаЗаПредоплату = ИСТИНА Тогда
			
		СкидкаЗаПредоплату = 5;
		Объект.СкидкаЗаПредоплатуПроцент = СкидкаЗаПредоплату;
		//
		//Объект.СкидкаОбщая = Объект.СкидкаОбщая + СкидкаЗаПредоплату;
		
		//Заполнение этапов оплаты
		Объект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным;
		
		Объект.ЭтапыГрафикаОплаты.Очистить();
		стрЭтапПредоплата = Объект.ЭтапыГрафикаОплаты.Добавить();
		стрЭтапПредоплата.ВариантОплаты = Перечисления.ВариантыОплатыКлиентом.ПредоплатаДоОтгрузки;
		стрЭтапПредоплата.ДатаПлатежа = Объект.Дата + 86400*3;
		//стрЭтапПредоплата.СуммаПлатежа = СуммаПредоплаты;
		стрЭтапПредоплата.ПроцентПлатежа = 100;
		стрЭтапПредоплата.СуммаПлатежа = Объект.СуммаДокумента;
		
		
		
	Иначе		                     
		СкидкаЗаПредоплату = 0;
		Объект.СкидкаЗаПредоплатуПроцент = СкидкаЗаПредоплату;

		
		Объект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным;	
		Объект.ЭтапыГрафикаОплаты.Очистить();
			
	КонецЕсли; 	

  НадписьЭтапыОплаты = ЭтапыОплатыКлиентСервер.НадписьЭтапыОплаты(ЭтаФорма, Истина);
	

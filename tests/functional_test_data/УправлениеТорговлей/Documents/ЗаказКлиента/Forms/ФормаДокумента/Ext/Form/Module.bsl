Процедура ЗаполнитьЗонуДоставкиНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПунктыРазгрузкиПогрузкиКлиентов.Наименование КАК Наименование,
		|	ПунктыРазгрузкиПогрузкиКлиентов.ЗонаДоставки КАК ЗонаДоставки,
		|	ПунктыРазгрузкиПогрузкиКлиентов.Владелец КАК Владелец,
		|	ПунктыРазгрузкиПогрузкиКлиентов.Ссылка КАК Ссылка,
		|	ПунктыРазгрузкиПогрузкиКлиентов.ОсновноеКонтактноеЛицо КАК ОсновноеКонтактноеЛицо
		|ИЗ
		|	Справочник.ПунктыРазгрузкиПогрузкиКлиентов КАК ПунктыРазгрузкиПогрузкиКлиентов
		|ГДЕ
		|	ПунктыРазгрузкиПогрузкиКлиентов.Ссылка = &Ссылка
		|	И ПунктыРазгрузкиПогрузкиКлиентов.Владелец = &Владелец
		|	И ПунктыРазгрузкиПогрузкиКлиентов.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Владелец", Объект.Партнер);
	Запрос.УстановитьПараметр("Ссылка", Объект.АдресДоставки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Объект.ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
	Объект.ОсновноеКонтактноеЛицо = Справочники.КонтактныеЛица.ПустаяСсылка();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		 Объект.ЗонаДоставки = ВыборкаДетальныеЗаписи.ЗонаДоставки;
		 Объект.ОсновноеКонтактноеЛицо = ВыборкаДетальныеЗаписи.ОсновноеКонтактноеЛицо;
	КонецЦикла;

КонецПроцедуры


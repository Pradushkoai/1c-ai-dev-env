	Макет = ПолучитьМакетНаСервере("ЗаданиеНаОтборРазмещениеТовара");
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ТекстЗаголовка = "";
	//ТекстЗаголовка = "Задание на отбор "+" "+Объект.Ссылка.Склад;
	ТекстЗаголовка = "Задание на отбор";
	
	ПредставлениеРаспоряжения = "";
	ПредставлениеРаспоряжения = ""+Объект.Ссылка+"    ("+Объект.Ссылка.Контрагент+")";
	
	ПредставлениеСклада = "";
	ПредставлениеСклада = Объект.Ссылка.Склад;
	
	
	ОбластьШапка.Параметры.ТекстЗаголовка =  ТекстЗаголовка;
	ОбластьШапка.Параметры.ПредставлениеРаспоряжения =  ПредставлениеРаспоряжения;
	ОбластьШапка.Параметры.ПредставлениеСклада =  ПредставлениеСклада;
	
	ТабДок.Вывести(ОбластьШапка);
	
	ОбластьШапкаТаблицы  = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ТабДок.Вывести(ОбластьШапкаТаблицы);
	
	
	ТЗ_Товары = Новый ТаблицаЗначений;
	ТЗ_Товары = Объект.Товары.Выгрузить();
	ТЗ_Товары.Свернуть("Номенклатура,Серия","КоличествоУпаковок");
	
	
	
	НомерСтроки = 0;
	//Для каждого Строка Из Объект.Товары Цикл
	  Для каждого Строка Из ТЗ_Товары Цикл
		
		НомерСтроки = НомерСтроки+1;	

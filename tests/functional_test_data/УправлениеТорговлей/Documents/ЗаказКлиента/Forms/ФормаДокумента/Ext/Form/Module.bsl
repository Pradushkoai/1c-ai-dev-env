Функция ПолучитьКоличествоВНаборе(Номенклатура) 
	КолВоВНаборе = 1;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УпаковкиЕдиницыИзмерения.Владелец КАК Владелец,
		|	УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	УпаковкиЕдиницыИзмерения.Числитель КАК Числитель
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
		|ГДЕ
		|	УпаковкиЕдиницыИзмерения.Владелец = &Владелец
		|	И УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения = &ЕдиницаИзмерения
		|	И УпаковкиЕдиницыИзмерения.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	Запрос.УстановитьПараметр("ЕдиницаИзмерения", Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("Н-р для опта",ИСТИНА));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КолВоВНаборе = ВыборкаДетальныеЗаписи.Числитель;
	КонецЦикла;   
	
	Если РезультатЗапроса.Пустой() Тогда
	
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	УпаковкиЕдиницыИзмерения.Владелец КАК Владелец,
			|	УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	УпаковкиЕдиницыИзмерения.Числитель КАК Числитель
			|ИЗ
			|	Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
			|ГДЕ
			|	УпаковкиЕдиницыИзмерения.Владелец = &Владелец
			|	И УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения = &ЕдиницаИзмерения
			|	И УпаковкиЕдиницыИзмерения.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("Владелец", Номенклатура);
		Запрос.УстановитьПараметр("ЕдиницаИзмерения", Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("упак",ИСТИНА));
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			КолВоВНаборе = ВыборкаДетальныеЗаписи.Числитель;
		КонецЦикла; 
   		
	КонецЕсли;

	
	Возврат КолВоВНаборе;
КонецФункции


&НаКлиенте
Процедура ТоварыПриИзменении(Элемент)     ///////77w qaws
	// SWI jadmin
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Попытка
		ТекущаяСтрока.КратностьУпаковки = ПолучитьКоличествоВНаборе(ТекущаяСтрока.Номенклатура);
	Исключение
	    //ОписаниеОшибки()
	КонецПопытки;  
	
	Если ТекущаяСтрока <> Неопределено Тогда
		Если СВ_РасчетныйНДС Тогда
			НДС = 0;
			СуммаСкидкиОбщаяСНДС = 0;
			ЦенаСоСкидкойСНДС = 0;
			НДССоСкидкой = 0;
			Цена = ОбщийМодуль77w.ПолучитьЦенуНаСервере_Розница(ТекущаяСтрока.Номенклатура,ТекущаяСтрока.Серия,Объект.Дата);
			Попытка
				
				ЦенаСоСкидкойСНДС =  Окр(Цена * (1-ТекущаяСтрока.ПроцентАвтоматическойСкидки/100) * (1-ТекущаяСтрока.ПроцентРучнойСкидки/100),2);
				
				Если ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС20") Тогда
					НДС = Окр(Цена /6 , 2, РежимОкругления.Окр15как20);
				ИначеЕсли ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС10") Тогда
					НДС = Окр(Цена /11 , 2, РежимОкругления.Окр15как20);	
				Иначе
					НДС = 0;
				КонецЕсли;
				
				Если ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС20") Тогда
					НДССоСкидкой = Окр(ЦенаСоСкидкойСНДС /6 , 2, РежимОкругления.Окр15как20);
				ИначеЕсли ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС10") Тогда
					НДССоСкидкой = Окр(ЦенаСоСкидкойСНДС /11 , 2, РежимОкругления.Окр15как20);	
				Иначе
					НДССоСкидкой = 0;
				КонецЕсли;

				
					ТекущаяСтрока.Цена = Окр((Цена - НДС),2);
					////ТекущаяСтрока.ЦенаСоСкидкой = ТекущаяСтрока.Цена;
					//ТекущаяСтрока.ЦенаСоСкидкой = Окр(ТекущаяСтрока.Цена * (1-ТекущаяСтрока.ПроцентАвтоматическойСкидки/100) * (1-ТекущаяСтрока.ПроцентРучнойСкидки/100),2);
					ТекущаяСтрока.ЦенаСоСкидкой = Окр((ЦенаСоСкидкойСНДС - НДССоСкидкой),2);
					
					ТекущаяСтрока.ПроцентРучнойСкидки = 0;
					ТекущаяСтрока.СуммаРучнойСкидки = 0;
					ТекущаяСтрока.ПроцентАвтоматическойСкидки = 0;
					ТекущаяСтрока.СуммаАвтоматическойСкидки = 0;
					
					ТекущаяСтрока.СуммаНДС = Окр(НДССоСкидкой * ТекущаяСтрока.КоличествоУпаковок,2);
					
					ТекущаяСтрока.Сумма = ТекущаяСтрока.ЦенаСоСкидкой * ТекущаяСтрока.КоличествоУпаковок;	


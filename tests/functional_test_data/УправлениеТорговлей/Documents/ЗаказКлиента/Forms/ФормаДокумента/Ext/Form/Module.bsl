&НаСервере
Процедура ПолучитьРазмерСкидкиНаСервере(ВыбКонтрагент)
    
	СкидкаСезоннаяРазмер = 0;
	СкидкаЗаПредоплатуРазмер = 0;
	СкидкаОборотРазмер = 0;

	СкидкаОбщая = 0;
	СуммаОборотаМССО = 0;
	ОбщийМодуль77w.РасчитатьСкидкуКлиента(ВыбКонтрагент,Объект.Ссылка,СуммаОборотаМССО,СкидкаОборотРазмер,СкидкаОбщая);
	
	
	
		Если СкидкаОборотРазмер>0 И Объект.СкидкаИндивидуальная = ЛОЖЬ Тогда
			Объект.СкидкаОборот = ИСТИНА;
			Объект.СкидкаОборотПроцент = СкидкаОборотРазмер;
		Иначе
			Объект.СкидкаОборот = ЛОЖЬ;
			Объект.СкидкаОборотПроцент = 0;
		КонецЕсли;
		
		
		//Предоплата
		Если Объект.Партнер.ВидПартнераКонтрагента.Наименование = "РУПС" 
			ИЛИ Объект.Партнер.ВидПартнераКонтрагента.Наименование = "Розница"
		//	ИЛИ Объект.Склад = Справочники.Склады.НайтиПоНаименованию("склад N 1 Центральный",ИСТИНА)  
			//ИЛИ Объект.Партнер.ИндивидуальныеСкидки = ИСТИНА 
			Тогда
			Объект.СкидкаЗаПредоплату = ЛОЖЬ; 
			Объект.СкидкаЗаПредоплатуПроцент = 0;


		Иначе
			
			СкидкаЗаПредоплатуРазмер = 0;
			Если Объект.СкидкаЗаПредоплату = ИСТИНА Тогда
				СкидкаЗаПредоплатуРазмер = 5;
				Объект.СкидкаЗаПредоплатуПроцент = СкидкаЗаПредоплатуРазмер;
			Иначе
				Объект.СкидкаЗаПредоплатуПроцент = 0;
			КонецЕсли; 
		КонецЕсли;
		/////
		
		//Скидка Сезонная				
		Если НачалоДня(Объект.Дата) >= Дата("20221024") И ТекущаяДата()<Дата("20230101") Тогда
			
			СкидкаСезоннаяРазмер = 7;
			Объект.СкидкаСезонная = ИСТИНА;
			Объект.СкидкаСезоннаяПроцент = СкидкаСезоннаяРазмер;
			
			
		Иначе
			Объект.СкидкаСезонная = ЛОЖЬ;
			Объект.СкидкаСезоннаяПроцент = 0;
			
		КонецЕсли; 
		///

	
	
	Объект.СкидкаОбщая = СкидкаОбщая;
	Сообщить(" Оборот на текущий момент =  "+СуммаОборотаМССО+" руб. Скидка по обороту = "+СкидкаОборотРазмер+"%.  Сумма общей скидки = "+СкидкаОбщая+"%");	
	
КонецПроцедуры


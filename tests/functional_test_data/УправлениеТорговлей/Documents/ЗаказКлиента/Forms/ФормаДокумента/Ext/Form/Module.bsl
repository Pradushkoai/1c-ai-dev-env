		КонецЕсли;
		
		Если Партия_МССО_Ссылка.МокройГнилью > 0 Тогда
			Дополнительно_Картофель = Дополнительно_Картофель+Символы.ПС+"мокрой гнилью - "+Партия_МССО_Ссылка.МокройГнилью+"%";
		КонецЕсли;
		
		Если Партия_МССО_Ссылка.ЧернойНожкой > 0 Тогда
			Дополнительно_Картофель = Дополнительно_Картофель+Символы.ПС+"черной ножкой - "+Партия_МССО_Ссылка.ЧернойНожкой+"%";
		КонецЕсли;
		
		Если Партия_МССО_Ссылка.КольцевойГнилью > 0 Тогда
			Дополнительно_Картофель = Дополнительно_Картофель+Символы.ПС+"кольцевой гнилью - "+Партия_МССО_Ссылка.КольцевойГнилью+"%";
		КонецЕсли;
		
		Если Партия_МССО_Ссылка.Фитофторозом > 0 Тогда
			Дополнительно_Картофель = Дополнительно_Картофель+Символы.ПС+"Фитофторозом - "+Партия_МССО_Ссылка.Фитофторозом+"%";
		КонецЕсли;
		
		Если Партия_МССО_Ссылка.РезиновойСухимиГнилями > 0 Тогда
			Дополнительно_Картофель = Дополнительно_Картофель+Символы.ПС+"презиновой, сухими гнилями (фомоз, фузариозантракноз) - "+Партия_МССО_Ссылка.РезиновойСухимиГнилями+"%";
		КонецЕсли;
		
		Если Партия_МССО_Ссылка.СтеблевойНематодой > 0 Тогда
			Дополнительно_Картофель = Дополнительно_Картофель+Символы.ПС+"стеблевой нематодой - "+Партия_МССО_Ссылка.СтеблевойНематодой+"%";
		КонецЕсли;
		
		Если Партия_МССО_Ссылка.ОбыкновеннойПаршой > 0 Тогда

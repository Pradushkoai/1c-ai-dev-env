		"ВЫБРАТЬ
		|	ВзвешенныеТоварыОстатки.Склад КАК Склад,
		|	ВзвешенныеТоварыОстатки.Номенклатура КАК Номенклатура,
		|	ВзвешенныеТоварыОстатки.Серия КАК Серия,
		|	ВзвешенныеТоварыОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|	ВзвешенныеТоварыОстатки.ВРезервеОстаток КАК ВРезервеОстаток
		|ИЗ
		|	РегистрНакопления.ВзвешенныеТовары.Остатки КАК ВзвешенныеТоварыОстатки
		|ГДЕ
		|	ВзвешенныеТоварыОстатки.Склад = &Склад
		|	И ВзвешенныеТоварыОстатки.Номенклатура = &Номенклатура
		|	И ВзвешенныеТоварыОстатки.Серия = &Серия";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Склад", Склад);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Доступно =  ВыборкаДетальныеЗаписи.КоличествоОстаток - ВыборкаДетальныеЗаписи.ВРезервеОстаток;
	КонецЦикла;
	

	Возврат Доступно;

КонецФункции // ()
 
Функция НайтиОрдерКОтгрузке(Распоряжение)
	НашлиОрдер = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение КАК Распоряжение,
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|ГДЕ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение = &Распоряжение
		|	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Проведен = ИСТИНА
		|	И (РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Статус = &Статус1
		|		ИЛИ РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Статус = &Статус2
		|		ИЛИ РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Статус = &Статус3)";
	
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	Запрос.УстановитьПараметр("Статус1", Перечисления.СтатусыРасходныхОрдеров.КОтгрузке);
	Запрос.УстановитьПараметр("Статус2", Перечисления.СтатусыРасходныхОрдеров.Отгружен);
	Запрос.УстановитьПараметр("Статус3", Перечисления.СтатусыРасходныхОрдеров.Проверен);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		НашлиОрдер = ИСТИНА;
	КонецЕсли;
	
	Возврат НашлиОрдер;
	

КонецФункции // ()


Функция ПроверитьЗаявкуНаЛук(ТЧ_Товары)

	ЭтоЛук = ИСТИНА;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗ_Товары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_ТЗ_ТОВАРЫ
		|ИЗ
		|	&ТЗ_Товары КАК ТЗ_Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыТЧ.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТ_ТЗ_ТОВАРЫ КАК ТоварыТЧ
		|ГДЕ
		|	НЕ (ТоварыТЧ.Номенклатура В ИЕРАРХИИ(&Родитель))";
	
		Запрос.УстановитьПараметр("Родитель", Справочники.Номенклатура.НайтиПоКоду("00-00000016"));  ///6.  Лук-севок и чеснок
		Запрос.УстановитьПараметр("ТЗ_Товары", ТЧ_Товары);
	//Запрос.УстановитьПараметр("ТипСклада", ТипСклада);

	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	

	Если РезультатЗапроса.Количество() > 0 Тогда
	
		ЭтоЛук = ЛОЖЬ;
	
	КонецЕсли;
	
	Возврат ЭтоЛук;
	
КонецФункции

Функция ПроверитьКонтрагентаНаПризнакОтгрузкуРазрешил(Контрагент)
	ЕстьРазрешение = ЛОЖЬ;
	
	НаборЗаписей = РегистрыСведений.СписокКлиентовСПризнакомОтгрузкуРазрешил.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Контрагент.Установить(Контрагент);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество()>0 Тогда
	
		ЕстьРазрешение = ИСТИНА;
	
	КонецЕсли; 
	
	Возврат ЕстьРазрешение;
КонецФункции // ()

Функция ПолучитьТоварыСЗапретомОтгрузки(ТЧ_Товары)
	ЗапретДоставки = ЛОЖЬ;
	Для каждого стр Из ТЧ_Товары Цикл
	    Номенклатура = стр.Номенклатура;
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗапретДоставкиТоваров.Номенклатура КАК Номенклатура
			|ИЗ
			|	РегистрСведений.ЗапретДоставкиТоваров КАК ЗапретДоставкиТоваров
			|ГДЕ
			|	(ЗапретДоставкиТоваров.Номенклатура = &Номенклатура
			|			ИЛИ ЗапретДоставкиТоваров.Номенклатура = &НоменклатураРодитель1
			|			ИЛИ ЗапретДоставкиТоваров.Номенклатура = &НоменклатураРодитель2
			|			ИЛИ ЗапретДоставкиТоваров.Номенклатура = &НоменклатураРодитель3
			|			ИЛИ ЗапретДоставкиТоваров.Номенклатура = &НоменклатураРодитель4
			|			ИЛИ ЗапретДоставкиТоваров.Номенклатура = &НоменклатураРодитель5)";
		
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("НоменклатураРодитель1", Номенклатура.Родитель);
	Запрос.УстановитьПараметр("НоменклатураРодитель2", Номенклатура.Родитель.Родитель);
	Запрос.УстановитьПараметр("НоменклатураРодитель3", Номенклатура.Родитель.Родитель.Родитель);
	Запрос.УстановитьПараметр("НоменклатураРодитель4", Номенклатура.Родитель.Родитель.Родитель.Родитель);
	Запрос.УстановитьПараметр("НоменклатураРодитель5", Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель);

		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Сообщить("Строка" +стр.НомерСтроки + " "+ стр.Номенклатура + " установлен запрет доставки товара, необходимо выбрать самовывоз или согласовать другие условия доставки!" );
			ЗапретДоставки = ИСТИНА;
		КонецЦикла;

	КонецЦикла; 
	
	Возврат ЗапретДоставки;
КонецФункции // ()
  


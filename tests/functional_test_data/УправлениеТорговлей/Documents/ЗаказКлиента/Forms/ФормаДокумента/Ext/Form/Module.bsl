&НаКлиенте
Процедура СравнитьТЧ(Команда)
	
		
	Если Объект.ТоварыДоКорректировкиОрдером.Количество() = 0 Тогда
		ПоказатьПредупреждение(,
        "Заказ не изменялся.",0, "Предупреждение" );

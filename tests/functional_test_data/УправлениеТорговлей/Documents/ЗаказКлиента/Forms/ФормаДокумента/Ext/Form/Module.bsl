		//[?(ТаблицаВ.ПР="","",", примесь семян др. растений "+ ТаблицаВ.ПР+"%")]
		//[?(ТаблицаВ.М1="","",", масса 1000 семян "+ ТаблицаВ.М1+"г")]
		
		//[?(ТаблицаВ.АктОпр="","","Акт апробации № "+ТаблицаВ.АктОпр)]
		//[?(ТаблицаВ.Свид="","","Сертификат на семена № "+ТаблицаВ.Свид)]
		
		
		/////Репродукция = ?(СтрокаТовары.Серия.Партия_МССО.Репродукция = 1,", репродукция "+СтрокаТовары.Серия.Партия_МССО.Репродукция,"");
		РепродукцияЕсть = Партия_МССО_Ссылка.Репродукция;
		Если ЗначениеЗаполнено(РепродукцияЕсть) Тогда
			Репродукция = ", репродукция "+РепродукцияЕсть;
		Иначе
			Репродукция = "";
		КонецЕсли; 
		
		СортоваяЧистотаЕсть = Партия_МССО_Ссылка.СортоваяЧистота;
		Если ЗначениеЗаполнено(СортоваяЧистотаЕсть) Тогда
			СортоваяЧистота = "Сортовая чистота "+СортоваяЧистотаЕсть;
		Иначе
			СортоваяЧистота = "";
		КонецЕсли; 
		
		
		АктАпробацииЕсть = Партия_МССО_Ссылка.АктАпробации;
		Если ЗначениеЗаполнено(АктАпробацииЕсть) Тогда
			АктАпробации = "Акт апробации № "+АктАпробацииЕсть;
		Иначе
			АктАпробации = "";
		КонецЕсли; 
		
		СвидетельствоЕсть = Партия_МССО_Ссылка.Свидетельство;
		Если ЗначениеЗаполнено(СвидетельствоЕсть) Тогда
			Свидетельство = "Сертификат на семена № "+СвидетельствоЕсть;
		Иначе
			Свидетельство = "";
		КонецЕсли; 
		
		
		
		//Партия_МССО = ", партия № "+Партия_МССО_Ссылка;
		Партия_МССО = ""+Партия_МССО_Ссылка;
		

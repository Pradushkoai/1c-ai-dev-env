				Иначе
					СрокДействияАнализа = "";
				КонецЕсли;
			
		КонецЕсли; 
		
		
		//////// лук \\\\\\\\\
		
		Дополнительно_Лук = "";
		Лук_НаличиеОтходовВсего = Партия_МССО_Ссылка.Лук_НаличиеОтходовВсего;	
		Если Лук_НаличиеОтходовВсего > 0 Тогда
			Дополнительно_Лук = Дополнительно_Лук +Символы.ПС+"наличие отходов и примесей "+Лук_НаличиеОтходовВсего+"%, в том числе: "; 	
		КонецЕсли;	
		
		Лук_БольныеПоврежденные = Партия_МССО_Ссылка.Лук_БольныеПоврежденные; 
		
		Если Лук_БольныеПоврежденные > 0 Тогда

    КолДнейОтсрочкиПоДоговору = 0;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	ОтсрочкаОплатыПоДоговорамСрезПоследних.Контрагент КАК Контрагент,
    |	ОтсрочкаОплатыПоДоговорамСрезПоследних.Договор КАК Договор,
    |	ОтсрочкаОплатыПоДоговорамСрезПоследних.ОтсрочкаОплатыПоДоговору КАК ОтсрочкаОплатыПоДоговору,
    |	ОтсрочкаОплатыПоДоговорамСрезПоследних.СкидкаИндивидуальнаяПроцент КАК СкидкаИндивидуальнаяПроцент
    |ИЗ
    |	РегистрСведений.ОтсрочкаОплатыПоДоговорам.СрезПоследних(&Период, ) КАК ОтсрочкаОплатыПоДоговорамСрезПоследних
    |ГДЕ
    |	ОтсрочкаОплатыПоДоговорамСрезПоследних.Контрагент = &Контрагент
    |	И ОтсрочкаОплатыПоДоговорамСрезПоследних.Договор = &Договор";
    
    Запрос.УстановитьПараметр("Период", Объект.Дата);
    Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
    Запрос.УстановитьПараметр("Договор", Объект.Договор);
    
    РезультатЗапроса = Запрос.Выполнить();
    
    Если НЕ РезультатЗапроса.Пустой() Тогда
        ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
        
        Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
            КолДнейОтсрочкиПоДоговору = ВыборкаДетальныеЗаписи.ОтсрочкаОплатыПоДоговору;
			СкидкаИндивидуальнаяРазмер = ВыборкаДетальныеЗаписи.СкидкаИндивидуальнаяПроцент;
        КонецЦикла;
    Иначе
       КолДнейОтсрочкиПоДоговору = Объект.Договор.ОтсрочкаОплатыПоДоговору;
	   СкидкаИндивидуальнаяРазмер = Объект.Договор.СкидкаИндивидуальнаяПроцент;
    КонецЕсли; 
	
		
	//Возврат КолДнейОтсрочкиПоДоговору;
    
КонецПроцедуры 


&НаСервере
Процедура НайтиОсновнойДоговор()  //////77w qaws
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДоговорыКонтрагентов.Ссылка,
		|	ДоговорыКонтрагентов.Контрагент,
		|	ДоговорыКонтрагентов.Партнер,
		|	ДоговорыКонтрагентов.ОсновнойДоговор
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Партнер = &Партнер
		|	И ДоговорыКонтрагентов.ОсновнойДоговор = ИСТИНА";
	
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Объект.Договор = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	ДоговорПриИзмененииСервер();   //////77w qaws      для подстановки условий оплаты и расчетов по соглашению.
		
КонецПроцедуры
 


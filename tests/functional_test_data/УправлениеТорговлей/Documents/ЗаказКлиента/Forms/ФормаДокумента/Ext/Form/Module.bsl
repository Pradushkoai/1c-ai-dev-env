		Область_Секция_8.Параметры.СрокДействияАнализа = СрокДействияАнализа;
		
		//[?(ТаблицаВ.ВС="","","всхожесть "+ ТаблицаВ.ВС+"%")]
		//[?(ТаблицаВ.ВЛ="","",", влажность "+ ТаблицаВ.ВЛ+"%")]

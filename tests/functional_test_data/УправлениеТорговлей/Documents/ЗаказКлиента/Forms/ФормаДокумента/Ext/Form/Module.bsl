&НаСервере
Процедура УстановитьУсловноеОформление()
    
   
	Объект.ОтгрузкаНеОсуществляется = ОтгрузкаНеОсуществляетсяНаСервере(Объект.Партнер);	
       
	Если Объект.ОтгрузкаНеОсуществляется Тогда
		Элементы.ОтгрузкаНеОсуществляется.Видимость = Истина;
		//Элементы.ГруппаПартнер.ЦветФона = WebЦвета.Красный;
		Элементы.ГруппаШапка.ЦветФона = WebЦвета.Красный;
		Элементы.Партнер.Шрифт = ШрифтыСтиля.ШрифтОтмененнойСтрокиДокумента;
	Иначе
		Элементы.ОтгрузкаНеОсуществляется.Видимость = Ложь;
		//Элементы.ГруппаПартнер.ЦветФона = WebЦвета.Белый;
		Элементы.ГруппаШапка.ЦветФона = WebЦвета.Белый;
	КонецЕсли; 

	
	Объект.ОтгрузкаТолькоПоПредоплате = ОтгрузкаТолькоПоПредоплатеНаСервере(Объект.Партнер);	
	Если Объект.ОтгрузкаТолькоПоПредоплате Тогда
		Элементы.ОтгрузкаНеОсуществляется.Видимость = Ложь;
		Элементы.ОтгрузкаТолькоПоПредоплате.ЦветТекста = WebЦвета.Синий;
		Элементы.ОтгрузкаТолькоПоПредоплате.Доступность = Ложь;
		//Элементы.ГруппаПартнер.ЦветФона = WebЦвета.Красный;
		Элементы.ГруппаШапка.ЦветФона = WebЦвета.Оранжевый;
		Элементы.Партнер.Шрифт = ШрифтыСтиля.ШрифтВажнойНадписи;
	Иначе
		Элементы.ОтгрузкаТолькоПоПредоплате.Видимость = Ложь;
		//Элементы.ГруппаПартнер.ЦветФона = WebЦвета.Белый;
		Элементы.ГруппаШапка.ЦветФона = WebЦвета.Белый;
	КонецЕсли; 
	
	
	
	УсловноеОформление.Элементы.Очистить();

	// Условное оформление обеспечения.
	ОбщегоНазначенияУТ.УстановитьСнятьОтметкуНезаполненного(
		УсловноеОформление,"ДатаОтгрузки", "ДатаОтгрузки", "", "ДатаОтгрузкиОбязательна");
	
	ОбщегоНазначенияУТ.УстановитьСнятьОтметкуНезаполненного(
		УсловноеОформление, "ТоварыДатаОтгрузки", "ДатаОтгрузки", "Товары", "ДатаОтгрузкиОбязательна");

	ОбщегоНазначенияУТ.УстановитьСнятьОтметкуНезаполненного(
		УсловноеОформление, "ТоварыСклад", "Склад", "Товары", "СкладОбязателен");
	
	ОбщегоНазначенияУТ.УстановитьСнятьОтметкуНезаполненного(
		УсловноеОформление, "Склад", "Склад", "", "СкладОбязателен");
	
	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Состояние.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СостояниеПросрочено");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ПросроченныйДокумент);

	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Состояние.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Состояние");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Перечисления.СостоянияЗаказовКлиентов.Закрыт;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЗакрытыйДокумент);
	
	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыПроцентАвтоматическойСкидки.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();

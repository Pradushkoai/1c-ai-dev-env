&НаСервере
Процедура РазукраситьТоварыНаСервере()
	ТЧ = Объект.Товары.Выгрузить();
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВнешнийИсточник.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТ_ВнешнийИсточник
	               |ИЗ
	               |	&ТЧ КАК ВнешнийИсточник
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ВнешнийИсточник.Номенклатура КАК Номенклатура,
	               |	СУММА(1) КАК КолВо
	               |ПОМЕСТИТЬ ТАБ
	               |ИЗ
	               |	ВТ_ВнешнийИсточник КАК ВТ_ВнешнийИсточник
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_ВнешнийИсточник.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТАБ.Номенклатура КАК Номенклатура,
	               |	ТАБ.КолВо КАК КолВо
	               |ИЗ
	               |	ТАБ КАК ТАБ
	               |ГДЕ
	               |	ТАБ.КолВо > 1
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТАБ.Номенклатура,
	               |	ТАБ.КолВо";    
	
	  Запрос.УстановитьПараметр("ТЧ",ТЧ);
	  
	  РезультатЗапроса = Запрос.Выполнить();
	  
	  ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	  
	  Ном = 0;
	  Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	      Ном = Ном + 1;
		  НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура",ВыборкаДетальныеЗаписи.Номенклатура));
		  
		  Для каждого стрНайд Из НайденныеСтроки Цикл
		  
		  	  стрНайд.Ном = Ном;
		  
		  КонецЦикла;
	     
	  КонецЦикла;  
	  	  
КонецПроцедуры



&НаСервере
Процедура ЗаполнитьУпаковкамиНаСервере()
	Для каждого СтрокаТовары Из Объект.Товары Цикл
		
		
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	УпаковкиЕдиницыИзмерения.Ссылка КАК Ссылка,
			|	УпаковкиЕдиницыИзмерения.Числитель КАК Числитель,
			|	УпаковкиЕдиницыИзмерения.Знаменатель КАК Знаменатель,
			|	УпаковкиЕдиницыИзмерения.Владелец КАК Владелец,
			|	УпаковкиЕдиницыИзмерения.ПометкаУдаления КАК ПометкаУдаления
			|ИЗ
			|	Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
			|ГДЕ
			|	УпаковкиЕдиницыИзмерения.ПометкаУдаления = ЛОЖЬ
			|	И УпаковкиЕдиницыИзмерения.Владелец = &Владелец ";
			//|	И УпаковкиЕдиницыИзмерения.Владелец.ДвеЦеныВЦеннике = ИСТИНА";
			
			//Запрос.УстановитьПараметр("Владелец", СтрокаТовары.Номенклатура);
			
			Если СтрокаТовары.Номенклатура.НаборУпаковок = ПредопределенноеЗначение("Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры") Тогда
				Запрос.УстановитьПараметр("Владелец", СтрокаТовары.Номенклатура);
			Иначе
				Запрос.УстановитьПараметр("Владелец", СтрокаТовары.Номенклатура.НаборУпаковок);
			КонецЕсли;	
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			

		Если Объект.ТоварыДоКорректировкиОрдером.Количество() = 0  Тогда
			
			Коэффициент = 1;
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Если Найти(ВыборкаДетальныеЗаписи.Ссылка.Наименование, "упак") = 1 Тогда
					Коэффициент = 1;
					Коэффициент = ВыборкаДетальныеЗаписи.Числитель;
					СтрокаТовары.Упаковка = ВыборкаДетальныеЗаписи.Ссылка;
					СтрокаТовары.Количество = СтрокаТовары.КоличествоУпаковок*Коэффициент;
				КонецЕсли; 
				
			КонецЦикла;
			
		Иначе      ////////////////  после расхождений при сборке складом
			
			Коэффициент = 1;
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Если Найти(ВыборкаДетальныеЗаписи.Ссылка.Наименование, "упак") = 1 Тогда
					Коэффициент = 1;
					Коэффициент = ВыборкаДетальныеЗаписи.Числитель;
					СтрокаТовары.Упаковка = ВыборкаДетальныеЗаписи.Ссылка;
					КоличествоПервоначальноеШТ = 0;
					КоличествоПервоначальноеШТ = СтрокаТовары.КоличествоУпаковок;
					Если Коэффициент <> 0 Тогда
						СтрокаТовары.КоличествоУпаковок = КоличествоПервоначальноеШТ/Коэффициент;
						СтрокаТовары.Количество = КоличествоПервоначальноеШТ;
					КонецЕсли; 
				КонецЕсли; 
				
			КонецЦикла;
			
		КонецЕсли; 
	
			
	КонецЦикла; 

КонецПроцедуры


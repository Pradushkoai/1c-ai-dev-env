		Если ЭтотОбъект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным Тогда
			
			Заказы = ЭтотОбъект.Товары.Выгрузить();
			Заказы.Свернуть("ЗаказКлиента","");
			Заказы.Сортировать("ЗаказКлиента");
			
			Ном = 0;
			Счет = 0;                                                  
			Для Ном = 0 По Заказы.Количество()-1 Цикл
				Счет = Ном + 1;
				Выполнить("УИДЗаказа"+Счет+" = Заказы["+Ном+"].ЗаказКлиента.Ссылка.УникальныйИдентификатор()");
			КонецЦикла; 
			
			Для Ном = 1 По 9 Цикл
				Выполнить("МенеджерЗаписей.UID_ZAK"+Ном+" = УИДЗаказа"+Ном+";")	
			КонецЦикла;	
		КонецЕсли; 
		
		
		МенеджерЗаписей.ПометкаУдаления = 0;
		МенеджерЗаписей.ПризнакОбработано = 0;
		
		МенеджерЗаписей.Регистратор = ЭтотОбъект.Ссылка;
		МенеджерЗаписей.Записать(ИСТИНА);
		
	КонецЕсли; 
	
КонецПроцедуры


&НаСервере
Функция ПолучитьКурсыВалютПоПредоплате(Валюта, ДатаКурса)
  
  Запрос = Новый Запрос;
  Запрос.Текст = 
    "ВЫБРАТЬ
    |  КурсыВалютСрезПоследних.Валюта КАК Валюта,
    |  КурсыВалютСрезПоследних.Курс КАК Курс
    |ИЗ
    |  РегистрСведений.КурсыВалют.СрезПоследних(&Период, ) КАК КурсыВалютСрезПоследних
    |ГДЕ
    |  КурсыВалютСрезПоследних.Период = &Период
    |  И КурсыВалютСрезПоследних.Валюта = &Валюта";
  
  Запрос.УстановитьПараметр("Период", НачалоДня(ДатаКурса));
  Запрос.УстановитьПараметр("Валюта", Валюта);
  
  РезультатЗапроса = Запрос.Выполнить();
  
  ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
  
  КурсПредоплаты = 0;
  
  Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
    КурсПредоплаты = ВыборкаДетальныеЗаписи.Курс;
  КонецЦикла;
  
  Возврат КурсПредоплаты;
  
КонецФункции


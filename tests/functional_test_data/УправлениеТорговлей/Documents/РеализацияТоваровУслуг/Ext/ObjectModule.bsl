Функция ПроверитьЗаданиеНаДоставку(Заказ)

	ЗаданиеФормируется = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРаспоряжения.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаданиеНаПеревозку.Распоряжения КАК ЗаданиеНаПеревозкуРаспоряжения
		|ГДЕ
		|	ЗаданиеНаПеревозкуРаспоряжения.Распоряжение = &Распоряжение
		|	И ЗаданиеНаПеревозкуРаспоряжения.Ссылка.Проведен = ИСТИНА
		|	И ЗаданиеНаПеревозкуРаспоряжения.Ссылка.Статус = &Статус";
	
	Запрос.УстановитьПараметр("Распоряжение", Заказ);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЗаданийНаПеревозку.Формируется);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗаданиеФормируется = ИСТИНА;
	КонецЦикла;
	
	Возврат ЗаданиеФормируется;


КонецФункции // ()


&НаСервере
 Функция УбратьЛидирующиеНули(НомерДокумента_)
    
    Попытка
        НомерДокумента_ = Формат(Число(НомерДокумента_), "ЧГ=");
    Исключение
        НомерДокумента_ = СтрЗаменить(СокрЛ(СтрЗаменить(СокрП(НомерДокумента_), "0", " ")), " ", "0");
		
        Префикс = "";
        Пока КодСимвола(НомерДокумента_) < 48 Или КодСимвола(НомерДокумента_) > 57 Цикл
            Префикс = Префикс + Лев(НомерДокумента_, 1);
            НомерДокумента_ = Сред(НомерДокумента_, 2);
        КонецЦикла;
        Если Не ПустаяСтрока(Префикс) Тогда
            НомерДокумента_ = Префикс + УбратьЛидирующиеНули(НомерДокумента_);
        КонецЕсли;
	КонецПопытки;
	
    НомерДокумента_ = СтрЗаменить(СокрЛП(НомерДокумента_), "-", "");
	
    Возврат НомерДокумента_;
    
КонецФункции  

&НаСервере
Процедура ПечатьСвидетельстваНаСеменаНаСервере(ТабДок) Экспорт
	
	Объект = ЭтотОбъект.Ссылка;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
    //ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ДвусторонняяПечать = ТипДвустороннейПечати.ПереворотВлево;
	
	ТабДок.ПолеСнизу = 10;
	
	ТабДок.РазмерКолонтитулаСнизу = 5;
	
	//// Колонтитулы
	//ТабДок.НижнийКолонтитул.Выводить = Истина;
	//ТабДок.НижнийКолонтитул.ТекстСправа = НСтр("ru= 'Лист [&НомерСтраницы] из [&СтраницВсего]'");
	
	
	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.ОтображатьЗаголовки = Ложь;
	ТабДок.ТолькоПросмотр = Истина;	
	Макет = ПолучитьОбщийМакет("СвидетельствоНаСемена");
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	НаименованиеФирмы = "";
	
	ОбластьШапка.Параметры.Заполнить(Объект);
	
	ОбластьШапка.Параметры.Дата = ТекущаяДата();
	//ОбластьШапка.Параметры.НаименованиеФирмы = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , Объект.БанковскийСчет), "ПолноеНаименование,ИНН,ЮридическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет");
	ОбластьШапка.Параметры.НаименованиеФирмы = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , ), "ПолноеНаименование,ИНН,,,,,,");
	ОбластьШапка.Параметры.НаименованиеФирмы1 = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация, Объект.Дата, , ), ",,ЮридическийАдрес,Телефоны,,,,");
	//ОбластьШапка.Параметры.ПредставлениеПолучателя = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата,, ), "ПолноеНаименование,ИНН,ЮридическийАдрес,Телефоны,,,,");
	Если ЗначениеЗаполнено(Объект.АдресДоставки) Тогда
		ОбластьШапка.Параметры.ПредставлениеПолучателя = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата,, ), "ПолноеНаименование,ИНН,,,,,") + ", " +Объект.АдресДоставки + ", " + ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата,, ), "Телефоны,,,,") ; 
	Иначе	
		ОбластьШапка.Параметры.ПредставлениеПолучателя = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Контрагент, Объект.Дата,, ), "ПолноеНаименование,ИНН,ЮридическийАдрес,Телефоны,,,,");
	КонецЕсли;
	
	Если ЭтотОбъект.ЭтоИнтернетЗаказ Тогда
     ОбластьШапка.Параметры.ПредставлениеПолучателя = ""+СокрЛП(ЭтотОбъект.ЗаказКлиента.Клиент);
   КонецЕсли;
	
	НомерСвидетельства_ = Объект.Номер;	
	НомерСвидетельства = УбратьЛидирующиеНули(НомерСвидетельства_);
	
	ОбластьШапка.Параметры.НомерСвидетельства = НомерСвидетельства;
	
	ТабДок.Вывести(ОбластьШапка);
	
	
	Область_Секция_8  = Макет.ПолучитьОбласть("Секция_8");
	
	Ном = 0;  
	
	ТЗ_Товары = Объект.Товары.Выгрузить();
	
	ТЗ_Товары.Свернуть("Номенклатура,Серия,Упаковка","КоличествоУпаковок,Количество");
	
	//Для каждого СтрокаТовары Из Объект.Товары Цикл
	Для каждого СтрокаТовары Из ТЗ_Товары Цикл
		//Если СтрокаТовары.Отменено Тогда
		//	Продолжить;
		//КонецЕсли; 
		
		
		Если СтрокаТовары.Номенклатура.Ссылка.ВидТМЦ.ТипТМЦ = Перечисления.ТипыТМЦ.Товар Тогда
			Продолжить;
		КонецЕсли; 
		
		Если СтрокаТовары.Номенклатура.Ссылка.ВидТМЦ.ТипТМЦ = Перечисления.ТипыТМЦ.ТранспортнаяТара Тогда
			Продолжить;
		КонецЕсли; 
		
		
		Ном = Ном+1;
		Область_Секция_8.Параметры.Ном = Ном;
		
		Товар = СокрЛП(СтрокаТовары.Номенклатура.НаименованиеПолное);
		ВидРасфасовки_Есть = СтрокаТовары.Номенклатура.УпаковкаГрузомест;
		
		Если ЗначениеЗаполнено(ВидРасфасовки_Есть) Тогда
			ВидРасфасовки = ", "+ВидРасфасовки_Есть;
		Иначе
			ВидРасфасовки = "";
		КонецЕсли; 
		
		ВесПартии = 0;
		
		Если СтрокаТовары.Номенклатура.ЕдиницаИзмерения.Вес > 0 Тогда
			ВесПартии = СтрокаТовары.Номенклатура.ЕдиницаИзмерения.Вес*СтрокаТовары.Количество;
		КонецЕсли;	 
		
		Если ВесПартии = 0 Тогда
			Если СтрокаТовары.Номенклатура.УпаковкаГрузомест.Вес  > 0 Тогда
				ВесПартии = СтрокаТовары.Номенклатура.УпаковкаГрузомест.Вес*СтрокаТовары.Количество;
			КонецЕсли; 
		КонецЕсли;
		
		Если ВесПартии = 0 Тогда
			Если СтрокаТовары.Упаковка.Вес  > 0 Тогда
				ВесПартии = СтрокаТовары.Количество*СтрокаТовары.Упаковка.Вес;
			КонецЕсли; 
		КонецЕсли;
		
		Если ВесПартии <> 0 Тогда
			//ВесПартии = ",  вес партии "+Строка(ВесПартии)+" кг.";
			ВесПартии = ""+Строка(ВесПартии)+" кг.";
		Иначе
			ВесПартии = "";
		КонецЕсли; 
		
		ВесПартии = ""+ВесПартии+Символы.ПС+""+СтрокаТовары.Количество+" "+СтрокаТовары.Упаковка.ЕдиницаИзмерения.Наименование;
		
		Партия_МССО_Ссылка = СтрокаТовары.Серия.Партия_МССО.Ссылка;
		
		
		Если Партия_МССО_Ссылка.Анализы.Количество() > 0 Тогда
			Для Каждого СтрокаАнализы Из Партия_МССО_Ссылка.Анализы Цикл 
				
				ВсхожестьЕсть = СтрокаАнализы.Всхожесть;
				Если ЗначениеЗаполнено(ВсхожестьЕсть) Тогда
					Всхожесть = "всхожесть "+ВсхожестьЕсть+"%";
				Иначе
					Всхожесть = "";
				КонецЕсли;
				
				ВлажностьЕсть = СтрокаАнализы.Влажность;
				Если ЗначениеЗаполнено(ВлажностьЕсть) Тогда
					Влажность = ", влажность "+ВлажностьЕсть+"%";
				Иначе
					Влажность = "";
				КонецЕсли;
				
				СОКЕсть = СтрокаАнализы.СОК;
				Если ЗначениеЗаполнено(СОКЕсть) Тогда
					СОК = ", семян основной культуры "+СОКЕсть+"%";
				Иначе
					СОК = "";
				КонецЕсли;
				
				ПримесиЕсть = СтрокаАнализы.Примеси;
				Если ЗначениеЗаполнено(ПримесиЕсть) Тогда
					Примеси = ", примесь семян др. растений "+ПримесиЕсть+"%";
				Иначе
					Примеси = "";
				КонецЕсли;
				
				Масса1000семянЕсть = СтрокаАнализы.Масса1000семян;
				Если ЗначениеЗаполнено(Масса1000семянЕсть) Тогда
					Масса1000семян = ", масса 1000 семян "+Масса1000семянЕсть+"г";
				Иначе
					Масса1000семян = "";
				КонецЕсли;
				
				
				
				Болезни_Вредители_КарантинныеОбъекты = "";
				
				Болезни = ", зараженность болезнями " + СтрокаАнализы.БолезниПроцент+ "%";
				Вредители = ", зараженность вредителями " + СтрокаАнализы.БолезниПроцент+ "%";
				КарантинныеОбъекты = ", карантинные объекты " + СтрокаАнализы.КарантинныеОбъекты+ " 0 шт/кг";
				
				Болезни_Вредители_КарантинныеОбъекты = ""+Болезни+Символы.ПС+Вредители+Символы.ПС+КарантинныеОбъекты;
				
				Область_Секция_8.Параметры.Болезни_Вредители = Болезни_Вредители_КарантинныеОбъекты;
				
				
				
				
				
				
				//Если ЗначениеЗаполнено(СтрокаАнализы.Примечание) = Истина Тогда
					Область_Секция_8.Параметры.Прочее = ""+Символы.ПС+СтрокаАнализы.Примечание;
				//КонецЕсли; 
				
				УдостоверениеОКондиционностиЕсть = СтрокаАнализы.УдостоверениеОКондиционности;
				Если ЗначениеЗаполнено(УдостоверениеОКондиционностиЕсть) Тогда
					УдостоверениеОКондиционности = "Удостоверение о качестве семян № "+УдостоверениеОКондиционностиЕсть;
				Иначе
					УдостоверениеОКондиционности = "";
				КонецЕсли;
				                       
				ДатаУдостоверенияЕсть = Формат(СтрокаАнализы.ДатаУдостоверения,"ДЛФ=D");
				Если ЗначениеЗаполнено(ДатаУдостоверенияЕсть) Тогда
					ДатаУдостоверения = " от "+ДатаУдостоверенияЕсть;
				Иначе
					ДатаУдостоверения = "";
				КонецЕсли;
				
				ЛабораторияЕсть = СтрокаАнализы.Лаборатория;
				Если ЗначениеЗаполнено(ЛабораторияЕсть) Тогда
					Лаборатория = ", выданное "+ЛабораторияЕсть;
				Иначе
					Лаборатория = "";
				КонецЕсли;
				
				СрокДействияАнализаЕсть = СтрокаАнализы.СрокДействияАнализа;
				
				Если НЕ ЗначениеЗаполнено(СрокДействияАнализаЕсть) Тогда
					Продолжить;
				КонецЕсли;
				Если ЗначениеЗаполнено(СрокДействияАнализаЕсть) Тогда
					СрокДействияАнализа = ", срок действия до "+Формат(СрокДействияАнализаЕсть,"ДЛФ=D");
					//СрокДействияАнализа = ""+Формат(СрокДействияАнализаЕсть,"ДЛФ=D");
				Иначе
					СрокДействияАнализа = "";
				КонецЕсли;
				
				
			КонецЦикла;
			
		Иначе
			
				ВсхожестьЕсть = Партия_МССО_Ссылка.Всхожесть;
				Если ЗначениеЗаполнено(ВсхожестьЕсть) Тогда
					Всхожесть = "всхожесть "+ВсхожестьЕсть+"%";
				Иначе
					Всхожесть = "";
				КонецЕсли;
				
				ВлажностьЕсть = Партия_МССО_Ссылка.Влажность;
				Если ЗначениеЗаполнено(ВлажностьЕсть) Тогда
					Влажность = ", влажность "+ВлажностьЕсть+"%";
				Иначе
					Влажность = "";
				КонецЕсли;
				
				СОКЕсть = Партия_МССО_Ссылка.СОК;
				Если ЗначениеЗаполнено(СОКЕсть) Тогда
					СОК = ", семян основной культуры "+СОКЕсть+"%";
				Иначе
					СОК = "";

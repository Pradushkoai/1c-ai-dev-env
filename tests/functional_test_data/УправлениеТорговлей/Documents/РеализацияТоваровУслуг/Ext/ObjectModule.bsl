Процедура ЗаполнитьДанныеДляОбменаСБухгалтерией()
	
	
	
			////////////////////// Предварительный расчет
			ТЗ_Товары = Новый ТаблицаЗначений;
			ТЗ_Товары = ЭтотОбъект.Товары.Выгрузить();
			ТЗ_Товары.Свернуть("СтавкаНДС","Сумма,СуммаНДС,СуммаСНДС");
			
    		НДС_20_ПоДоку = 0;
    		НДС_10_ПоДоку = 0;
    		БЕЗ_НДС_ПоДоку = 0;
    		
    		Выручка_С_НДС_20_ПоДоку = 0;
    		Выручка_С_НДС_10_ПоДоку = 0;
    		Выручка_БЕЗ_НДС_ПоДоку = 0;
    		
    		Для каждого Строка Из ТЗ_Товары Цикл
    			
    			Если Строка.СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
    				НДС_20_ПоДоку = НДС_20_ПоДоку + Строка.СуммаНДС;
    				Выручка_С_НДС_20_ПоДоку = Выручка_С_НДС_20_ПоДоку + Строка.СуммаСНДС;
    			КонецЕсли; 
    			
    			Если Строка.СтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда
    				НДС_10_ПоДоку = НДС_10_ПоДоку + Строка.СуммаНДС;
    				Выручка_С_НДС_10_ПоДоку = Выручка_С_НДС_10_ПоДоку + Строка.СуммаСНДС;
    			КонецЕсли; 
    			
    			Если Строка.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
    				БЕЗ_НДС_ПоДоку = БЕЗ_НДС_ПоДоку + Строка.СуммаНДС;
    				Выручка_БЕЗ_НДС_ПоДоку = Выручка_БЕЗ_НДС_ПоДоку + Строка.СуммаСНДС;
    			КонецЕсли; 
	
			КонецЦикла; 
			

			НДСВсего = 0;
			СебестоимостьВсего = 0;
			
			ТаблДвиженийВыручкаИСебестоимость = Новый ТаблицаЗначений;

			ТаблДвиженийВыручкаИСебестоимость = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаВыручкаИСебестоимостьПродаж;
   			ТаблДвиженийВыручкаИСебестоимость.Колонки.Добавить("ВидТМЦНаименование");
   			ТаблДвиженийВыручкаИСебестоимость.Колонки.Добавить("ВидТМЦСчет");
			
			СебестоимостьВсего = ТаблДвиженийВыручкаИСебестоимость.Итог("СуммаВыручкиРегл");
			НДСВсего = ТаблДвиженийВыручкаИСебестоимость.Итог("СуммаВыручкиСНДСРегл") - ТаблДвиженийВыручкаИСебестоимость.Итог("СуммаВыручкиРегл");
			
			Для каждого СтрокаДвижения Из ТаблДвиженийВыручкаИСебестоимость Цикл
				СтрокаДвижения.ВидТМЦНаименование = ""+СокрЛП(СтрокаДвижения.АналитикаУчетаНоменклатуры.Номенклатура.ВидТМЦ.Наименование);
				СтрокаДвижения.ВидТМЦСчет = ""+СокрЛП(СтрокаДвижения.АналитикаУчетаНоменклатуры.Номенклатура.ВидТМЦ.Счет); 
			КонецЦикла; 
			
			ТаблДвиженийВыручкаИСебестоимость.Свернуть("ВидТМЦСчет","СебестоимостьРегл");
			
			СебестоимостьФасованных4122 = 0;		
			СебестоимостьТары413 = 0;
			Себестоимость4111 = 0;
			
			Для каждого СтрокаТара Из ТаблДвиженийВыручкаИСебестоимость Цикл

				Если СокрЛП(СтрокаТара.ВидТМЦСчет) = "41.33" Тогда
					 СебестоимостьТары413 = СебестоимостьТары413 + СтрокаТара.СебестоимостьРегл;
				
				ИначеЕсли СокрЛП(СтрокаТара.ВидТМЦСчет) = "41.22" Тогда
					 СебестоимостьФасованных4122 = СебестоимостьФасованных4122 + СтрокаТара.СебестоимостьРегл;
						
					ИначеЕсли СокрЛП(СтрокаТара.ВидТМЦСчет) = "" Тогда
					 Себестоимость4111 = Себестоимость4111 + СтрокаТара.СебестоимостьРегл;
				КонецЕсли;
			КонецЦикла; 
			
			//////////////Конт информация

		
			ЮрАдрес = "";
			ФактАдрес = "";
			Телефон = "";
			Для каждого стрИнфо Из ЭтотОбъект.Контрагент.КонтактнаяИнформация Цикл
				Если стрИнфо.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента Тогда
					ЮрАдрес	= стрИнфо.Представление;			
				ИначеЕсли стрИнфо.Вид = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента Тогда
					ФактАдрес = стрИнфо.Представление;
				ИначеЕсли стрИнфо.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента Тогда
					Телефон = стрИнфо.Представление;
				КонецЕсли;
			КонецЦикла; 
			///
		БлаготворительностьОбмен = 0;
		Если ЭтотОбъект.Благотворительность = ИСТИНА Тогда
			БлаготворительностьОбмен = 1			
		КонецЕсли; 
		
		БезвозмезднаяПередача = 0;
		Если ЭтотОбъект.БезвозмезднаяПередача = ИСТИНА Тогда
			БезвозмезднаяПередача = 1;
		КонецЕсли;
					
		Если ЭтотОбъект.ПометкаУдаления = ЛОЖЬ Тогда
			ПометкаУдаления = 0;
		КонецЕсли;

	
	НаборЗаписейОбменРеализация = РегистрыСведений.Обмен_Реализация.СоздатьНаборЗаписей();
	НаборЗаписейОбменРеализация.Отбор.РеализацияСсылка.Установить(ЭтотОбъект.Ссылка);
	НаборЗаписейОбменРеализация.Прочитать();
	
	Если НаборЗаписейОбменРеализация.Количество() > 0 Тогда
		
		ЕстьИзменения = ЛОЖЬ;	
		
		Для каждого стр Из НаборЗаписейОбменРеализация Цикл
			
			Если НачалоДня(стр.ДатаДок) <> НачалоДня(ЭтотОбъект.Дата) Тогда
				стр.ДатаДок = ЭтотОбъект.Дата;
				ЕстьИзменения = ИСТИНА;
			КонецЕсли;
			
			Если стр.НомерДок <> ЭтотОбъект.НомерБСО Тогда			
				стр.НомерДок = ЭтотОбъект.НомерБСО;
				ЕстьИзменения = ИСТИНА;
			КонецЕсли; 
			
			Если СокрЛП(стр.УНП) <> СокрЛП(ЭтотОбъект.Контрагент.ИНН) Тогда
				стр.УНП = СокрЛП(ЭтотОбъект.Контрагент.ИНН);
				ЕстьИзменения = ИСТИНА;
			КонецЕсли;
			
			Если стр.Клиент <> ЭтотОбъект.Контрагент.Наименование Тогда
				стр.Клиент = ЭтотОбъект.Контрагент.Наименование;
				ЕстьИзменения = ИСТИНА;
			КонецЕсли; 
			
			Если стр.КлиентПолноеНаименование <> ЭтотОбъект.Контрагент.НаименованиеПолное Тогда
				стр.КлиентПолноеНаименование = ЭтотОбъект.Контрагент.НаименованиеПолное;
				ЕстьИзменения = ИСТИНА;
			КонецЕсли; 
			
			Если стр.КодФилиалаКонтрагента <> ЭтотОбъект.Контрагент.КодФилиала Тогда
				стр.КодФилиалаКонтрагента = ЭтотОбъект.Контрагент.КодФилиала;
				ЕстьИзменения = ИСТИНА;
			КонецЕсли;
			
			Если стр.СуммаДокумента <> ЭтотОбъект.СуммаДокумента Тогда
				стр.СуммаДокумента = ЭтотОбъект.СуммаДокумента;
				ЕстьИзменения = ИСТИНА;
			КонецЕсли;
			
			Если стр.Договор <> ЭтотОбъект.Договор.Наименование Тогда			
				стр.Договор = ЭтотОбъект.Договор.Наименование;

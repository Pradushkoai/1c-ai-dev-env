        КонецЕсли;
	Иначе
		 ЭтотОбъект.ДатаПлатежа = ЭтотОбъект.ДатаПлатежа;
	КонецЕсли;	
	//////77w qaws
	
	

		Если Константы.ВыпискаБудущейДатой_Реализация_МССО.Получить() = ИСТИНА Тогда
			

	Объект = ЭтотОбъект.Ссылка;
	Если Объект.Контрагент.Партнер.СогласиеКлиентаНаПолучениеРассылкиЭлДок = ИСТИНА Тогда
		
		ПутьКФайлуЭД     = "";
		ИмяФайла	   = "";
		ПолноеИмяФайла = "";
		
		ПутьКФайлу = "\\192.168.0.111\DATA_EXCHANGE_1C83\E_DOC\";
		НомСвид = "";
		НомСвид = Объект.Номер;
		ИмяФайла = ""+ВидСчета +" "+УбратьЛидирующиеНули(НомСвид)+".xls";
		ПутьКФайлуЭД = ПутьКФайлу+ИмяФайла;
		
		ТабДок.Записать(ПутьКФайлуЭД, ТипФайлаТабличногоДокумента.XLS);
		
		МенеджерЗаписи = РегистрыСведений.РассылкаЭлектронныхДокументовКлиентам.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Контрагент = Объект.Контрагент;

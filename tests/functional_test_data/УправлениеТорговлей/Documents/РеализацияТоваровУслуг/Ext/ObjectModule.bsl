функция ПолучитьСтатусПолучателя(Статус)
	
	Если Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Покупатель Тогда
		СтатусПолучателя = "CUSTOMER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Потребитель Тогда
		СтатусПолучателя = "CONSUMER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комитент Тогда
		СтатусПолучателя = "CONSIGNOR";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комиссионер Тогда
		СтатусПолучателя = "COMMISSIONAIRE";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПолучающийВычеты Тогда
		СтатусПолучателя = "TAX_DEDUCTION_RECIPIENT";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПокупательОбъектаУИностраннойОрганизации Тогда
		СтатусПолучателя = "FOREIGN_ORGANIZATION_BUYER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПолучающийОборотыПоРеализации Тогда
		СтатусПолучателя = "TURNOVERS_ON_SALE_RECIPIENT";
	КонецЕсли;
	
	Возврат СтатусПолучателя;
	
КонецФункции

функция ПолучитьСтатусПоставщика(Статус)
	
	Если Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Продавец Тогда
		СтатусПоставщика = "SELLER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комитент Тогда
		СтатусПоставщика = "CONSIGNOR";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Комиссионер Тогда
		СтатусПоставщика = "COMMISSIONAIRE";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ИностраннаяОрганизация Тогда
		СтатусПоставщика = "FOREIGN_ORGANIZATION";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Посредник Тогда
		СтатусПоставщика = "AGENT";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.Заказчик Тогда
		СтатусПоставщика = "DEVELOPER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ДоверительныйУправляющий Тогда
		СтатусПоставщика = "TRUSTEE";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПередающийВычеты Тогда
		СтатусПоставщика = "TAX_DEDUCTION_PAYER";
	ИначеЕсли Статус=Перечисления.СтатусыКонтрагентаЭСЧФ.ПлательщикПередающийОборотыПоРеализации Тогда
		СтатусПоставщика = "TURNOVERS_ON_SALE_PAYER";
	КонецЕсли;
	Возврат СтатусПоставщика;
	
КонецФункции



Функция  КомпонентаУстановлена(ТекстОшибки, Отказ)
	
	EVatService = Неопределено;
	
	Попытка 
		#Если ВебКлиент Тогда
			ПодключитьВнешнююКомпоненту("ОбщийМакет.EInvVatService_Локализация");
			EVatService = Новый ComОбъект("EInvVatService.Connector");
		#Иначе 
			EVatService = Новый ComОбъект("EInvVatService.Connector");
		#КонецЕсли	
		
	Исключение
		ТекстОшибки = Описаниеошибки(); //Нстр("ru='Не установлена компонента для доступа к порталу ЭСЧФ'");
		Отказ = Истина;
	КонецПопытки;
	

&НаСервере
Процедура ОбработкаПрисоединенныхФайловНаСервере() Экспорт
	
	МассивФайлов = Новый Массив;
	ПутьКФайлу = "\\192.168.0.111\DATA_EXCHANGE_1C83\E_DOC\";

	Объект = ЭтотОбъект.Ссылка;
	
	Для каждого Строка Из ЭтотОбъект.Товары Цикл
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПартионныеКарточкиПрисоединенныеФайлы.Ссылка КАК Ссылка,
			|	ПартионныеКарточкиПрисоединенныеФайлы.ВладелецФайла КАК ВладелецФайла,
			|	ПартионныеКарточкиПрисоединенныеФайлы.ПутьКФайлу КАК ПутьКФайлу
			|ИЗ
			|	Справочник.ПартионныеКарточкиПрисоединенныеФайлы КАК ПартионныеКарточкиПрисоединенныеФайлы
			|ГДЕ
			|	ПартионныеКарточкиПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла
			|	И ПартионныеКарточкиПрисоединенныеФайлы.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("ВладелецФайла", Строка.Серия.Партия_МССО);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ПутьКФайлуЭД     = "";
			ИмяФайла	   = "";
			ПолноеИмяФайла = "";
			
			ИмяФайла = ВыборкаДетальныеЗаписи.Ссылка.Наименование;
			РасширениеФайла = ВыборкаДетальныеЗаписи.Ссылка.Расширение;
			СсылкаНаФайл = ПолучитьНавигационнуюСсылку(ВыборкаДетальныеЗаписи.Ссылка);
			ДвоичныйФайл = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДетальныеЗаписи.ссылка);
			
			ПутьКФайлуЭД = ПутьКФайлу+ИмяФайла+"."+РасширениеФайла;

			ДвоичныйФайл.Записать(ПутьКФайлуЭД);
			
			Если Объект.Контрагент.Партнер.СогласиеКлиентаНаПолучениеРассылкиЭлДок = ИСТИНА Тогда
				
				
				МенеджерЗаписи = РегистрыСведений.РассылкаЭлектронныхДокументовКлиентам.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Контрагент = Объект.Контрагент;
				МенеджерЗаписи.Документ = Объект.Ссылка;
				МенеджерЗаписи.ПутьКФайлуЭД = ПутьКФайлуЭД; 
				
				
				ЗапросЭП = Новый Запрос;
				ЗапросЭП.Текст = 
				"ВЫБРАТЬ
				|	ПунктыРазгрузкиПогрузкиКлиентов.ЭлектроннаяПочта КАК ЭлектроннаяПочта
				|ИЗ
				|	Справочник.ПунктыРазгрузкиПогрузкиКлиентов КАК ПунктыРазгрузкиПогрузкиКлиентов
				|ГДЕ
				|	ПунктыРазгрузкиПогрузкиКлиентов.ПометкаУдаления = ЛОЖЬ
				|	И ПунктыРазгрузкиПогрузкиКлиентов.Владелец = &Владелец
				|	И ПунктыРазгрузкиПогрузкиКлиентов.Наименование = &Наименование";
				
				ЗапросЭП.УстановитьПараметр("Владелец", Объект.Контрагент.Партнер);
				ЗапросЭП.УстановитьПараметр("Наименование", Объект.АдресДоставки);
				
				РезультатЗапросаЭП = ЗапросЭП.Выполнить();
				
				ВыборкаДетальныеЗаписиЭП = РезультатЗапросаЭП.Выбрать();
				
				АдресЭлПочты = "";
				Пока ВыборкаДетальныеЗаписиЭП.Следующий() Цикл
					АдресЭлПочты = ВыборкаДетальныеЗаписиЭП.ЭлектроннаяПочта;
				КонецЦикла;
				
				Если ЗначениеЗаполнено(АдресЭлПочты) Тогда
					МенеджерЗаписи.АдресЭлПочты = СокрЛП(АдресЭлПочты);
				Иначе
					Ном = 0;
					Для каждого Строка Из Объект.Контрагент.Партнер.КонтактнаяИнформация Цикл
						Если Строка.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
							МенеджерЗаписи.АдресЭлПочты = Строка.Представление;
						КонецЕсли; 
					КонецЦикла;
					
				КонецЕсли; 
				
				МенеджерЗаписи.Записать(Истина);
				
			КонецЕсли;   
			
		КонецЦикла;
		
	КонецЦикла; 
	
	
КонецПроцедуры

Функция ПроверитьКонтрагентаНаПризнакОтгрузкуРазрешил(Контрагент)
	ЕстьРазрешение = ЛОЖЬ;
	
	НаборЗаписей = РегистрыСведений.СписокКлиентовСПризнакомОтгрузкуРазрешил.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Контрагент.Установить(Контрагент);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество()>0 Тогда
	
		ЕстьРазрешение = ИСТИНА;
	
	КонецЕсли; 
	
	Возврат ЕстьРазрешение;
КонецФункции // ()

Функция ПолучитьЗаказыПоРеализации(Ссылка)
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.ЗаказКлиента КАК ЗаказКлиента
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И  ТИПЗНАЧЕНИЯ(РеализацияТоваровУслугТовары.Ссылка) = ТИП(Документ.ЗаказКлиента)
		|
		|СГРУППИРОВАТЬ ПО
		|	РеализацияТоваровУслугТовары.ЗаказКлиента";
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
	Возврат РезультатЗапроса;	

КонецФункции // ()



// SEC001: SQL-инъекция — конкатенация в запросе
Функция ПолучитьТоварыПоКатегории(Категория) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ * ИЗ Справочник.Товары ГДЕ Категория = '" + Категория + "'";

	Возврат Запрос.Выполнить();

КонецФункции

// SEC002: Выполнить с динамическим кодом
Процедура ВыполнитьДинамическийКод(ИмяМетода) Экспорт

	Код = ИмяМетода + "(Параметры)";
	Выполнить(Код);

КонецПроцедуры

// SEC004: Хардкод пароля
Функция ПолучитьПароль() Экспорт
	Пароль = "Secret123!";
	Возврат Пароль;
КонецФункции

// SEC007: Привилегированный режим безусловно
Процедура УстановитьПривилегии() Экспорт
	УстановкаПривилегированногоРежима(Истина);
КонецПроцедуры

// SEC008: ЗапуститьПриложение с динамическим путём
Процедура ЗапуститьВнешнююПрограмму(Путь) Экспорт
	ЗапуститьПриложение(Путь);
КонецПроцедуры

// bsl-ls-bp-002: Функция без Возврат
Функция ФункцияБезВозврата()

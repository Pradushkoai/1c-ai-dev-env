// Общий модуль: ОбщегоНазначения
// Чистый код — для тестирования что анализаторы НЕ находят ложных нарушений

#Область ПрограммныйИнтерфейс

// Найти элемент справочника по коду (параметризованный запрос — безопасно)
Функция НайтиПоКоду(СсылкаНаСправочник, КодЭлемента) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Справочник.Ссылка
		|ИЗ
		|	Справочник.Товары КАК Справочник
		|ГДЕ
		|	Справочник.Код = &Код";

	Запрос.УстановитьПараметр("Код", КодЭлемента);
	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Результат.Выбрать().Ссылка;

КонецФункции

// Проверить заполнение обязательных полей
Функция ПроверитьЗаполнение(Объект) Экспорт

	Если Не ЗначениеЗаполнено(Объект.Наименование) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;

КонецФункции

#КонецОбласти

// Шаблон: Модуль формы отчёта на СКД
// Заменяемые переменные: {{NAME}}, {{SYNONYM}}

#Область ОписаниеПеременных

Перем СхемаКомпоновкиДанных;
Перем НастройкиКомпоновки;
Перем АдресНастроек;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Инициализация формы отчёта {{NAME}}
	ИнициализироватьОтчет();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СформироватьОтчет(Команда)
	
	// Сохраняем настройки перед выполнением на сервере
	СохранитьНастройкиНаСервере();
	
	// Выполняем отчёт
	СформироватьНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область Серверные процедуры

&НаСервере
Процедура ИнициализироватьОтчет()
	
	// Получаем СКД-схему из модуля объекта
	ОбъектОтчет = РеквизитФормыВЗначение("Отчет");
	СхемаКомпоновкиДанных = ОбъектОтчет.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	НастройкиКомпоновки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	
	// Инициализация компоновщика настроек
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиКомпоновки);
	
	// Сохраняем настройки в адрес
	АдресНастроек = ПоместитьВоВременноеХранилище(НастройкиКомпоновки, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройкиНаСервере()
	
	НастройкиКомпоновки = КомпоновщикНастроек.ПолучитьНастройки();
	АдресНастроек = ПоместитьВоВременноеХранилище(НастройкиКомпоновки, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Процедура СформироватьНаСервере()
	
	// Получаем настройки из временного хранилища
	Настройки = ПолучитьИзВременногоХранилища(АдресНастроек);
	
	// Формируем отчёт
	ОбъектОтчет = РеквизитФормыВЗначение("Отчет");
	РезультатОтчета = ОбъектОтчет.СформироватьОтчетИзНастроек(Настройки);
	
	// Выводим результат в элемент формы
	ЗначениеВРеквизитФормы(РезультатОтчета, "Результат");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// TODO: Добавьте служебные процедуры и функции

#КонецОбласти

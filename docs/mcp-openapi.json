{
  "openapi": "3.0.3",
  "info": {
    "title": "1C AI Dev Environment — MCP Tools API",
    "description": "MCP (Model Context Protocol) tools for 1C development.\n\nКаждый endpoint соответствует MCP tool. Параметры передаются в JSON body.",
    "version": "7.0.0",
    "contact": {
      "name": "Pradushkoai",
      "url": "https://github.com/Pradushkoai/1c-ai-dev-env"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "stdio://1c-ai-mcp",
      "description": "MCP server (stdio transport)"
    }
  ],
  "paths": {
    "/tools/bsl_templates": {
      "post": {
        "summary": "bsl_templates",
        "description": "Список доступных шаблонов: 15 query-шаблонов (SELECT-запросы) + BSL code-шаблоны (готовые функции). Query категории: basic, virtual_tables, batch, analytics, catalogs, documents. BSL категории: catalog, document, form, http, json, query, security. Если category указан — возвращает шаблоны только этой категории. Пример: bsl_templates(category='query'). Пример: bsl_templates(category='virtual_tables').",
        "operationId": "bsl_templates",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "string",
                    "description": "Optional parameter: category"
                  }
                },
                "required": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/check_bsl_context": {
      "post": {
        "summary": "check_bsl_context",
        "description": "B7: Проверка BSL-кода на доступность методов в целевом контексте. CTX001: метод недоступен (ERROR), CTX002: устарел (WARNING). Пример: check_bsl_context(code='...', target_context=['thin_client']).",
        "operationId": "check_bsl_context",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string",
                    "description": "Required parameter: code"
                  },
                  "target_context": {
                    "type": "string",
                    "description": "Optional parameter: target_context"
                  }
                },
                "required": [
                  "code"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/data_status": {
      "post": {
        "summary": "data_status",
        "description": "Статус данных проекта: что доступно (платформа, конфигурации), что нужно перестроить, доступен ли autosave пакет. Возвращает: has_platform_index, has_platform_methods, configs[], autosave_available. Пример: data_status().",
        "operationId": "data_status",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {},
                "required": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/generate_query": {
      "post": {
        "summary": "generate_query",
        "description": "Phase B: Генерация запроса 1С по описанию задачи. Принимает описание на русском (напр. 'продажи по месяцам за последний год'), возвращает готовый текст запроса с параметрами, объяснением и ссылкой на паттерн knowledge base. 15 шаблонов в 6 категориях: базовые, виртуальные таблицы, пакетные, аналитика, справочники, документы. Пример: generate_query(task='топ-10 клиентов по выручке', config_name='ut11').",
        "operationId": "generate_query",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "task": {
                    "type": "string",
                    "description": "Required parameter: task"
                  },
                  "config_name": {
                    "type": "string",
                    "description": "Optional parameter: config_name"
                  },
                  "object_hints": {
                    "type": "string",
                    "description": "Optional parameter: object_hints"
                  }
                },
                "required": [
                  "task"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/get_method_details": {
      "post": {
        "summary": "get_method_details",
        "description": "B7: Полная карточка метода платформы 1С: синтаксис, параметры, описание, доступность (9 контекстов), пример, версию. Пример: get_method_details(name='ЗаписьЖурналаРегистрации').",
        "operationId": "get_method_details",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Required parameter: name"
                  },
                  "platform_version": {
                    "type": "string",
                    "description": "Optional parameter: platform_version"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/get_method_details_batch": {
      "post": {
        "summary": "get_method_details_batch",
        "description": "F2.2: Batch-вызов get_method_details — карточки нескольких методов одним запросом. ИСПОЛЬЗУЙТЕ вместо N отдельных get_method_details вызовов. Опционально: target_context — проверит доступность методов в контексте и вернёт not_available_in_context + deprecated списки. Максимальный batch: 50 методов. Пример: get_method_details_batch(names=['Сообщить', 'ЗаписьЖурналаРегистрации'], target_context='thin_client').",
        "operationId": "get_method_details_batch",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "names": {
                    "type": "string",
                    "description": "Required parameter: names"
                  },
                  "platform_version": {
                    "type": "string",
                    "description": "Optional parameter: platform_version"
                  },
                  "target_context": {
                    "type": "string",
                    "description": "Optional parameter: target_context"
                  }
                },
                "required": [
                  "names"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/get_object_structure": {
      "post": {
        "summary": "get_object_structure",
        "description": "Полная структура объекта конфигурации: ресурсы, измерения, реквизиты (с типами), табличные части. ВЫЗЫВАЙТЕ ПЕРЕД НАПИСАНИЕМ ЗАПРОСА для получения точных имён полей. Если object_name не указан — список всех объектов. Пример: get_object_structure(config_name='ut11', object_name='ВыручкаИСебестоимостьПродаж').",
        "operationId": "get_object_structure",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",

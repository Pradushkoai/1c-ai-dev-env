    "/tools/solve_check": {
      "post": {
        "summary": "solve_check",
        "description": "Полная проверка .bsl кода: 7 анализаторов. Уровни: 'quick' (4 анализатора, без Java), 'standard' (quick + BSL LS), 'full' (standard + code_metrics + metadata_standards). Возвращает: total_errors, total_warnings, violations, verdict, analyzers_run, metrics (для full). verdict: 'ready' (0 errors), 'warnings' (0 errors, есть warnings), 'errors' (есть errors). Пример: solve_check(file_path='/tmp/module.bsl', level='standard')",
        "operationId": "solve_check",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file_path": {
                    "type": "string",
                    "description": "Required parameter: file_path"
                  },
                  "level": {
                    "type": "string",
                    "description": "Optional parameter: level"
                  }
                },
                "required": [
                  "file_path"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/solve_context": {
      "post": {
        "summary": "solve_context",
        "description": "META-TOOL: сбор контекста + workflow recommendations. ВЫЗЫВАЙТЕ ПЕРВЫМ при решении любой задачи. Анализирует тип задачи (запрос, обработка, аудит, архитектура, поиск) и возвращает _workflow — пошаговый план какие tools вызывать и в каком порядке. Собирает 7 источников: методы платформы (BM25), API-справочник, структура объектов, СКД-схемы, формы, база знаний, стандарты. Пример: solve_context(query='написать запрос к регистру продаж', config='ut11').",
        "operationId": "solve_context",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Required parameter: query"
                  },
                  "config": {
                    "type": "string",
                    "description": "Optional parameter: config"
                  },
                  "limit": {
                    "type": "string",
                    "description": "Optional parameter: limit"
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing required parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }

          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/tools/get_safe_methods": {
      "post": {
        "summary": "get_safe_methods",
        "description": "F2.3: Pre-hoc guidance — возвращает методы платформы 1С, ДОСТУПНЫЕ в target_context и не устаревшие. ИСПОЛЬЗУЙТЕ ДО генерации BSL-кода — получите сразу безопасный набор, вместо post-hoc проверки через check_bsl_context. Опционально: intent — фильтр по типу задачи (query, form, catalog, document, register, security, http, json, file, string, date). Пример: get_safe_methods(target_context='thin_client', intent='query', limit=20).",
        "operationId": "get_safe_methods",
        "tags": [
          "MCP Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "target_context": {
                    "type": "string",
                    "description": "Required parameter: target_context"
                  },
                  "intent": {
                    "type": "string",
                    "description": "Optional parameter: intent"
                  },
                  "limit": {
                    "type": "string",
                    "description": "Optional parameter: limit"
                  },
                  "platform_version": {
                    "type": "string",
                    "description": "Optional parameter: platform_version"
                  }
                },
                "required": [
                  "target_context"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {

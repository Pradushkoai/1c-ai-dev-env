                    "type": "string",
                    "description": "Required parameter: config_name"
                  },
                  "object_name": {
                    "type": "string",
                    "description": "Optional parameter: object_name"
                  },
                  "object_type": {
                    "type": "string",
                    "description": "Optional parameter: object_type"
                  }
                },
                "required": [

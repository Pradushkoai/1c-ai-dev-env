{
  "version": "3.19.0",
  "name": "1C AI Development Environment",
  "description": "Среда разработки 1С с ИИ-ассистентом: BM25 поиск, API-справочники, BSL LS, MCP-сервер",
  "system_dependencies": {
    "java": ">=17 (для BSL Language Server, опционально)",
    "python": ">=3.10",
    "git": "any",
    "unzip": "any"
  },
  "python_dependencies": [
    "python-dotenv>=1.0.0"
  ],
  "python_dependencies_optional": [
    "fastembed>=0.8.0",
    "qdrant-client>=1.0.0",
    "mcp>=1.0.0"
  ],
  "python_dependencies_dev": [
    "pytest>=7.0",
    "mcp>=1.0.0"
  ],
  "git_repositories": [
    {
      "name": "ai_rules_1c",
      "url": "https://github.com/Pradushkoai/ai_rules_1c.git"
    },
    {
      "name": "bsl-language-server",
      "url": "https://github.com/Pradushkoai/bsl-language-server.git"
    },
    {
      "name": "bsl-parser",
      "url": "https://github.com/Pradushkoai/bsl-parser.git"
    },
    {
      "name": "claude-code-skills-1c",
      "url": "https://github.com/Pradushkoai/claude-code-skills-1c.git"
    },
    {
      "name": "claude-code-bsl-lsp",
      "url": "https://github.com/Pradushkoai/claude-code-bsl-lsp.git"
    },
    {
      "name": "EDT-MCP",
      "url": "https://github.com/Pradushkoai/EDT-MCP.git"
    },
    {
      "name": "MCP-DB-Client",
      "url": "https://github.com/Pradushkoai/MCP-DB-Client.git"
    },
    {
      "name": "OneScript",
      "url": "https://github.com/Pradushkoai/OneScript.git"
    },
    {
      "name": "add",
      "url": "https://github.com/Pradushkoai/add.git"
    },
    {
      "name": "OpenIntegrations",
      "url": "https://github.com/Pradushkoai/OpenIntegrations.git"
    },
    {
      "name": "1c-agent-based-dev-framework",
      "url": "https://github.com/Pradushkoai/1c-agent-based-dev-framework.git"
    },
    {
      "name": "1c-ai-rules",
      "url": "https://github.com/Pradushkoai/1c-ai-rules.git"
    },
    {
      "name": "1c-standards-claude-skill",
      "url": "https://github.com/Pradushkoai/1c-standards-claude-skill.git"
    },
    {
      "name": "bsl-help-toc-parser",
      "url": "https://github.com/Pradushkoai/bsl-help-toc-parser.git"
    },
    {
      "name": "claude_rules_1c",
      "url": "https://github.com/Pradushkoai/claude_rules_1c.git"
    }
  ],
  "bsl_language_server": {
    "version": "1.0.1",
    "url": "https://github.com/1c-syntax/bsl-language-server/releases/download/v1.0.1/bsl-language-server_nix.zip",
    "install_path": "~/.local/share/bsl-language-server",
    "binary_path": "~/.local/bin/bsl-language-server"
  },
  "scripts": [
    {
      "name": "cf_extractor.py",
      "purpose": "Распаковка .cf/.cfe/.epf файлов (Container32 + Container64, без v8unpack)"
    },
    {
      "name": "v8_metadata_parser.py",
      "purpose": "Парсер метаданных 1С (V2 type map для 8.3.24+)"
    },
    {
      "name": "cf_to_xml_adapter.py",
      "purpose": "Конвертер распакованного .cf в XML формат"
    },
    {
      "name": "hbk_extractor.py",
      "purpose": "Распаковка .hbk файлов синтакс-помощника"
    },
    {
      "name": "build_config_index_generic.py",
      "purpose": "Индексация метаданных конфигурации"
    },
    {
      "name": "build_syntax_helper_index.py",
      "purpose": "Индексация методов 1С из .hbk (8141 методов)"
    },
    {
      "name": "build_api_reference.py",
      "purpose": "API-справочник экспортных методов конфигурации"
    },
    {
      "name": "fast_search_1c.py",
      "purpose": "BM25 + триграммы поиск по методам платформы 1С"
    },
    {
      "name": "check_1c_standards.py",
      "purpose": "56 правил стандартов 1С (стилистика, антипаттерны, запросы)"
    },
    {
      "name": "check_metadata_standards.py",
      "purpose": "18 правил для XML метаданных объектов"
    },
    {
      "name": "test_mcp_e2e.py",
      "purpose": "E2E тест MCP-сервера через stdio"
    }
  ],
  "src_modules": [
    {
      "name": "src/mcp_server.py",
      "purpose": "MCP-сервер (8 tools для IDE/LLM)"
    },
    {
      "name": "src/project.py",
      "purpose": "Project — оркестратор всех сервисов"
    },
    {
      "name": "src/cli.py",
      "purpose": "Единый CLI (config, bsl, search, standards, solve, mcp, data, backup)"
    },
    {
      "name": "src/exceptions.py",
      "purpose": "Кастомные исключения (ConfigNotFoundError, BuildError, etc.)"
    },
    {
      "name": "src/services/path_manager.py",
      "purpose": "PathManager — единый источник путей (OOP)"
    },
    {
      "name": "src/services/config_manager.py",
      "purpose": "ConfigManager — add/build/archive конфигураций"
    },
    {
      "name": "src/services/bsl_analyzer.py",
      "purpose": "BSLAnalyzer — wrapper над BSL LS (analyze/baseline/diff)"
    },
    {
      "name": "src/services/search.py",
      "purpose": "TF-IDF поиск (legacy v1)"
    },
    {
      "name": "src/services/search_bm25.py",
      "purpose": "BM25 + триграммы + стеммер (v2, по умолчанию)"
    },
    {
      "name": "src/services/data_package.py",
      "purpose": "DataPackage — persistence данных (autosave/autoload)"
    },
    {
      "name": "src/services/github_releases.py",
      "purpose": "GitHub Releases — push/pull data-пакета через REST API"
    }
  ],
  "mcp_tools": [
    {"name": "list_configs", "description": "Список загруженных конфигураций 1С"},
    {"name": "search_1c_methods", "description": "BM25 поиск по 8141 методам платформы"},
    {"name": "get_api_reference", "description": "API-справочник общих модулей конфигурации"},
    {"name": "analyze_bsl", "description": "Анализ .bsl через BSL LS (187 диагностик)"},
    {"name": "check_standards", "description": "Проверка на 56 правил стандартов 1С"},
    {"name": "solve_context", "description": "Сбор контекста для решения задачи"},
    {"name": "solve_check", "description": "Полная проверка .bsl кода"},
    {"name": "data_status", "description": "Статус данных проекта"}
  ],
  "user_data": {
    "description": "Пользователь предоставляет:",
    "items": [
      "ZIP выгрузки конфигураций (через Конфигуратор → Сохранить в файлы)",
      ".hbk файлы синтакс-помощника (из C:\\Program Files\\1cv8\\<версия>\\bin\\ru\\)",
      ".cf/.cfe файлы (через cf_extractor — без внешних зависимостей)"
    ]
  },
  "indexes_generated": [
    {
      "name": "syntax-helper-index",
      "input": "derived/platform/syntax-helper/shcntx_ru/",
      "output": "derived/platform/syntax-helper-index.json",
      "stats": "8141 методов платформы 1С"
    },
    {
      "name": "fast-search-index (BM25 v2)",
      "input": "derived/platform/syntax-helper-index.json",
      "output": "derived/platform/fast-search-index.json",
      "stats": "11.7 МБ, 5005 токенов, 7271 триграмм"
    },
    {
      "name": "config-api-reference",
      "input": "data/configs/<name>/CommonModules/",
      "output": "derived/configs/<name>/api-reference.json",
      "stats": "115666 методов в 7419 модулях (4 configs)"
    }
  ],
  "architecture": {
    "version": "3.0",
    "layers": {
      "data": "Исходные данные (configs, archives, hbk)",
      "derived": "Производные (BM25 индекс, API-справочники, syntax-helper)",
      "tools": "Инструменты (15 git репозиториев + BSL LS binary)",
      "runtime": "Файлы работы (paths, registry, session-resume, worklog)"
    }
  },
  "tests": {
    "total": 314,
    "framework": "pytest",
    "coverage": [
      "PathManager, ConfigManager, Configuration model",
      "BSLAnalyzer (mock subprocess)",
      "Search: TF-IDF + BM25 + триграммы + стеммер",
      "cf_extractor (32+64 бита), v8_metadata_parser V2",
      "DataPackage, GitHubReleases",
      "56 правил check_1c_standards, 18 правил check_metadata_standards",
      "MCP-сервер (8 tools, E2E через stdio)"
    ]
  },
  "persistence": {
    "data_package": {
      "size_mb": 146.2,
      "files": 60191,
      "configs": ["edo2", "edo3", "ut11", "unp"],
      "total_methods": 115666
    },
    "github_release": {
      "tag": "data-package",
      "url": "https://github.com/Pradushkoai/1c-ai-dev-env/releases/tag/data-package"
    }
  },
  "forks": {
